# ---------------------------------------------------------------------------- #
#               ------- Homebox Configuration File ------
# ---------------------------------------------------------------------------- #
# https://homebox.software/en/configure/

# Application mode used for runtime behavior. [development, production]
HBOX_MODE=production

# Enable demo mode (resets data on a schedule, used by the official demo site).
# HBOX_DEMO=false

# ---------------------------------------------------------------------------- #
#               ------- Authentication ------
# ---------------------------------------------------------------------------- #
# Pepper value added to API keys before hashing for additional security.
HBOX_AUTH_API_KEY_PEPPER=${HOMEBOX_AUTH_API_KEY_PEPPER}

# Enable rate limiting on authentication endpoints.
# HBOX_AUTH_RATE_LIMIT_ENABLED=true

# Maximum number of login attempts before rate limit kicks in.
# HBOX_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# ---------------------------------------------------------------------------- #
#               ------- Barcode ------
# ---------------------------------------------------------------------------- #
# Enable barcode/UPC lookup to auto-fill item details when scanning product barcodes.
# HBOX_BARCODE_ENABLED=false

# API key for BarcodeSpider product lookup service (https://www.barcodelookup.com/).
# HBOX_BARCODE_API_KEY=

# Enable OpenFoodFacts as a barcode lookup provider (no API key required).
# HBOX_BARCODE_OPEN_FOOD_FACTS_ENABLED=false

# Enable OpenBeautyFacts as a barcode lookup provider (no API key required).
# HBOX_BARCODE_OPEN_BEAUTY_FACTS_ENABLED=false

# Enable OpenProductsFact as a barcode lookup provider (no API key required).
# HBOX_BARCODE_OPEN_PRODUCTS_FACT_ENABLED=false

# ---------------------------------------------------------------------------- #
#               ------- Database ------
# ---------------------------------------------------------------------------- #
# Database driver to use. [sqlite3, postgres]
HBOX_DATABASE_DRIVER=sqlite3

# SQLite database file path with connection parameters.
# HBOX_DATABASE_SQLITE_PATH=./.data/homebox.db?_pragma=busy_timeout=999&_pragma=journal_mode=WAL&_fk=1&_time_format=sqlite

# PostgreSQL host address.
# HBOX_DATABASE_HOST=db
# PostgreSQL port.
# HBOX_DATABASE_PORT=5432
# PostgreSQL username.
# HBOX_DATABASE_USERNAME=${HOMEBOX_DB_USERNAME}
# PostgreSQL password.
# HBOX_DATABASE_PASSWORD=${HOMEBOX_DB_PASSWORD}
# PostgreSQL database name.
# HBOX_DATABASE_DATABASE=postgres

# SSL mode for PostgreSQL connections. [disable, require, verify-ca, verify-full]
# HBOX_DATABASE_SSL_MODE=disable
# Path to the client SSL certificate for PostgreSQL.
# HBOX_DATABASE_SSL_CERT=
# Path to the client SSL key for PostgreSQL.
# HBOX_DATABASE_SSL_KEY=
# Path to the root SSL certificate for PostgreSQL.
# HBOX_DATABASE_SSL_ROOT_CERT=

# Connection string for a pub/sub database (used for real-time notifications between instances).
# HBOX_DATABASE_PUB_SUB_CONN_STRING=

# ---------------------------------------------------------------------------- #
#               ------- Label Maker ------
# ---------------------------------------------------------------------------- #
# Width of the generated QR code label in pixels.
# HBOX_LABEL_MAKER_WIDTH=526

# Height of the generated QR code label in pixels.
# HBOX_LABEL_MAKER_HEIGHT=200

# Font size used on the generated QR code label.
# HBOX_LABEL_MAKER_FONT_SIZE=32.0

# Additional text printed on every label (e.g., owner name or inventory name).
# HBOX_LABEL_MAKER_ADDITIONAL_INFORMATION=

# ---------------------------------------------------------------------------- #
#               ------- Log ------
# ---------------------------------------------------------------------------- #
# Log verbosity level. [trace, debug, info, warn, error, fatal, panic]
HBOX_LOG_LEVEL=info

# Log output format. [text, json]
HBOX_LOG_FORMAT=json

# ---------------------------------------------------------------------------- #
#               ------- Notifier ------
# ---------------------------------------------------------------------------- #
# Generic webhook notifier URL (supports 18+ services via the Shoutrrr library,
# e.g., Discord, Slack, Telegram, ntfy, Gotify). See https://containrrr.dev/shoutrrr/
# HBOX_NOTIFIER_0_NAME=
# HBOX_NOTIFIER_0_URL=
# Multiple notifiers can be defined by incrementing the index (0, 1, 2, ...).

# Skip TLS verification for notifier webhook calls (insecure, use only internally).
# HBOX_NOTIFIER_SKIP_TLS_VERIFY=false

# ---------------------------------------------------------------------------- #
#               ------- OIDC ------
# ---------------------------------------------------------------------------- #
# Enable OpenID Connect (OIDC) single sign-on. Requires an OIDC provider (e.g.,
# Authentik, Keycloak, Authelia). See https://homebox.software/en/quick-start/configure/oidc/
# HBOX_OIDC_ENABLED=false

# Issuer URL of the OIDC provider. Must match exactly (no trailing slash).
# HBOX_OIDC_ISSUER_URL=https://auth.example.com

# Client ID registered in the OIDC provider.
# HBOX_OIDC_CLIENT_ID=

# Client secret registered in the OIDC provider.
# HBOX_OIDC_CLIENT_SECRET=

# OAuth2 scopes to request from the OIDC provider.
# HBOX_OIDC_SCOPE=openid profile email

# Automatically redirect to the OIDC provider instead of showing the local login page.
# HBOX_OIDC_AUTO_REDIRECT=false

# Restrict OIDC login to users belonging to specific groups (comma-separated).
# HBOX_OIDC_ALLOWED_GROUPS=

# ---------------------------------------------------------------------------- #
#               ------- OpenTelemetry ------
# ---------------------------------------------------------------------------- #
# Enable OpenTelemetry tracing, logging, and error tracking.
# HBOX_OTEL_ENABLED=false

# OpenTelemetry collector endpoint (gRPC). e.g., http://otel-collector:4317
# HBOX_OTEL_ENDPOINT=

# Service name reported to the OpenTelemetry collector.
# HBOX_OTEL_SERVICE_NAME=homebox

# ---------------------------------------------------------------------------- #
#               ------- Options ------
# ---------------------------------------------------------------------------- #
# Allow new users to register. Disable after initial account creation for a private instance.
HBOX_OPTIONS_ALLOW_REGISTRATION=false

# Auto-increment asset IDs when new items are created (format: 000-001).
HBOX_OPTIONS_AUTO_INCREMENT_ASSET_ID=true

# Path to a custom currency configuration JSON file.
# HBOX_OPTIONS_CURRENCY_CONFIG=

# Allow Homebox to send anonymous usage analytics (basic system info, no personal data).
HBOX_OPTIONS_ALLOW_ANALYTICS=false

# Check GitHub for new Homebox releases and display a notification in the UI.
HBOX_OPTIONS_CHECK_GITHUB_RELEASE=true

# Allow users to log in with a local username and password (in addition to OIDC if enabled).
HBOX_OPTIONS_ALLOW_LOCAL_LOGIN=true

# Trust X-Forwarded-For / X-Forwarded-Proto headers from a reverse proxy (required behind Traefik).
# Ensures QR codes and links use https:// rather than http://.
HBOX_OPTIONS_TRUST_PROXY=true

# Public hostname of the Homebox instance (without protocol, e.g., homebox.example.com).
# Required for correct QR code URLs when behind a reverse proxy.
# HBOX_OPTIONS_HOSTNAME=${DOMAIN}

# ---------------------------------------------------------------------------- #
#               ------- SMTP ------
# ---------------------------------------------------------------------------- #
# SMTP server hostname for sending maintenance reminder and notification emails.
HBOX_MAILER_HOST=${SMTP_HOST}

# SMTP server port. Common ports: 25 (plain), 465 (SMTPS), 587 (STARTTLS).
HBOX_MAILER_PORT=${SMTP_PORT}

# SMTP username (usually the sender email address).
HBOX_MAILER_USERNAME=${SMTP_USERNAME}

# SMTP password.
HBOX_MAILER_PASSWORD=${SMTP_PASSWORD}

# Sender address shown in outgoing emails.
HBOX_MAILER_FROM=noreply-homebox@${DOMAIN}

# ---------------------------------------------------------------------------- #
#               ------- Storage ------
# ---------------------------------------------------------------------------- #
# Storage connection string. Defaults to local disk. Supported backends:
#   Local:  file:///full/path/to/data  (or leave unset to use default /data in Docker)
#   S3:     s3://bucket-name?endpoint=https://...&region=us-east-1
#   GCS:    gcs://bucket-name  (set GOOGLE_APPLICATION_CREDENTIALS env var for auth)
#   Azure:  azblob://container-name  (set AZURE_STORAGE_ACCOUNT + AZURE_STORAGE_KEY env vars for auth)
# HBOX_STORAGE_CONN_STRING=

# Prefix path appended after the connection string path (acts as a subdirectory within storage).
# HBOX_STORAGE_PREFIX_PATH=

# ---------------------------------------------------------------------------- #
#               ------- Thumbnails ------
# ---------------------------------------------------------------------------- #
# Enable automatic thumbnail generation for uploaded images.
# HBOX_THUMBNAIL_ENABLED=true

# Maximum width of generated thumbnails in pixels.
# HBOX_THUMBNAIL_MAX_WIDTH=300

# Maximum height of generated thumbnails in pixels.
# HBOX_THUMBNAIL_MAX_HEIGHT=300

# ---------------------------------------------------------------------------- #
#               ------- Web ------
# ---------------------------------------------------------------------------- #
# Port the Homebox web server listens on inside the container.
HBOX_WEB_PORT=7745

# Host address the web server binds to. Leave unset to bind to all interfaces.
# HBOX_WEB_HOST=0.0.0.0

# Maximum file upload size in megabytes.
HBOX_WEB_MAX_UPLOAD_SIZE=10

# HTTP read timeout (must include unit: s for seconds, m for minutes).
HBOX_WEB_READ_TIMEOUT=10s

# HTTP write timeout (must include unit: s for seconds, m for minutes).
HBOX_WEB_WRITE_TIMEOUT=10s

# HTTP idle connection timeout (must include unit: s for seconds, m for minutes).
HBOX_WEB_IDLE_TIMEOUT=30s

# ---------------------------------------------------------------------------- #
#               ------- Swagger / Debug ------
# ---------------------------------------------------------------------------- #
# Hostname used in the Swagger API documentation UI.
# HBOX_SWAGGER_HOST=localhost:7745

# Scheme used in the Swagger API documentation UI. [http, https]
# HBOX_SWAGGER_SCHEME=http

# Enable the Go pprof debug endpoint on HBOX_DEBUG_PORT.
# HBOX_DEBUG_ENABLED=false

# Port the debug/pprof endpoint listens on.
# HBOX_DEBUG_PORT=4000
