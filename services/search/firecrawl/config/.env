# ---------------------------------------------------------------------------- #
#               ------- Firecrawl Configuration File --------
# ---------------------------------------------------------------------------- #
# https://github.com/firecrawl/firecrawl/blob/main/SELF_HOST.md
# https://github.com/firecrawl/firecrawl/blob/main/docker-compose.yaml

ENV=production

PORT=3002
HOST=0.0.0.0

# To turn on DB authentication, you need to set up Supabase.
USE_DB_AUTHENTICATION=false

# ---------------------------------------------------------------------------- #
#               ------- Administration UI --------
# ---------------------------------------------------------------------------- #
BULL_AUTH_KEY=${FIRECRAWL_ADMIN_KEY}

# ---------------------------------------------------------------------------- #
#               ------- Broker --------
# ---------------------------------------------------------------------------- #
NUQ_RABBITMQ_URL=amqp://broker:5672

# ---------------------------------------------------------------------------- #
#               ------- Cache --------
# ---------------------------------------------------------------------------- #
REDIS_URL=redis://:${FIRECRAWL_CACHE_PASSWORD}@cache:6379
REDIS_RATE_LIMIT_URL=redis://:${FIRECRAWL_CACHE_PASSWORD}@cache:6379

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=${FIRECRAWL_DB_PASSWORD}
POSTGRES_USER=${FIRECRAWL_DB_USERNAME}

# ---------------------------------------------------------------------------- #
#               ------- FoundationDB --------
# ---------------------------------------------------------------------------- #
FDB_CLUSTER_FILE=/var/fdb/fdb.cluster

# ---------------------------------------------------------------------------- #
#               ------- Logging --------
# ---------------------------------------------------------------------------- #
LOGGING_LEVEL=INFO

# ---------------------------------------------------------------------------- #
#               ------- Ollama --------
# ---------------------------------------------------------------------------- #

# Experimental
# OLLAMA_BASE_URL=http://ollama:11434/api
# MODEL_NAME=deepseek-r1:7b
# MODEL_EMBEDDING_NAME=nomic-embed-text

# ---------------------------------------------------------------------------- #
#               ------- OpenAI --------
# ---------------------------------------------------------------------------- #

## === AI features (JSON format on scrape, /extract API) ===
# Provide your OpenAI API key here to enable AI features
OPENAI_API_KEY=${OPENAI_FIRECRAWL_API_KEY}

# Experimental
# OPENAI_BASE_URL=https://example.com/v1

# ---------------------------------------------------------------------------- #
#               ------- Proxy --------
# ---------------------------------------------------------------------------- #

# PROXY_SERVER can be a full URL (e.g. http://0.1.2.3:1234) or just an IP and port combo (e.g. 0.1.2.3:1234)
# Do not uncomment PROXY_USERNAME and PROXY_PASSWORD if your proxy is unauthenticated

# PROXY_SERVER=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# ---------------------------------------------------------------------------- #
#               ------- Scraper --------
# ---------------------------------------------------------------------------- #
PLAYWRIGHT_MICROSERVICE_URL=http://playwright:3000/scrape

# ---------------------------------------------------------------------------- #
#               ------- Search API --------
# ---------------------------------------------------------------------------- #

# By default, the /search API will use Google search.

# You can specify a SearXNG server with the JSON format enabled, if you'd like to use that instead of direct Google.
# You can also customize the engines and categories parameters, but the defaults should also work just fine.
SEARXNG_ENDPOINT=searxng:8080
# SEARXNG_ENGINES=
# SEARXNG_CATEGORIES=

# ---------------------------------------------------------------------------- #
#               ------- Supabase --------
# ---------------------------------------------------------------------------- #

# Used to support DB authentication, advanced logging, etc.
# SUPABASE_ANON_TOKEN=
# SUPABASE_URL=
# SUPABASE_SERVICE_TOKEN=

# ---------------------------------------------------------------------------- #
#               ------- Workers --------
# ---------------------------------------------------------------------------- #
HARNESS_STARTUP_TIMEOUT_MS=60000

BROWSER_POOL_SIZE=5
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
NUM_WORKERS_PER_QUEUE=8

EXTRACT_WORKER_PORT=3004
WORKER_PORT=3005

NUQ_BACKEND=
