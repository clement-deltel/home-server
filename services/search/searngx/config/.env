# ---------------------------------------------------------------------------- #
#               ------- SearXNG Environment Configuration ------
# ---------------------------------------------------------------------------- #
# Source: https://docs.searxng.org/admin/settings/index.html
# Authoritative env-var mapping: searx/settings_defaults.py (SCHEMA)
#
# These environment variables override corresponding entries in settings.yml.
# The mapping is flat: each env var maps to one specific key in the YAML tree.
# Boolean values accept: true/false, 1/0, on/off (case-insensitive).
# All env vars are optional unless noted otherwise.

# Use a specific version tag. E.g. "latest" or "2026.3.25-541c6c3cb".
#SEARXNG_VERSION=latest

# ---------------------------------------------------------------------------- #
#               ------- Settings File Location ------
# ---------------------------------------------------------------------------- #

# Path to the settings.yml file or folder containing it.
# If a folder (e.g. /etc/searxng/), SearXNG expects settings.yml inside it.
# If a file (e.g. /etc/searxng/myinstance.yml), that file IS the settings.
# When set, overrides the default /etc/searxng/settings.yml lookup.
# SEARXNG_SETTINGS_PATH=/etc/searxng

# Disable the fallback to /etc/searxng for settings discovery.
# Intended for testing; not recommended for production.
# SEARXNG_DISABLE_ETC_SETTINGS=false

# ---------------------------------------------------------------------------- #
#               ------- General ------
# ---------------------------------------------------------------------------- #

# Enable debug mode: interactive debugger, code reload, verbose logging.
# WARNING: Never enable in production. Development use only.
# Allowed: true, false, 1, 0, on, off
SEARXNG_DEBUG=false

# ---------------------------------------------------------------------------- #
#               ------- Server ------
# ---------------------------------------------------------------------------- #

# Port number for the SearXNG web application when running directly
# (does not apply behind a reverse proxy using socket communication).
# SEARXNG_PORT=8080

# Bind address for the SearXNG web application when running directly.
# SEARXNG_BIND_ADDRESS=127.0.0.1

# Public base URL of the instance, used to generate correct inbound links.
# Must be set to your actual deployment URL for production use.
# Example: https://search.example.com
SEARXNG_BASE_URL=https://${SEARXNG_HOST}

# Secret key used for cryptographic purposes (session signing, tokens).
# REQUIRED for production. Generate with: openssl rand -base64 42
SEARXNG_SECRET=${SEARXNG_SECRET}

# Enable rate limiting to block bots. Requires a valkey: database.
# Allowed: true, false
# SEARXNG_LIMITER=false

# Enable features designed for public instances (link token bot detection,
# image proxy). Not needed for local/personal use.
# Allowed: true, false
# SEARXNG_PUBLIC_INSTANCE=false

# Proxy image results through SearXNG. Uses memory space.
# Allowed: true, false
SEARXNG_IMAGE_PROXY=true

# HTTP method for search queries.
# POST: more secure (history harder to read), but breaks back-button and
#       drag-and-drop to new tabs.
# GET:  better UX (back button, tab drag-and-drop work), less private.
# Allowed: POST, GET
SEARXNG_METHOD=POST

# ---------------------------------------------------------------------------- #
#               ------- Valkey (Database / Cache) ------
# ---------------------------------------------------------------------------- #
# Note: Redis is deprecated in favor of Valkey. The SEARXNG_REDIS_URL env var
# still works but prefer SEARXNG_VALKEY_URL.

# URL to connect the Valkey database.
# Format examples:
#   valkey://[[username]:[password]]@localhost:6379/0
#   valkeys://[[username]:[password]]@localhost:6379/0
#   unix://[[username]:[password]]@/path/to/socket.sock?db=0
# Set to false or leave unset to disable.
SEARXNG_VALKEY_URL=valkey://:${SEARXNG_CACHE_PASSWORD}@cache:6379/0

# Deprecated — use SEARXNG_VALKEY_URL instead.
# SEARXNG_REDIS_URL=

# ---------------------------------------------------------------------------- #
#               ------- Debug / Logging ------
# ---------------------------------------------------------------------------- #

# Log level when debug mode is active. Defaults to DEBUG.
# Standard Python log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# SEARXNG_DEBUG_LOG_LEVEL=DEBUG
