# ---------------------------------------------------------------------------- #
#               ------- Camofox Browser Configuration File ------
# ---------------------------------------------------------------------------- #
# https://github.com/jo-inc/camofox-browser/tree/master#environment-variables
#
# Camofox Browser: Anti-detection browser server for AI agents, powered by
# Camoufox — a Firefox fork with fingerprint spoofing at the C++ level.
#
# ---------------------------------------------------------------------------- #
#               ------- Server ------
# ---------------------------------------------------------------------------- #

# HTTP port for the REST API. Also respects PORT (fallback) for Fly.io / Railway.
CAMOFOX_PORT=9377

# Fallback port used when CAMOFOX_PORT is not set (used by Fly.io, Railway).
# PORT=9377

# Node.js environment. [development, production]
NODE_ENV=development

# ---------------------------------------------------------------------------- #
#               ------- Security & Access ------
# ---------------------------------------------------------------------------- #

# Required to enable the cookie import endpoint (POST /sessions/:userId/cookies).
# Generate with: openssl rand -hex 32
# Cookie import is silently disabled (403) if this is not set.
CAMOFOX_API_KEY=${CAMOFOX_API_KEY}

# Required for POST /stop (admin shutdown endpoint). Leave empty to disable.
# Generate with: openssl rand -hex 32
CAMOFOX_ADMIN_KEY=${CAMOFOX_ADMIN_KEY}

# Global bearer token. When set, ALL routes (except /health, cookie import,
# and /stop) require Authorization: Bearer <this-key>.
# Strongly recommended for any deployment beyond localhost.
# Generate with: openssl rand -hex 32
CAMOFOX_ACCESS_KEY=${CAMOFOX_ACCESS_KEY}

# ---------------------------------------------------------------------------- #
#               ------- Browser Engine ------
# ---------------------------------------------------------------------------- #

# External Camoufox executable path. When set, skips the bundled binary download
# and launches this executable instead. Must point to a Camoufox bundle with
# sibling resources (properties.json, version.json, fontconfig/).
# Set before npm install AND at server start.
# CAMOUFOX_EXECUTABLE=

# Compatibility aliases for CAMOUFOX_EXECUTABLE (all resolve to the same value;
# CAMOUFOX_EXECUTABLE takes precedence).
# CAMOUFOX_EXECUTABLE_PATH=
# CAMOFOX_EXECUTABLE_PATH=

# Kill the browser process after this many milliseconds of inactivity.
# Set to 0 to keep the browser alive indefinitely.
BROWSER_IDLE_TIMEOUT_MS=300000

# ---------------------------------------------------------------------------- #
#               ------- Sessions & Tabs ------
# ---------------------------------------------------------------------------- #

# Maximum number of concurrent browser sessions (BrowserContext objects).
MAX_SESSIONS=50

# Maximum number of tabs per session. Oldest/least-used tab is recycled when
# the limit is reached — no errors, just silent replacement.
MAX_TABS_PER_SESSION=10

# Maximum number of open tabs across ALL sessions.
# (Found in config.js; not listed in the public README table.)
MAX_TABS_GLOBAL=50

# Inactivity timeout for a browser session (milliseconds).
# README says default is 1800000 (30 min), but config.js uses 600000 (10 min).
# Config.js fallback takes precedence at runtime.
SESSION_TIMEOUT_MS=600000

# Close tabs that have been idle longer than this (milliseconds).
TAB_INACTIVITY_MS=300000

# ---------------------------------------------------------------------------- #
#               ------- Timeouts ------
# ---------------------------------------------------------------------------- #

# Maximum time allowed for any single request handler (milliseconds).
HANDLER_TIMEOUT_MS=30000

# Page navigation timeout (milliseconds).
# (Found in config.js; not listed in the public README table.)
NAVIGATE_TIMEOUT_MS=25000

# Accessibility-tree build timeout per page (milliseconds).
# (Found in config.js; not listed in the public README table.)
BUILDREFS_TIMEOUT_MS=12000

# ---------------------------------------------------------------------------- #
#               ------- Concurrency ------
# ---------------------------------------------------------------------------- #

# Maximum in-flight requests per user. Additional requests are queued.
MAX_CONCURRENT_PER_USER=3

# ---------------------------------------------------------------------------- #
#               ------- Performance & Memory ------
# ---------------------------------------------------------------------------- #

# Node.js V8 old-space heap limit in MB. Passed as --max-old-space-size=N.
MAX_OLD_SPACE_SIZE=128

# Browser process RSS memory threshold in MB. If exceeded, the browser is
# restarted automatically to recover from leaks.
# (Found in config.js; not listed in the public README table.)
BROWSER_RSS_RESTART_THRESHOLD_MB=1500

# Node.js process native memory threshold in MB. If exceeded, triggers restart.
# (Found in config.js; not listed in the public README table.)
NATIVE_MEM_RESTART_THRESHOLD_MB=300

# ---------------------------------------------------------------------------- #
#               ------- Proxy & GeoIP ------
# ---------------------------------------------------------------------------- #

# Proxy routing strategy. [backconnect, round_robin]
# - backconnect: rotating sticky sessions via gateway (Decodo, Bright Data, Oxylabs)
# - round_robin: round-robin across PROXY_PORTS (default when unset in config.js)
# - empty/omitted: single endpoint via PROXY_HOST / PROXY_PORT
# PROXY_STRATEGY=round_robin

# Provider name for session-id format (e.g., decodo).
PROXY_PROVIDER=decodo

# ---- Simple Proxy (single endpoint) ----

# Proxy hostname or IP address.
# PROXY_HOST=

# Proxy port.
# PROXY_PORT=

# Multiple proxy ports for round_robin strategy. Supports range ("10001-10010")
# or comma-separated list ("10001,10002,10003"). Falls back to PROXY_PORT.
# (Found in config.js; not listed in the public README table.)
# PROXY_PORTS=

# ---- Backconnect Proxy (rotating sticky sessions) ----

# Backconnect gateway hostname.
# PROXY_BACKCONNECT_HOST=

# Backconnect gateway port.
PROXY_BACKCONNECT_PORT=7000

# ---- Proxy Authentication ----

# Proxy username.
# PROXY_USERNAME=

# Proxy password.
# PROXY_PASSWORD=${CAMOFOX_PROXY_PASSWORD}

# ---- Proxy Geo-Targeting ----

# Target country for proxy geo-targeting (e.g., US, DE, JP).
# PROXY_COUNTRY=

# Target state/region for proxy geo-targeting.
# PROXY_STATE=

# Target city for proxy geo-targeting.
# (Found in config.js; not listed in the public README table.)
# PROXY_CITY=

# Target ZIP/postal code for proxy geo-targeting.
# (Found in config.js; not listed in the public README table.)
# PROXY_ZIP=

# Duration in minutes before a sticky proxy session rotates to a new IP.
# (Found in config.js; not listed in the public README table.)
PROXY_SESSION_DURATION_MINUTES=10

# ---------------------------------------------------------------------------- #
#               ------- Storage & Profiles ------
# ---------------------------------------------------------------------------- #

# Directory for Netscape-format cookie files (cookie import source).
CAMOFOX_COOKIES_DIR=~/.camofox/cookies

# Directory for persisted browser session state (cookies + localStorage).
# User IDs are hashed for directory names.
CAMOFOX_PROFILE_DIR=~/.camofox/profiles

# ---------------------------------------------------------------------------- #
#               ------- Session Tracing ------
# ---------------------------------------------------------------------------- #

# Base directory for Playwright trace ZIP files.
CAMOFOX_TRACES_DIR=~/.camofox/traces

# Maximum size in bytes for a single trace file. Traces exceeding this are
# removed at next server startup.
CAMOFOX_TRACES_MAX_BYTES=52428800

# Trace files older than this many hours are swept on server startup.
CAMOFOX_TRACES_TTL_HOURS=24

# ---------------------------------------------------------------------------- #
#               ------- VNC (Interactive Browser) ------
# ---------------------------------------------------------------------------- #

# Set to "1" or "true" to enable the VNC plugin for interactive browser access
# via noVNC web UI. Allows visual login to sites; export storage state for reuse.
ENABLE_VNC=1

# Password for VNC access. Strongly recommended in production.
VNC_PASSWORD=${CAMOFOX_VNC_PASSWORD}

# noVNC web UI port.
NOVNC_PORT=6080

# VNC server port.
# (Found in config.js; not listed in the public README table.)
# VNC_PORT=5900

# VNC display resolution (e.g., 1280x720).
# (Found in config.js; not listed in the public README table.)
# VNC_RESOLUTION=1280x720

# VNC bind address (default: 0.0.0.0).
# (Found in config.js; not listed in the public README table.)
# VNC_BIND=0.0.0.0

# Set to "1" to enable view-only VNC mode (no remote interaction).
# (Found in config.js; not listed in the public README table.)
# VIEW_ONLY=

# ---------------------------------------------------------------------------- #
#               ------- Telemetry ------
# ---------------------------------------------------------------------------- #

# Set to "false" to disable all anonymized crash/hang telemetry.
# See docs for full privacy/redaction details. Default: enabled.
# CAMOFOX_CRASH_REPORT_ENABLED=true

# Custom telemetry endpoint URL. Point to your own Cloudflare Worker to file
# issues in your own repo instead of jo-inc/camofox-browser.
# CAMOFOX_CRASH_REPORT_URL=https://camofox-telemetry.askjo.workers.dev/report

# GitHub repo for telemetry issues (used when self-hosting the endpoint).
# CAMOFOX_CRASH_REPORT_REPO=jo-inc/camofox-browser

# Maximum telemetry reports per hour. Duplicates are deduplicated by stack
# signature (get a +1 comment instead of a new issue).
CAMOFOX_CRASH_REPORT_RATE_LIMIT=10

# ---------------------------------------------------------------------------- #
#               ------- Platform: Fly.io ------
# ---------------------------------------------------------------------------- #

# Fly.io machine ID (auto-set by Fly.io; no manual config needed).
# FLY_MACHINE_ID=

# Fly.io app name (auto-set by Fly.io; no manual config needed).
# FLY_APP_NAME=

# Fly.io API token for machine management.
# FLY_API_TOKEN=${CAMOFOX_FLY_API_TOKEN}

# ---------------------------------------------------------------------------- #
#               ------- Observability ------
# ---------------------------------------------------------------------------- #

# Set to "1" or "true" to expose Prometheus metrics.
# (Found in config.js; not listed in the public README table.)
# PROMETHEUS_ENABLED=false

# Sentry DSN for error tracking.
# (Found in config.js; not listed in the public README table.)
# SENTRY_DSN=${CAMOFOX_SENTRY_DSN}
