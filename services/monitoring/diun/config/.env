# ---------------------------------------------------------------------------- #
#               ------- Diun Configuration File --------
# ---------------------------------------------------------------------------- #
# https://crazymax.dev/diun/config

TZ=${TIMEZONE}

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #

DIUN_DB_PATH=diun.db

# ---------------------------------------------------------------------------- #
#               ------- Watch --------
# ---------------------------------------------------------------------------- #

DIUN_WATCH_WORKERS=10
DIUN_WATCH_SCHEDULE=0 */6 * * *
DIUN_WATCH_JITTER=30s

DIUN_WATCH_FIRSTCHECKNOTIF=false
DIUN_WATCH_RUNONSTARTUP=true

DIUN_WATCH_COMPAREDIGEST=true

# ---------------------------------------------------------------------------- #
#               ------- Defaults --------
# ---------------------------------------------------------------------------- #

DIUN_DEFAULTS_WATCHREPO=false
DIUN_DEFAULTS_NOTIFYON=new,update
DIUN_DEFAULTS_SORTTAGS=reverse

# ---------------------------------------------------------------------------- #
#               ------- Notifications - Gotify --------
# ---------------------------------------------------------------------------- #

# DIUN_NOTIF_GOTIFY_ENDPOINT=http://gotify.${DOMAIN}
# DIUN_NOTIF_GOTIFY_TOKEN=
# DIUN_NOTIF_GOTIFY_PRIORITY=1
# DIUN_NOTIF_GOTIFY_TIMEOUT=10s

# ---------------------------------------------------------------------------- #
#               ------- Notifications - Mail --------
# ---------------------------------------------------------------------------- #

DIUN_NOTIF_MAIL_HOST=${SMTP_HOST}
DIUN_NOTIF_MAIL_PORT=${SMTP_PORT}
DIUN_NOTIF_MAIL_SSL=false
DIUN_NOTIF_MAIL_INSECURESKIPVERIFY=false
DIUN_NOTIF_MAIL_LOCALNAME=${DOMAIN}
DIUN_NOTIF_MAIL_USERNAME=${SMTP_USERNAME}
# DIUN_NOTIF_MAIL_USERNAMEFILE=
DIUN_NOTIF_MAIL_PASSWORD=${SMTP_PASSWORD}
# DIUN_NOTIF_MAIL_PASSWORDFILE=
DIUN_NOTIF_MAIL_FROM=noreply-diun@${DOMAIN}

# (comma separated)
DIUN_NOTIF_MAIL_TO=${USER_EMAIL}

# DIUN_NOTIF_MAIL_TEMPLATETITLE=
# DIUN_NOTIF_MAIL_TEMPLATEBODY=

# ---------------------------------------------------------------------------- #
#               ------- Notifications - Ntfy --------
# ---------------------------------------------------------------------------- #

# DIUN_NOTIF_NTFY_ENDPOINT=https://notifications.${DOMAIN}
# DIUN_NOTIF_NTFY_TOPIC=
# DIUN_NOTIF_NTFY_TAGS=
# DIUN_NOTIF_NTFY_TIMEOUT=10s

# ---------------------------------------------------------------------------- #
#               ------- Registry options --------
# ---------------------------------------------------------------------------- #

DIUN_REGOPTS_0_NAME=docker.io
DIUN_REGOPTS_0_SELECTOR=image
DIUN_REGOPTS_0_USERNAME=${DOCKER_HUB_USERNAME}
DIUN_REGOPTS_0_PASSWORD=${DOCKER_HUB_PASSWORD}
DIUN_REGOPTS_0_TIMEOUT=30s

# ---------------------------------------------------------------------------- #
#               ------- Providers - Docker --------
# ---------------------------------------------------------------------------- #

DIUN_PROVIDERS_DOCKER=false
# DIUN_PROVIDERS_DOCKER_ENDPOINT=unix:///var/run/docker.sock
# DIUN_PROVIDERS_DOCKER_WATCHBYDEFAULT=true
# DIUN_PROVIDERS_DOCKER_WATCHSTOPPED=false


# ---------------------------------------------------------------------------- #
#               ------- Providers - File --------
# ---------------------------------------------------------------------------- #

DIUN_PROVIDERS_FILE_FILENAME=/data/config/images.yaml
