# ---------------------------------------------------------------------------- #
#               ------- ntfy Configuration File ------
# ---------------------------------------------------------------------------- #
# https://docs.ntfy.sh/config

# General
TZ=${TIMEZONE}    # optional: Change to your desired timezone

# URLs
NTFY_BASE_URL=https://${NTFY_HOST}
NTFY_UPSTREAM_BASE_URL=https://ntfy.sh

# ---------------------------------------------------------------------------- #
#               ------- Attachment ------
# ---------------------------------------------------------------------------- #

NTFY_ATTACHMENT_CACHE_DIR=/var/lib/ntfy/attachments
NTFY_ATTACHMENT_EXPIRY_DURATION=3h
NTFY_ATTACHMENT_FILE_SIZE_LIMIT=15M
NTFY_ATTACHMENT_TOTAL_SIZE_LIMIT=5G

# ---------------------------------------------------------------------------- #
#               ------- Authentication ------
# ---------------------------------------------------------------------------- #

NTFY_AUTH_DEFAULT_ACCESS=deny-all
NTFY_AUTH_FILE=/var/lib/ntfy/auth.db
NTFY_BEHIND_PROXY=true
NTFY_ENABLE_LOGIN=true

# ---------------------------------------------------------------------------- #
#               ------- Cache ------
# ---------------------------------------------------------------------------- #

NTFY_CACHE_DURATION=24h
NTFY_CACHE_FILE=/var/lib/ntfy/cache.db

# ---------------------------------------------------------------------------- #
#               ------- Log ------
# ---------------------------------------------------------------------------- #
NTFY_LOG_FILE=json
NTFY_LOG_FORMAT=/var/log/ntfy.log
NTFY_LOG_LEVEL=info

# ---------------------------------------------------------------------------- #
#               ------- SMTP ------
# ---------------------------------------------------------------------------- #

NTFY_SMTP_SENDER_ADDR=${SMTP_HOST}:${SMTP_PORT}
NTFY_SMTP_SENDER_FROM=noreply-ntfy@${DOMAIN}
NTFY_SMTP_SENDER_USER=${SMTP_USERNAME}
NTFY_SMTP_SENDER_PASS=${SMTP_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Web Push ------
# ---------------------------------------------------------------------------- #

# NTFY_WEB_PUSH_PUBLIC_KEY=<public_key>
# NTFY_WEB_PUSH_PRIVATE_KEY=<private_key>
# NTFY_WEB_PUSH_FILE=/var/lib/ntfy/webpush.db
# NTFY_WEB_PUSH_EMAIL_ADDRESS=<email>
