# ---------------------------------------------------------------------------- #
#               ------- Gitea Mirror Configuration File --------
# ---------------------------------------------------------------------------- #

# Application environment
NODE_ENV=production

# Server host binding
HOST=0.0.0.0
# Server port
PORT=4321

# ---------------------------------------------------------------------------- #
#               ------- Authentication --------
# ---------------------------------------------------------------------------- #

# Secret key for session signing (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=${GITEA_MIRROR_BETTER_AUTH_SECRET}
# Primary base URL for authentication. This should be the main URL where your
# application is accessed.
BETTER_AUTH_URL=https://${GITEA_MIRROR_HOST}
# Client-side auth URL for multi-origin access. Set this to your primary domain
# when you need to access the app from different origins (e.g., both IP and
# domain). The client will use this URL for all auth requests instead of the
# current browser origin.
PUBLIC_BETTER_AUTH_URL=https://${GITEA_MIRROR_HOST}
# Trusted origins for authentication requests. Comma-separated list of URLs. Use
# this to specify additional access URLs (e.g., local IP + domain:
# http://10.10.20.45:4321,https://gitea-mirror.mydomain.tld), SSO providers,
# reverse proxies, etc.
BETTER_AUTH_TRUSTED_ORIGINS=https://${GITEA_MIRROR_HOST}

# Optional encryption key for tokens (generate with: openssl rand -base64 48)
ENCRYPTION_SECRET=${GITEA_MIRROR_ENCRYPTION_SECRET}

# Header Authentication (Reverse Proxy SSO)
# Enable header-based authentication
HEADER_AUTH_ENABLED=false
# Header containing username
HEADER_AUTH_USER_HEADER=X-Authentik-Username
# Header containing email
HEADER_AUTH_EMAIL_HEADER=X-Authentik-Email
# Header containing display name
HEADER_AUTH_NAME_HEADER=X-Authentik-Name
# Auto-create users from headers
HEADER_AUTH_AUTO_PROVISION=false
# Comma-separated list of allowed email domains
# HEADER_AUTH_ALLOWED_DOMAINS=

# ---------------------------------------------------------------------------- #
#               ------- Automation --------
# ---------------------------------------------------------------------------- #

# Basic Schedule Settings
# Enable automatic mirroring. When set to true, automatically imports and
# mirrors all repositories on startup (v3.5.3+)
SCHEDULE_ENABLED=true
# Interval in seconds or cron expression. Supports cron syntax for scheduled
# runs (e.g., "0 2 * * *" for 2 AM daily)
SCHEDULE_INTERVAL=28800

# Execution Settings
# Allow concurrent mirror operations
SCHEDULE_CONCURRENT=true
# Number of repos to process in parallel
SCHEDULE_BATCH_SIZE=5
# Pause between batches (milliseconds)
SCHEDULE_PAUSE_BETWEEN_BATCHES=5000

# Retry Configuration
# Number of retry attempts
SCHEDULE_RETRY_ATTEMPTS=3
# Delay between retries (milliseconds)
SCHEDULE_RETRY_DELAY=60000
# Max time for a mirror operation (milliseconds)
SCHEDULE_TIMEOUT=3600000
# Automatically retry failed operations
SCHEDULE_AUTO_RETRY=true

# Update Detection
# Automatically discover and import new GitHub repositories during scheduled
# syncs
AUTO_IMPORT_REPOS=true
# Automatically mirror newly imported repositories during scheduled syncs
# (no manual “Mirror All” required)
AUTO_MIRROR_REPOS=false
# Only mirror repos with updates
SCHEDULE_ONLY_MIRROR_UPDATED=false
# Check for updates interval (milliseconds)
SCHEDULE_UPDATE_INTERVAL=86400000
# Skip recently mirrored repos
SCHEDULE_SKIP_RECENTLY_MIRRORED=true
# Skip if mirrored within this time (milliseconds)
SCHEDULE_RECENT_THRESHOLD=3600000

# Maintenance & Notifications
# Run cleanup before mirroring
SCHEDULE_CLEANUP_BEFORE_MIRROR=false
# Send notifications on failure
SCHEDULE_NOTIFY_ON_FAILURE=true
# Send notifications on success
SCHEDULE_NOTIFY_ON_SUCCESS=false
# Logging level
SCHEDULE_LOG_LEVEL=info
# Timezone for scheduling
SCHEDULE_TIMEZONE=${TIMEZONE}

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #

# Database connection URL
DATABASE_URL=file:data/gitea-mirror.db

# Basic Settings
# Enable automatic cleanup
CLEANUP_ENABLED=false
# Days to keep events
CLEANUP_RETENTION_DAYS=7

# Repository Cleanup
# Delete repositories from Gitea
CLEANUP_DELETE_FROM_GITEA=false
# Delete repos not found in GitHub (automatically enables cleanup)
CLEANUP_DELETE_IF_NOT_IN_GITHUB=true
# Action for orphaned repositories. Note: archive is recommended to preserve
# backups
CLEANUP_ORPHANED_REPO_ACTION=archive
# Test mode without actual deletion
CLEANUP_DRY_RUN=false
# Comma-separated list of protected repository names
# CLEANUP_PROTECTED_REPOS=

# Execution Settings
# Number of items to process per batch
CLEANUP_BATCH_SIZE=10
# Pause between deletions (milliseconds)
CLEANUP_PAUSE_BETWEEN_DELETES=2000

# ---------------------------------------------------------------------------- #
#               ------- GitHub --------
# ---------------------------------------------------------------------------- #

# Basic Settings
# Your GitHub username
GITHUB_USERNAME=${GITHUB_USERNAME}
# GitHub personal access token (requires repo and admin:org scopes)
GITHUB_TOKEN=${GITHUB_TOKEN}
# GitHub account type
GITHUB_TYPE=personal

# Repository Selection
# Include private repositories
PRIVATE_REPOSITORIES=true
# Include public repositories
PUBLIC_REPOSITORIES=true
# Include archived repositories
INCLUDE_ARCHIVED=false
# Skip forked repositories
SKIP_FORKS=false
# Mirror starred repositories
MIRROR_STARRED=true
# Organization name for starred repos
STARRED_REPOS_ORG=starred
# How starred repos are mirrored
STARRED_REPOS_MODE=dedicated-org

# Organization Settings
# Mirror organization repositories
MIRROR_ORGANIZATIONS=false
# Preserve GitHub organization structure in Gitea
PRESERVE_ORG_STRUCTURE=false
# Only mirror organization repos (skip personal)
ONLY_MIRROR_ORGS=false
# Repository organization strategy
MIRROR_STRATEGY=single-org

# Advanced Settings
# Enable lightweight mode for starred repos (skip issues)
SKIP_STARRED_ISSUES=true

# ---------------------------------------------------------------------------- #
#               ------- Gitea --------
# ---------------------------------------------------------------------------- #

# Connection Settings
# Gitea instance URL
GITEA_URL=https://${FORGEJO_HOST}
# Optional external/browser URL used for dashboard links. API and mirroring still use GITEA_URL.
GITEA_EXTERNAL_URL=https://${FORGEJO_HOST}
# Gitea access token
GITEA_TOKEN=${GITEA_MIRROR_FORGEJO_TOKEN}
# Gitea username
GITEA_USERNAME=${GITEA_MIRROR_FORGEJO_USERNAME}
# Default organization for single-org strategy
GITEA_ORGANIZATION=github

# Repository Settings
# Default organization visibility
GITEA_ORG_VISIBILITY=limited
# Mirror sync interval - automatically enables scheduled mirroring when set
GITEA_MIRROR_INTERVAL=8h
# Enable LFS support (requires LFS on Gitea server) - Shows in UI
GITEA_LFS=true
# Auto-create organizations
GITEA_CREATE_ORG=true
# Preserve GitHub repo visibility in Gitea
GITEA_PRESERVE_VISIBILITY=false

# Template Settings
# Template repository owner
# GITEA_TEMPLATE_OWNER=
# Template repository name
# GITEA_TEMPLATE_REPO=

# Topic Settings
# Add topics to repositories
GITEA_ADD_TOPICS=true
# Prefix for repository topics
# GITEA_TOPIC_PREFIX=

# Fork Handling
# How to handle forked repositories
GITEA_FORK_STRATEGY=full-copy

# Additional Settings
# Optional: Skip TLS verification (insecure, use only for testing)
GITEA_SKIP_TLS_VERIFY=false

# ---------------------------------------------------------------------------- #
#               ------- Mirror --------
# ---------------------------------------------------------------------------- #

# Mirror GitHub releases
MIRROR_RELEASES=false
# Maximum number of releases to mirror per repository
RELEASE_LIMIT=5

# Mirror wiki content
MIRROR_WIKI=true
# Master toggle for metadata mirroring
MIRROR_METADATA=true
# Mirror issues (requires MIRROR_METADATA=true)
MIRROR_ISSUES=false
# Mirror pull requests (requires MIRROR_METADATA=true)
MIRROR_PULL_REQUESTS=false
# Mirror labels (requires MIRROR_METADATA=true)
MIRROR_LABELS=true
# Mirror milestones (requires MIRROR_METADATA=true)
MIRROR_MILESTONES=false

# Number of issues processed in parallel. Set above 1 to speed up mirroring at
# the risk of out-of-order creation.
MIRROR_ISSUE_CONCURRENCY=3
# Number of pull requests processed in parallel. Values above 1 may cause
# ordering differences.
MIRROR_PULL_REQUEST_CONCURRENCY=5
