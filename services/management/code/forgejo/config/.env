# ---------------------------------------------------------------------------- #
#               ------- Forgejo Configuration File ------
# ---------------------------------------------------------------------------- #
# https://forgejo.org/docs/latest/admin/config-cheat-sheet

# Environment variables are translated to app.ini via environment-to-ini.
# Format: FORGEJO__<section>__<KEY>=value
# Sections with dots use double underscores: e.g. repository.editor ->
# FORGEJO__repository__editor__KEY

# ---------------------------------------------------------------------------- #
#               ------- User ------
# ---------------------------------------------------------------------------- #
USER_UID=${USER_UID}
USER_GID=${USER_GID}

# ---------------------------------------------------------------------------- #
#               ------- Overall (DEFAULT) ------
# ---------------------------------------------------------------------------- #
# Application name, used in the page title.
FORGEJO____APP_NAME=Forgejo: Beyond coding. We forge.

# The user Forgejo will run as. This should be a dedicated system (non-user)
# account. Setting this incorrectly will cause Forgejo to not start.
FORGEJO____RUN_USER=git

# Application run mode, affects performance and debugging: dev or prod.
FORGEJO____RUN_MODE=prod

# ---------------------------------------------------------------------------- #
#               ------- Repository ------
# ---------------------------------------------------------------------------- #
# Force every new repository to be private.
FORGEJO__repository__FORCE_PRIVATE=false

# Default privacy setting when creating a new repository. [last, private, public]
FORGEJO__repository__DEFAULT_PRIVATE=last

# Default privacy setting when creating a new repository with push-to-create.
FORGEJO__repository__DEFAULT_PUSH_CREATE_PRIVATE=true

# Global maximum creation limit of repositories per user/org; -1 means no limit.
FORGEJO__repository__MAX_CREATION_LIMIT=-1

# Disable the ability to interact with repositories over the HTTP protocol.
FORGEJO__repository__DISABLE_HTTP_GIT=false

# Always use ssh:// clone URL instead of scp-style URI.
FORGEJO__repository__USE_COMPAT_SSH_URI=true

# Value for the "go get" request returns the repository URL as https or ssh.
FORGEJO__repository__GO_GET_CLONE_URL_PROTOCOL=https

# Close an issue if a commit on a non-default branch marks it as closed.
FORGEJO__repository__DEFAULT_CLOSE_ISSUES_VIA_COMMITS_IN_ANY_BRANCH=false

# Allow users to push local repositories to Forgejo and have them automatically
# created for a user.
FORGEJO__repository__ENABLE_PUSH_CREATE_USER=false

# Allow users to push local repositories to Forgejo and have them automatically
# created for an org.
FORGEJO__repository__ENABLE_PUSH_CREATE_ORG=false

# Prefix archive files by placing them in a directory named after the repository.
FORGEJO__repository__PREFIX_ARCHIVE_FILES=true

# Disable migrating feature.
FORGEJO__repository__DISABLE_MIGRATIONS=false

# Disable stars feature.
FORGEJO__repository__DISABLE_STARS=false

# Default branch name for all new repositories.
FORGEJO__repository__DEFAULT_BRANCH=main

# Prevents the downloading of source archive files from the UI.
FORGEJO__repository__DISABLE_DOWNLOAD_SOURCE_ARCHIVES=false

# ---------------------------------------------------------------------------- #
#               ------- Repository - Pull Request ------
# ---------------------------------------------------------------------------- #
# Set default merge style for repository creation; valid options: merge, rebase,
# rebase-merge, squash, fast-forward-only.
FORGEJO__repository__pull-request__DEFAULT_MERGE_STYLE=merge

# Set default PR branch update style; valid options: merge, rebase.
FORGEJO__repository__pull-request__DEFAULT_UPDATE_STYLE=merge

# Add Co-authored-by and Co-committed-by trailers to merge commit messages if
# committer doesn't match author.
FORGEJO__repository__pull-request__ADD_CO_COMMITTER_TRAILERS=true

# Retarget child pull requests to the parent PR branch target on merge of the
# parent pull request.
FORGEJO__repository__pull-request__RETARGET_CHILDREN_ON_MERGE=true

# ---------------------------------------------------------------------------- #
#               ------- Repository - Upload ------
# ---------------------------------------------------------------------------- #
# Whether repository file uploads are enabled.
FORGEJO__repository__upload__ENABLED=true

# Maximum size of each file in megabytes.
FORGEJO__repository__upload__FILE_MAX_SIZE=50

# Maximum number of files per upload.
FORGEJO__repository__upload__MAX_FILES=5

# ---------------------------------------------------------------------------- #
#               ------- Repository - Release ------
# ---------------------------------------------------------------------------- #
# The default paging number for the releases user interface.
FORGEJO__repository__release__DEFAULT_PAGING_NUM=10

# ---------------------------------------------------------------------------- #
#               ------- Repository - Signing ------
# ---------------------------------------------------------------------------- #
# Signing format that Forgejo should use. [openpgp, ssh]
FORGEJO__repository__signing__FORMAT=openpgp

# Key to sign with.
FORGEJO__repository__signing__SIGNING_KEY=default

# Sign initial commit. [never, pubkey, twofa, always]
FORGEJO__repository__signing__INITIAL_COMMIT=always

# The default trust model used for verifying commits.
# [collaborator, committer, collaboratorcommitter]
FORGEJO__repository__signing__DEFAULT_TRUST_MODEL=collaborator

# ---------------------------------------------------------------------------- #
#               ------- Server ------
# ---------------------------------------------------------------------------- #
# Protocol Forgejo listens on. [http, https, fcgi, http+unix, fcgi+unix]
# Behind Traefik, keep this as http; Traefik handles TLS termination.
FORGEJO__server__PROTOCOL=http

# Domain name of this server (used for clone URLs and emails).
FORGEJO__server__DOMAIN=${FORGEJO_HOST}

# Public-facing root URL. Traefik terminates HTTPS, so this should be https://.
FORGEJO__server__ROOT_URL=https://${FORGEJO_HOST}

# HTTP listen address.
FORGEJO__server__HTTP_ADDR=0.0.0.0

# HTTP listen port (internal, Traefik will proxy to this).
FORGEJO__server__HTTP_PORT=3000

# Disable SSH feature when it's not available. Set false since Traefik routes
# SSH.
FORGEJO__server__DISABLE_SSH=false

# When enabled, use the built-in SSH server. Set false to use the host SSH
# server via Traefik passthrough.
FORGEJO__server__START_SSH_SERVER=false

# SSH username displayed in clone URLs.
FORGEJO__server__SSH_USER=git

# Domain name used for displayed clone URL.
FORGEJO__server__SSH_DOMAIN=${FORGEJO_HOST}

# SSH port displayed in the clone URL. Port 22 as Traefik handles SSH routing on 22.
FORGEJO__server__SSH_PORT=22

# Root path of the SSH directory.
FORGEJO__server__SSH_ROOT_PATH=~/.ssh

# Forgejo will create an authorized_keys file by default when not using the
# internal SSH server.
FORGEJO__server__SSH_CREATE_AUTHORIZED_KEYS_FILE=true

# Enable exposure of SSH clone URL to anonymous visitors.
FORGEJO__server__SSH_EXPOSE_ANONYMOUS=false

# Disables use of CDNs for static files and Gravatar for profile pictures.
FORGEJO__server__OFFLINE_MODE=true

# Enable gzip compression for runtime-generated content.
FORGEJO__server__ENABLE_GZIP=true

# Landing page for unauthenticated users. [home, explore, organizations, login]
FORGEJO__server__LANDING_PAGE=home

# Enables Git LFS support.
FORGEJO__server__LFS_START_SERVER=true

# LFS authentication secret; generate with: forgejo generate secret LFS_JWT_SECRET
FORGEJO__server__LFS_JWT_SECRET=${FORGEJO_LFS_JWT_SECRET}

# LFS authentication validity period; pushes taking longer than this may fail.
FORGEJO__server__LFS_HTTP_AUTH_EXPIRY=24h

# Maximum allowed LFS file size in bytes (0 = no limit).
FORGEJO__server__LFS_MAX_FILE_SIZE=0

# ---------------------------------------------------------------------------- #
#               ------- Database ------
# ---------------------------------------------------------------------------- #
# The database type to use. [mysql, postgres, sqlite3]
FORGEJO__database__DB_TYPE=postgres

# Database host address and port.
FORGEJO__database__HOST=db:5432

# Database name.
FORGEJO__database__NAME=postgres

# Database username.
FORGEJO__database__USER=${FORGEJO_DB_USERNAME}

# Database user password.
FORGEJO__database__PASSWD=${FORGEJO_DB_PASSWORD}

# SSL/TLS encryption mode for connecting to the database.
# [disable, require, verify-ca, verify-full]
FORGEJO__database__SSL_MODE=disable

# Schema to use if different from "public" (PostgreSQL only).
# FORGEJO__database__SCHEMA=

# Log the executed SQL.
FORGEJO__database__LOG_SQL=false

# Database maximum open connections.
FORGEJO__database__MAX_OPEN_CONNS=100

# Maximum idle database connections on the connection pool.
FORGEJO__database__MAX_IDLE_CONNS=2

# Sets the maximum amount of time a DB connection may be reused.
FORGEJO__database__CONN_MAX_LIFETIME=3s

# Sets the maximum amount of time a DB connection may be idle.
FORGEJO__database__CONN_MAX_IDLETIME=0

# Whether to execute database models migrations automatically.
FORGEJO__database__AUTO_MIGRATION=true

# ---------------------------------------------------------------------------- #
#               ------- Indexer ------
# ---------------------------------------------------------------------------- #
# Issue indexer type. [bleve, db, elasticsearch, meilisearch]
FORGEJO__indexer__ISSUE_INDEXER_TYPE=bleve

# Index file used for issue search (bleve only).
FORGEJO__indexer__ISSUE_INDEXER_PATH=indexers/issues.bleve

# Enables code search (uses ~6x more disk space than the repository size).
FORGEJO__indexer__REPO_INDEXER_ENABLED=true

# Code search engine type. [bleve, elasticsearch]
FORGEJO__indexer__REPO_INDEXER_TYPE=bleve

# Index file used for code search.
FORGEJO__indexer__REPO_INDEXER_PATH=indexers/repos.bleve

# Exclude vendored files from the index.
FORGEJO__indexer__REPO_INDEXER_EXCLUDE_VENDORED=true

# Maximum size in bytes of files to be indexed.
FORGEJO__indexer__MAX_FILE_SIZE=1048576

# ---------------------------------------------------------------------------- #
#               ------- Queue ------
# ---------------------------------------------------------------------------- #
# General queue type. [level, channel, redis, dummy]
# Use redis since you have a cache instance running.
FORGEJO__queue__TYPE=redis

# Connection string for the Redis queue.
FORGEJO__queue__CONN_STR=redis://:${FORGEJO_CACHE_PASSWORD}@cache:6379/1

# Maximal queue size before channel queues block.
FORGEJO__queue__LENGTH=100000

# Batch data before passing to the handler.
FORGEJO__queue__BATCH_LENGTH=20

# Maximum number of worker goroutines for the queue.
FORGEJO__queue__MAX_WORKERS=4

# ---------------------------------------------------------------------------- #
#               ------- Admin ------
# ---------------------------------------------------------------------------- #
# Default configuration for email notifications for users. [enabled, onmention, disabled]
FORGEJO__admin__DEFAULT_EMAIL_NOTIFICATIONS=enabled

# Disallow regular (non-admin) users from creating organizations.
FORGEJO__admin__DISABLE_REGULAR_ORG_CREATION=true

# Enable email notifications to instance admins on new user sign-up.
FORGEJO__admin__SEND_NOTIFICATION_EMAIL_ON_NEW_USER=true

# ---------------------------------------------------------------------------- #
#               ------- Security ------
# ---------------------------------------------------------------------------- #

# Trusted proxy IPs/networks. Set to Traefik's container network or IP.
FORGEJO__server__REVERSE_PROXY_TRUSTED_PROXIES=*

# ---------------------------------------------------------------------------- #
#               ------- Security ------
# ---------------------------------------------------------------------------- #
# Controls access to the installation page. Set to true after installation.
FORGEJO__security__INSTALL_LOCK=true

# Global secret key. IMPORTANT: keep this safe, losing it means losing encrypted
# data.
# Generate with: forgejo generate secret SECRET_KEY
FORGEJO__security__SECRET_KEY=${FORGEJO_SECRET_KEY}

# Cookie lifetime in days.
FORGEJO__security__LOGIN_REMEMBER_DAYS=365

# Which users are required to enable 2FA.
FORGEJO__security__GLOBAL_TWO_FACTOR_REQUIREMENT=all

# Number of trusted proxy count. Set to 1 for Traefik.
FORGEJO__security__REVERSE_PROXY_LIMIT=1

# List of trusted proxy servers. Adjust to Traefik's IP or subnet.
FORGEJO__security__REVERSE_PROXY_TRUSTED_PROXIES=${TRAEFIK_IP}

# Set to false to enable users with Git Hook privilege to create custom Git
# Hooks (security risk).
FORGEJO__security__DISABLE_GIT_HOOKS=true

# Set to true to disable the webhooks feature.
FORGEJO__security__DISABLE_WEBHOOKS=false

# Secret used to validate communication within the Forgejo binary.
# Generate with: forgejo generate secret INTERNAL_TOKEN
FORGEJO__security__INTERNAL_TOKEN=${FORGEJO_INTERNAL_TOKEN}

# The hash algorithm to use. [argon2, pbkdf2, pbkdf2_v1, pbkdf2_hi, scrypt, bcrypt]
FORGEJO__security__PASSWORD_HASH_ALGO=argon2

# Set false to allow JavaScript to read the CSRF cookie.
FORGEJO__security__CSRF_COOKIE_HTTP_ONLY=true

# Minimum password length for new users.
FORGEJO__security__MIN_PASSWORD_LENGTH=12

# Comma-separated list of character classes required: lower, upper, digit, spec,
# off.
FORGEJO__security__PASSWORD_COMPLEXITY=lower,upper,digit,spec

# ---------------------------------------------------------------------------- #
#               ------- Service ------
# ---------------------------------------------------------------------------- #
# Enable this to ask for mail confirmation of registration.
FORGEJO__service__REGISTER_EMAIL_CONFIRM=false

# Enable this to manually confirm new registrations.
FORGEJO__service__REGISTER_MANUAL_CONFIRM=false

# Disable registration; only admin can create accounts for users.
FORGEJO__service__DISABLE_REGISTRATION=true

# Enable this to force users to log in to view any page or to use the API.
FORGEJO__service__REQUIRE_SIGNIN_VIEW=true

# Enable to send e-mail to watchers when something happens (requires Mailer).
FORGEJO__service__ENABLE_NOTIFY_MAIL=false

# Disallow authentication using HTTP BASIC and the user's password.
FORGEJO__service__ENABLE_BASIC_AUTHENTICATION=true

# Enables the built-in authentication flow.
FORGEJO__service__ENABLE_INTERNAL_SIGNIN=true

# Enable this to use captcha validation for registration.
FORGEJO__service__ENABLE_CAPTCHA=true

# By default, set users to keep their email address private.
FORGEJO__service__DEFAULT_KEEP_EMAIL_PRIVATE=true

# Allow new users to create organizations by default.
FORGEJO__service__DEFAULT_ALLOW_CREATE_ORGANIZATION=false

# Enable this to display the heatmap on users' profiles.
FORGEJO__service__ENABLE_USER_HEATMAP=true

# Enable the Timetracking feature.
FORGEJO__service__ENABLE_TIMETRACKING=true

# Allow repositories to use timetracking by default.
FORGEJO__service__DEFAULT_ENABLE_TIMETRACKING=true

# Only allow users with write permissions to track time.
FORGEJO__service__DEFAULT_ALLOW_ONLY_CONTRIBUTORS_TO_TRACK_TIME=true

# Enable this to let all organization users watch new repos when they are created.
FORGEJO__service__AUTO_WATCH_NEW_REPOS=true

# Enable this to make users watch a repository after their first commit to it.
FORGEJO__service__AUTO_WATCH_ON_CHANGES=true

# Set the default visibility mode for users. [public, limited, private]
FORGEJO__service__DEFAULT_USER_VISIBILITY=limited

# Set the default visibility mode for organizations. [public, limited, private]
FORGEJO__service__DEFAULT_ORG_VISIBILITY=limited

# Value for the domain part of the user's email in Git log when KeepEmailPrivate
# is true.
FORGEJO__service__NO_REPLY_ADDRESS=noreply.${FORGEJO_HOST}

# The cooldown period in days before a username previously used by another user
# can be claimed by someone other than the original user
FORGEJO__service__USERNAME_COOLDOWN_PERIOD=1

# ---------------------------------------------------------------------------- #
#               ------- Service - Explore ------
# ---------------------------------------------------------------------------- #
# Only allow signed-in users to view the explore section.
FORGEJO__service_explore__REQUIRE_SIGNIN_VIEW=true

# ---------------------------------------------------------------------------- #
#               ------- Webhook ------
# ---------------------------------------------------------------------------- #
# Delivery timeout (seconds) for shooting webhooks.
FORGEJO__webhook__DELIVER_TIMEOUT=5

# Webhooks can only call allowed hosts for security reasons.
# [loopback, private, external, *] or CIDR/wildcard.
FORGEJO__webhook__ALLOWED_HOST_LIST=private

# Allow insecure certificates.
FORGEJO__webhook__SKIP_TLS_VERIFY=false

# ---------------------------------------------------------------------------- #
#               ------- Mailer ------
# ---------------------------------------------------------------------------- #
# Enable to use a mail service.
FORGEJO__mailer__ENABLED=true

# Mail server protocol. [smtp, smtps, smtp+starttls, smtp+unix, sendmail, dummy]
FORGEJO__mailer__PROTOCOL=smtp+starttls

# Mail server address.
FORGEJO__mailer__SMTP_ADDR=${SMTP_HOST}

# Mail server port.
FORGEJO__mailer__SMTP_PORT=${SMTP_PORT}

# Username of the mailing user (usually the sender's e-mail address).
FORGEJO__mailer__USER=${SMTP_USERNAME}

# Password of the mailing user.
FORGEJO__mailer__PASSWD=${SMTP_PASSWORD}

# Mail from address. RFC 5322 format.
FORGEJO__mailer__FROM=noreply-forgejo@${DOMAIN}

# ---------------------------------------------------------------------------- #
#               ------- Email - Incoming ------
# ---------------------------------------------------------------------------- #
# Enable handling of incoming emails.
FORGEJO__email_incoming_ENABLED=false

# ---------------------------------------------------------------------------- #
#               ------- Cache ------
# ---------------------------------------------------------------------------- #
# Cache engine adapter. [memory, redis, redis-cluster, twoqueue, memcache]
# Using redis since you have a cache instance running.
FORGEJO__cache__ADAPTER=redis

# Connection string for redis cache.
FORGEJO__cache__HOST=redis://:${FORGEJO_CACHE_PASSWORD}@cache:6379/0

# Time to keep items in cache if not used. Setting to -1 disables caching.
FORGEJO__cache__ITEM_TTL=16h

# ---------------------------------------------------------------------------- #
#               ------- Cache - LastCommitCache ------
# ---------------------------------------------------------------------------- #
# Time to keep items in cache if not used.
FORGEJO__cache__last_commit__ITEM_TTL=8760h

# Only enable the cache when the repository's commit count is greater than this value.
FORGEJO__cache__last_commit__COMMITS_COUNT=1000

# ---------------------------------------------------------------------------- #
#               ------- Session ------
# ---------------------------------------------------------------------------- #
# Session engine provider. [memory, file, redis, redis-cluster, db, mysql, couchbase, memcache, postgres]
# Using redis since you have a cache instance running.
FORGEJO__session__PROVIDER=redis

# Connection string for the redis session provider.
FORGEJO__session__PROVIDER_CONFIG=redis://:${FORGEJO_CACHE_PASSWORD}@cache:6379/2

# Enable to force HTTPS for all session access. Auto-set to true if ROOT_URL is https.
FORGEJO__session__COOKIE_SECURE=true

# The name of the cookie used for the session ID.
FORGEJO__session__COOKIE_NAME=i_like_forgejo

# GC interval in seconds.
FORGEJO__session__GC_INTERVAL_TIME=86400

# Session life time in seconds. Default is 86400 (1 day).
FORGEJO__session__SESSION_LIFE_TIME=86400

# SameSite setting for the cookie. [strict, lax, none]
FORGEJO__session__SAME_SITE=lax

# ---------------------------------------------------------------------------- #
#               ------- Picture ------
# ---------------------------------------------------------------------------- #
# Enable support for federated avatars.
FORGEJO__picture__ENABLE_FEDERATED_AVATAR=false

# Maximum avatar image width in pixels.
FORGEJO__picture__AVATAR_MAX_WIDTH=4096

# Maximum avatar image height in pixels.
FORGEJO__picture__AVATAR_MAX_HEIGHT=4096

# Maximum avatar image file size in bytes.
FORGEJO__picture__AVATAR_MAX_FILE_SIZE=1048576

# How Forgejo deals with missing repository avatars. [none, random, image]
FORGEJO__picture__REPOSITORY_AVATAR_FALLBACK=random

# ---------------------------------------------------------------------------- #
#               ------- Attachment ------
# ---------------------------------------------------------------------------- #
# Whether issue and pull request attachments are enabled.
FORGEJO__attachment__ENABLED=true

# Maximum size (MB).
FORGEJO__attachment__MAX_SIZE=2048

# Maximum number of attachments that can be uploaded at once.
FORGEJO__attachment__MAX_FILES=5

# ---------------------------------------------------------------------------- #
#               ------- LFS Client ------
# ---------------------------------------------------------------------------- #
# When mirroring an upstream LFS endpoint, limit the number of pointers in each batch request to this number
FORGEJO__lfs_client__BATCH_SIZE=20

# Limit the number of concurrent upload/download operations within a batch.
FORGEJO__lfs_client__BATCH_OPERATION_CONCURRENCY=8

# ---------------------------------------------------------------------------- #
#               ------- Log ------
# ---------------------------------------------------------------------------- #
# Root path for log files.
FORGEJO__log__ROOT_PATH=/var/log/forgejo

# Logging mode. [console, file]
FORGEJO__log__MODE=console

# General log level. [Trace, Debug, Info, Warn, Error, Critical, Fatal, None]
FORGEJO__log__LEVEL=Info

# The “access” logger. [console, file]
FORGEJO__log__LOGGER_ACCESS_MODE=file

# The “ssh” logger, which is disabled by default. [console, file]
FORGEJO__log__LOGGER_SSH_MODE=file

# ---------------------------------------------------------------------------- #
#               ------- Cron ------
# ---------------------------------------------------------------------------- #
# Enable to run all cron tasks periodically with default settings.
FORGEJO__cron__ENABLED=true

# Run cron tasks at application start-up.
FORGEJO__cron__RUN_AT_START=false

# ---------------------------------------------------------------------------- #
#               ------- Cron - Archive Cleanup ------
# ---------------------------------------------------------------------------- #
# Archives created more than OLDER_THAN ago are subject to deletion.
FORGEJO__cron__archive_cleanup__ENABLED=true
FORGEJO__cron__archive_cleanup__RUN_AT_START=true
FORGEJO__cron__archive_cleanup__SCHEDULE=@midnight
FORGEJO__cron__archive_cleanup__OLDER_THAN=24h

# ---------------------------------------------------------------------------- #
#               ------- Cron - Update Mirrors ------
# ---------------------------------------------------------------------------- #
FORGEJO__cron__update_mirrors__ENABLED=true
FORGEJO__cron__update_mirrors__SCHEDULE=@every 10m

# ---------------------------------------------------------------------------- #
#               ------- Cron - Repository Health Check ------
# ---------------------------------------------------------------------------- #
FORGEJO__cron__repo_health_check__ENABLED=true
FORGEJO__cron__repo_health_check__SCHEDULE=@midnight
FORGEJO__cron__repo_health_check__TIMEOUT=60s

# ---------------------------------------------------------------------------- #
#               ------- Cron - Cleanup Expired Packages ------
# ---------------------------------------------------------------------------- #
# Unreferenced package data created more than OLDER_THAN ago is subject to deletion.
FORGEJO__cron__cleanup_packages__ENABLED=true
FORGEJO__cron__cleanup_packages__RUN_AT_START=true
FORGEJO__cron__cleanup_packages__SCHEDULE=@midnight
FORGEJO__cron__cleanup_packages__OLDER_THAN=24h

# ---------------------------------------------------------------------------- #
#               ------- Cron - Sync External Users ------
# ---------------------------------------------------------------------------- #
FORGEJO__cron__sync_external_users__ENABLED=true
FORGEJO__cron__sync_external_users__SCHEDULE=@midnight
# Create new users, update existing, and disable users no longer in external source.
FORGEJO__cron__sync_external_users__UPDATE_EXISTING=true

# ---------------------------------------------------------------------------- #
#               ------- Cron - Cleanup Actions Assets ------
# ---------------------------------------------------------------------------- #
FORGEJO__cron__cleanup_actions__ENABLED=true
FORGEJO__cron__cleanup_actions__RUN_AT_START=true
FORGEJO__cron__cleanup_actions__SCHEDULE=@midnight

# ---------------------------------------------------------------------------- #
#               ------- Cron - Update Checker ------
# ---------------------------------------------------------------------------- #
# Check for new Forgejo versions.
FORGEJO__cron__update_checker__ENABLED=true
FORGEJO__cron__update_checker__SCHEDULE=@every 168h
FORGEJO__cron__update_checker__DOMAIN_ENDPOINT=release.forgejo.org

# ---------------------------------------------------------------------------- #
#               ------- Cron - Deleted Branches Cleanup ------
# ---------------------------------------------------------------------------- #
# Deleted branches older than OLDER_THAN ago are subject to deletion.
FORGEJO__cron__deleted_branches_cleanup__ENABLED=true
FORGEJO__cron__deleted_branches_cleanup__RUN_AT_START=true
FORGEJO__cron__deleted_branches_cleanup__SCHEDULE=@midnight
FORGEJO__cron__deleted_branches_cleanup__OLDER_THAN=24h

# ---------------------------------------------------------------------------- #
#               ------- Cron - Git GC (disabled) ------
# ---------------------------------------------------------------------------- #
# Garbage collect all repositories.
FORGEJO__cron__git_gc_repos__ENABLED=false
FORGEJO__cron__git_gc_repos__SCHEDULE=@every 72h
FORGEJO__cron__git_gc_repos__TIMEOUT=60s

# ---------------------------------------------------------------------------- #
#               ------- Cron - Delete Old Actions (disabled) ------
# ---------------------------------------------------------------------------- #
# Any action older than OLDER_THAN will be deleted from the database.
FORGEJO__cron__delete_old_actions__ENABLED=false
FORGEJO__cron__delete_old_actions__SCHEDULE=@every 168h
FORGEJO__cron__delete_old_actions__OLDER_THAN=8760h

# ---------------------------------------------------------------------------- #
#               ------- Cron - Delete Inactive Accounts (disabled) ------
# ---------------------------------------------------------------------------- #
# Only delete inactive accounts older than OLDER_THAN.
FORGEJO__cron__delete_inactive_accounts__ENABLED=false
FORGEJO__cron__delete_inactive_accounts__SCHEDULE=@annually
FORGEJO__cron__delete_inactive_accounts__OLDER_THAN=168h

# ---------------------------------------------------------------------------- #
#               ------- Git ------
# ---------------------------------------------------------------------------- #
# Disables highlighting of added and removed changes.
FORGEJO__git__DISABLE_DIFF_HIGHLIGHT=false

# Maximum number of lines allowed for a single file in the diff view.
FORGEJO__git__MAX_GIT_DIFF_LINES=1000

# Maximum character count per line highlighted in the diff view.
FORGEJO__git__MAX_GIT_DIFF_LINE_CHARACTERS=5000

# Maximum number of files shown in the diff view.
FORGEJO__git__MAX_GIT_DIFF_FILES=100

# Use Git wire protocol version 2 when Git version >= 2.18.
FORGEJO__git__ENABLE_AUTO_GIT_WIRE_PROTOCOL=true

# Respond to pushes to a non-default branch with a URL for creating a Pull Request.
FORGEJO__git__PULL_REQUEST_PUSH_MESSAGE=true

# ---------------------------------------------------------------------------- #
#               ------- Git - Timeout ------
# ---------------------------------------------------------------------------- #
# Git operations default timeout in seconds.
FORGEJO__git__timeout__DEFAULT=360

# Migrate external repositories timeout in seconds.
FORGEJO__git__timeout__MIGRATE=600

# Mirror external repositories timeout in seconds.
FORGEJO__git__timeout__MIRROR=300

# Git clone from internal repositories timeout in seconds.
FORGEJO__git__timeout__CLONE=300

# Git pull from internal repositories timeout in seconds.
FORGEJO__git__timeout__PULL=300

# Git repository GC timeout in seconds.
FORGEJO__git__timeout__GC=60

# ---------------------------------------------------------------------------- #
#               ------- Metrics ------
# ---------------------------------------------------------------------------- #
# Enables the /metrics endpoint for Prometheus.
FORGEJO__metrics__ENABLED=false

# You need to specify the token if you want authorization in the metrics endpoint.
# FORGEJO__metrics__TOKEN=

# ---------------------------------------------------------------------------- #
#               ------- API ------
# ---------------------------------------------------------------------------- #
# Enables the API documentation endpoints (/api/swagger, /api/v1/swagger, ...).
FORGEJO__api__ENABLE_SWAGGER=true

# Maximum number of items in a page.
FORGEJO__api__MAX_RESPONSE_ITEMS=50

# Default paging number for the API.
FORGEJO__api__DEFAULT_PAGING_NUM=30

# ---------------------------------------------------------------------------- #
#               ------- OAuth2 ------
# ---------------------------------------------------------------------------- #
# Enables the OAuth2 provider.
FORGEJO__oauth2__ENABLED=false

# Lifetime of an OAuth2 access token in seconds.
FORGEJO__oauth2__ACCESS_TOKEN_EXPIRATION_TIME=3600

# Lifetime of an OAuth2 refresh token in hours.
FORGEJO__oauth2__REFRESH_TOKEN_EXPIRATION_TIME=730

# Check if a refresh token has already been used.
FORGEJO__oauth2__INVALIDATE_REFRESH_TOKENS=true

# OAuth2 authentication secret for access and refresh tokens.
# Generate with: forgejo generate secret JWT_SECRET
FORGEJO__oauth2__JWT_SECRET=${FORGEJO_JWT_SECRET}

# ---------------------------------------------------------------------------- #
#               ------- Federation ------
# ---------------------------------------------------------------------------- #
# Enable/Disable federation capabilities (experimental, read the docs before enabling!).
FORGEJO__federation__ENABLED=false

# ---------------------------------------------------------------------------- #
#               ------- Packages ------
# ---------------------------------------------------------------------------- #
# Enable/Disable package registry capabilities.
FORGEJO__packages__ENABLED=true

# Maximum count of package versions a single owner can have (-1 means no limits).
FORGEJO__packages__LIMIT_TOTAL_OWNER_COUNT=-1

# Maximum size of packages a single owner can use (-1 means no limits).
FORGEJO__packages__LIMIT_TOTAL_OWNER_SIZE=-1

# ---------------------------------------------------------------------------- #
#               ------- Mirror ------
# ---------------------------------------------------------------------------- #
# Enables the mirror functionality.
FORGEJO__mirror__ENABLED=true

# Disable the creation of new pull mirrors.
FORGEJO__mirror__DISABLE_NEW_PULL=false

# Disable the creation of new push mirrors.
FORGEJO__mirror__DISABLE_NEW_PUSH=false

# Default interval between each check.
FORGEJO__mirror__DEFAULT_INTERVAL=8h

# Minimum interval for checking (must be >1m).
FORGEJO__mirror__MIN_INTERVAL=10m

# ---------------------------------------------------------------------------- #
#               ------- LFS ------
# ---------------------------------------------------------------------------- #
# Storage type for LFS files. [local, minio]
FORGEJO__lfs__STORAGE_TYPE=local

# Path to store LFS files.
FORGEJO__lfs__PATH=/data/lfs

# ---------------------------------------------------------------------------- #
#               ------- Actions ------
# ---------------------------------------------------------------------------- #
# Enable/Disable Actions.
FORGEJO__actions__ENABLED=true

# Default address to get action plugins.
FORGEJO__actions__DEFAULT_ACTIONS_URL=https://data.forgejo.org

# Default number of days to keep artifacts.
FORGEJO__actions__ARTIFACT_RETENTION_DAYS=90

# Timeout to stop tasks which have a running status but haven't been updated for a long time.
FORGEJO__actions__ZOMBIE_TASK_TIMEOUT=10m

# Timeout to stop tasks which have a running status but don't end for a long time.
FORGEJO__actions__ENDLESS_TASK_TIMEOUT=3h

# Timeout to cancel jobs which haven't been picked up by a runner.
FORGEJO__actions__ABANDONED_JOB_TIMEOUT=24h

# Log retention time in days.
FORGEJO__actions__LOG_RETENTION_DAYS=365

# ---------------------------------------------------------------------------- #
#               ------- Other ------
# ---------------------------------------------------------------------------- #
# Show Forgejo and Go version information in the footer.
FORGEJO__other__SHOW_FOOTER_VERSION=true

# Show the time of template execution in the footer.
FORGEJO__other__SHOW_FOOTER_TEMPLATE_LOAD_TIME=true

# Enable/Disable RSS/Atom feed.
FORGEJO__other__ENABLE_FEED=true

# Generate sitemap.
FORGEJO__other__ENABLE_SITEMAP=true
