# ---------------------------------------------------------------------------- #
#               ------- Hermes Configuration File --------
# ---------------------------------------------------------------------------- #
# https://hermes-agent.nousresearch.com/docs/user-guide/docker

# ---------------------------------------------------------------------------- #
#               ------- API --------
# ---------------------------------------------------------------------------- #
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=${HERMES_API_SERVER_KEY}
API_SERVER_CORS_ORIGINS='*'

# ---------------------------------------------------------------------------- #
#               ------- Dashboard --------
# ---------------------------------------------------------------------------- #
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=9119
# HERMES_DASHBOARD_INSECURE=

HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=${HERMES_PASSWORD}
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=${HERMES_USERNAME}
HERMES_DASHBOARD_BASIC_AUTH_SECRET=${HERMES_BASIC_AUTH_SECRET}
