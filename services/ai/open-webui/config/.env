# IMAGES_GEMINI_API_BASE_URL=
# IMAGES_GEMINI_API_KEY=${OPEN_WEBUI_GEMINI_API_KEY}
# IMAGES_EDIT_GEMINI_API_BASE_URL=
# IMAGES_EDIT_GEMINI_API_KEY=${OPEN_WEBUI_GEMINI_API_KEY}

