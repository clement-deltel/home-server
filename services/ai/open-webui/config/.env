#               ------- Image Generation — OpenAI DALL-E --------
# ---------------------------------------------------------------------------- #

# OpenAI-compatible base URL for DALL-E (falls back to OPENAI_API_BASE_URL). [ConfigVar]
# IMAGES_OPENAI_API_BASE_URL=

# API key for DALL-E (falls back to OPENAI_API_KEY). [ConfigVar]
# IMAGES_OPENAI_API_KEY=${OPENAI_OPEN_WEBUI_API_KEY}

# Optional api-version query parameter (required for Azure). [ConfigVar]
# IMAGES_OPENAI_API_VERSION=

# Additional OpenAI image params as JSON (e.g., {"quality": "hd"}). [ConfigVar]
# IMAGES_OPENAI_API_PARAMS={}

# OpenAI image editing: base URL, key, API version
# IMAGES_EDIT_OPENAI_API_BASE_URL=
# IMAGES_EDIT_OPENAI_API_KEY=${OPENAI_OPEN_WEBUI_API_KEY}
# IMAGES_EDIT_OPENAI_API_VERSION=

