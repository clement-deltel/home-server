# ENABLE_OTEL=false
# ENABLE_OTEL_TRACES=false
# ENABLE_OTEL_METRICS=false
# ENABLE_OTEL_LOGS=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=open-webui

# ---------------------------------------------------------------------------- #
#               ------- Database Pool --------
# ---------------------------------------------------------------------------- #

# Full database connection URL (takes precedence over individual params).
# For PostgreSQL: postgresql+asyncpg://user:pass@host:5432/openwebui
# REQUIRED for multi-replica/worker deployments (SQLite is not safe).
# DATABASE_URL=sqlite:///${DATA_DIR}/webui.db

# Auto-run DB migrations on startup. Set false on all but one pod in multi-pod.
# ENABLE_DB_MIGRATIONS=true

# Individual DB params (used to construct DATABASE_URL if not explicitly set):
# DATABASE_TYPE=sqlite
# DATABASE_USER=
# DATABASE_PASSWORD=${OPEN_WEBUI_DB_PASSWORD}
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_NAME=

# Min interval (seconds) between user last_active_at DB writes.
# MANDATORY for production: set 300-500. Prevents per-request DB writes.
# DATABASE_USER_ACTIVE_STATUS_UPDATE_INTERVAL=300

# Reuses DB sessions across requests (PostgreSQL: consider true; SQLite: keep false).
# DATABASE_ENABLE_SESSION_SHARING=false

# Pool size. On SQLite, unset falls back to 512 internally (large memory footprint).
# Set explicitly on memory-constrained containers.
# DATABASE_POOL_SIZE=

# Pool max overflow.
# DATABASE_POOL_MAX_OVERFLOW=0

# Pool timeout in seconds.
# DATABASE_POOL_TIMEOUT=30

# Pool recycle time in seconds.
# DATABASE_POOL_RECYCLE=3600

# ---------- SQLite-specific PRAGMAs ----------
# Enables WAL mode (better read/write concurrency).
# DATABASE_ENABLE_SQLITE_WAL=false

# Synchronous mode: OFF(0), NORMAL(1), FULL(2), EXTRA(3).
# DATABASE_SQLITE_PRAGMA_SYNCHRONOUS=NORMAL

# Busy timeout in ms (how long to wait for write lock).
# DATABASE_SQLITE_PRAGMA_BUSY_TIMEOUT=5000

# Page cache per connection in KiB (negative = KiB, default -65536 ≈ 64 MB).
# PER CONNECTION — lower on memory-constrained containers.
# DATABASE_SQLITE_PRAGMA_CACHE_SIZE=-65536

# Temp store: DEFAULT(0), FILE(1), MEMORY(2).
# DATABASE_SQLITE_PRAGMA_TEMP_STORE=MEMORY

# mmap size in bytes (default 268435456 ≈ 256 MB). PER CONNECTION.
# DATABASE_SQLITE_PRAGMA_MMAP_SIZE=268435456

# WAL file size cap in bytes (default 67108864 ≈ 64 MB).
# DATABASE_SQLITE_PRAGMA_JOURNAL_SIZE_LIMIT=67108864

# ---------- Encrypted SQLite (SQLCipher) ----------
# Requires: libsqlcipher-dev + pip install sqlcipher3-wheels
# DATABASE_TYPE=sqlite+sqlcipher
# DATABASE_PASSWORD=${OPEN_WEBUI_SQLCIPHER_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Redis --------
# ---------------------------------------------------------------------------- #

# Redis URL for application state. REQUIRED for multi-worker/multi-node.
# REDIS_URL=redis://localhost:6379/0

# Redis Sentinel hosts (comma-separated). When set, REDIS_URL hostname is
# interpreted as the Sentinel service name.
# REDIS_SENTINEL_HOSTS=

# Sentinel port.
# REDIS_SENTINEL_PORT=26379

# Connect to Redis Cluster.
# REDIS_CLUSTER=false

# Key prefix for namespacing (allows multiple instances on one Redis).
# REDIS_KEY_PREFIX=open-webui

# Socket connect timeout in seconds. CRITICAL for Sentinel deployments.
# REDIS_SOCKET_CONNECT_TIMEOUT=5

# Enables TCP SO_KEEPALIVE on Redis sockets.
# REDIS_SOCKET_KEEPALIVE=false

# Health check interval in seconds (PINGs idle connections before reuse).
# Recommended: 60 (keep below Redis server timeout and firewall idle timeout).
# REDIS_HEALTH_CHECK_INTERVAL=

# ---------------------------------------------------------------------------- #
#               ------- Redis / WebSocket --------
# ---------------------------------------------------------------------------- #

# Enables websocket support.
# ENABLE_WEBSOCKET_SUPPORT=true

# WebSocket manager: redis (required for multi-worker).
# WEBSOCKET_MANAGER=

# WebSocket Redis URL (falls back to REDIS_URL).
# WEBSOCKET_REDIS_URL=

# WebSocket Redis Sentinel hosts.
# WEBSOCKET_SENTINEL_HOSTS=

# WebSocket Redis Cluster mode.
# WEBSOCKET_REDIS_CLUSTER=false

# Additional Redis connection options as JSON.
# WEBSOCKET_REDIS_OPTIONS={}

# WebSocket ping timeout in seconds.
# WEBSOCKET_SERVER_PING_TIMEOUT=20

# WebSocket ping interval in seconds.
# WEBSOCKET_SERVER_PING_INTERVAL=25

# Timeout for event_call interactive prompts in seconds.
# WEBSOCKET_EVENT_CALLER_TIMEOUT=300

# ---------------------------------------------------------------------------- #
#               ------- Uvicorn --------
# ---------------------------------------------------------------------------- #

# Number of worker processes. Keep at 1 for orchestrated (K8s) deployments.
# UVICORN_WORKERS=1

# ---------------------------------------------------------------------------- #
#               ------- Cache --------
# ---------------------------------------------------------------------------- #

# Cache-Control header for all HTTP responses.
# CACHE_CONTROL=

# ---------------------------------------------------------------------------- #
#               ------- Proxy --------
# ---------------------------------------------------------------------------- #

# HTTP proxy URL.
# http_proxy=

# HTTPS proxy URL.
# https_proxy=

# Comma-separated domains/IPs to bypass proxy.
# no_proxy=

# ---------------------------------------------------------------------------- #
#               ------- Pip Install --------
# ---------------------------------------------------------------------------- #

# Auto-runs pip install for function/tool requirements frontmatter.
# Set false in production (security: prevents arbitrary package installs).
# ENABLE_PIP_INSTALL_FRONTMATTER_REQUIREMENTS=true

# Additional pip command-line options.
# PIP_OPTIONS=

# Custom pip package index options.
# PIP_PACKAGE_INDEX_OPTIONS=

# ---------------------------------------------------------------------------- #
#               ------- Manual Review Required ------
# ---------------------------------------------------------------------------- #
# The following require site-specific decisions:
#
# DATABASE_URL / Redis / Vector DB
#   Defaults are fine for single-user local deployments. For multi-user,
#   multi-worker, or Kubernetes, you MUST configure PostgreSQL (DATABASE_URL),
#   Redis (REDIS_URL), and switch from ChromaDB to a client-server vector DB.
