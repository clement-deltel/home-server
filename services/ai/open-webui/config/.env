# ---------------------------------------------------------------------------- #
#               ------- Image Generation — AUTOMATIC1111 --------
# ---------------------------------------------------------------------------- #

# AUTOMATIC1111_BASE_URL=
# AUTOMATIC1111_API_AUTH=

# ---------------------------------------------------------------------------- #
#               ------- OAuth --------
# ---------------------------------------------------------------------------- #

# Master OAuth signup switch. [ConfigVar]
# ENABLE_OAUTH_SIGNUP=false

# Auto-redirects to OAuth provider (requires SSO-only deployment). [ConfigVar]
# OAUTH_AUTO_REDIRECT=false

# When ENABLE_PERSISTENT_CONFIG is true, controls whether OAuth settings
# are also loaded from DB (false = always read from env vars).
# ENABLE_OAUTH_PERSISTENT_CONFIG=false

# Overrides the OAuth subject claim (default: sub).
# OAUTH_SUB_CLAIM=

# Merges OAuth accounts with existing accounts by email (UNSAFE —
# not all providers verify emails). [ConfigVar]
# OAUTH_MERGE_ACCOUNTS_BY_EMAIL=false

# Enables authentication with OIDC providers that don't expose email scope. [ConfigVar]
# ENABLE_OAUTH_WITHOUT_EMAIL=false

# Updates local profile picture from OAuth provider on login. [ConfigVar]
# OAUTH_UPDATE_PICTURE_ON_LOGIN=false

# Sets legacy oauth_id_token cookie (backward compat). Set false for new deploys.
# ENABLE_OAUTH_ID_TOKEN_COOKIE=true

# Enables OAuth token exchange endpoint for external apps.
# ENABLE_OAUTH_TOKEN_EXCHANGE=false

# Enables OIDC Back-Channel Logout.
# ENABLE_OAUTH_BACKCHANNEL_LOGOUT=false

# Encryption key for OAuth client tokens (falls back to WEBUI_SECRET_KEY).
# Generate with: openssl rand -hex 32
# OAUTH_CLIENT_INFO_ENCRYPTION_KEY=${OPEN_WEBUI_OAUTH_CLIENT_ENCRYPTION_KEY}

# Encryption key for OAuth session tokens (falls back to WEBUI_SECRET_KEY).
# REQUIRED for multi-replica deployments.
# Generate with: openssl rand -hex 32
# OAUTH_SESSION_TOKEN_ENCRYPTION_KEY=${OPEN_WEBUI_OAUTH_SESSION_ENCRYPTION_KEY}

# Max concurrent OAuth sessions per user per provider.
# OAUTH_MAX_SESSIONS_PER_USER=10

# Includes scope in refresh token requests (required for Azure AD).
# OAUTH_REFRESH_TOKEN_INCLUDE_SCOPE=false

# ---------- Trusted Header Auth ----------
# WEBUI_AUTH_TRUSTED_EMAIL_HEADER=
# WEBUI_AUTH_TRUSTED_NAME_HEADER=
# WEBUI_AUTH_TRUSTED_GROUPS_HEADER=
# WEBUI_AUTH_TRUSTED_ROLE_HEADER=

# ---------- Google OAuth ----------
# GOOGLE_CLIENT_ID=${OPEN_WEBUI_GOOGLE_CLIENT_ID} [ConfigVar]
# GOOGLE_CLIENT_SECRET=${OPEN_WEBUI_GOOGLE_CLIENT_SECRET} [ConfigVar]
# GOOGLE_OAUTH_SCOPE=openid email profile
# GOOGLE_REDIRECT_URI=<backend>/oauth/google/callback

# ---------- Microsoft OAuth ----------
# MICROSOFT_CLIENT_ID=${OPEN_WEBUI_MICROSOFT_CLIENT_ID} [ConfigVar]
# MICROSOFT_CLIENT_SECRET=${OPEN_WEBUI_MICROSOFT_CLIENT_SECRET} [ConfigVar]
# MICROSOFT_CLIENT_TENANT_ID= [ConfigVar]
# MICROSOFT_OAUTH_SCOPE=openid email profile
# MICROSOFT_REDIRECT_URI=<backend>/oauth/microsoft/callback

# ---------- GitHub OAuth ----------
# GITHUB_CLIENT_ID=${OPEN_WEBUI_GITHUB_CLIENT_ID} [ConfigVar]
# GITHUB_CLIENT_SECRET=${OPEN_WEBUI_GITHUB_CLIENT_SECRET} [ConfigVar]
# GITHUB_CLIENT_SCOPE=user:email

# ---------- OpenID (OIDC) ----------
# OAUTH_CLIENT_ID=${OPEN_WEBUI_OIDC_CLIENT_ID} [ConfigVar]
# OAUTH_CLIENT_SECRET=${OPEN_WEBUI_OIDC_CLIENT_SECRET} [ConfigVar]
# OPENID_PROVIDER_URL= [ConfigVar]  # MUST be set for logout to work with most providers
# OPENID_REDIRECT_URI=<backend>/oauth/oidc/callback
# OAUTH_SCOPES=openid email profile
# OAUTH_PROVIDER_NAME=SSO
# OAUTH_USERNAME_CLAIM=name
# OAUTH_EMAIL_CLAIM=email
# OAUTH_PICTURE_CLAIM=picture
# OAUTH_GROUP_CLAIM=groups
# ENABLE_OAUTH_ROLE_MANAGEMENT=false
# ENABLE_OAUTH_GROUP_MANAGEMENT=false
# ENABLE_OAUTH_GROUP_CREATION=false
# OAUTH_ROLES_CLAIM=roles
# OAUTH_ALLOWED_ROLES=user,admin
# OAUTH_ADMIN_ROLES=admin
# OAUTH_ALLOWED_DOMAINS=*

# ---------- Feishu OAuth ----------
# FEISHU_CLIENT_ID=${OPEN_WEBUI_FEISHU_CLIENT_ID} [ConfigVar]
# FEISHU_CLIENT_SECRET=${OPEN_WEBUI_FEISHU_CLIENT_SECRET} [ConfigVar]

