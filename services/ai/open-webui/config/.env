# ---------------------------------------------------------------------------- #

# COMFYUI_BASE_URL=
# COMFYUI_API_KEY=${OPEN_WEBUI_COMFYUI_API_KEY}
# COMFYUI_WORKFLOW= (JSON — export from ComfyUI with "Save (API Format)")
# IMAGES_EDIT_COMFYUI_BASE_URL=
