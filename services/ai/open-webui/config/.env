# ---------------------------------------------------------------------------- #
#               ------- Open WebUI Configuration File ------
# ---------------------------------------------------------------------------- #
# https://docs.openwebui.com/reference/env-configuration
# Up-to-date with v0.9.6
#
# ConfigVar note: variables marked [ConfigVar] are persisted to the database
# on first launch. After that, the DB value takes precedence. Update them via
# the Admin Panel, or set ENABLE_PERSISTENT_CONFIG=false to force env-var usage.

# ---------------------------------------------------------------------------- #
#               ------- General --------
# ---------------------------------------------------------------------------- #

# Environment: dev (enables /docs), or prod (production defaults).
ENV=prod

# Override the instance name displayed in the UI. Appends (Open WebUI) if set.
# CUSTOM_NAME=

# Sets the main WebUI name (default: Open WebUI).
WEBUI_NAME=Open WebUI

# The public URL where your Open WebUI instance is reachable. Required for
# OAuth/SSO and search engine support. [ConfigVar]# WARNING: Must be set before any OAuth/SSO login, or logins will fail.
WEBUI_URL=https://${OPEN_WEBUI_HOST}

# Port to listen on. Ignored when using `open-webui serve --port`.
PORT=8080

# ---------------------------------------------------------------------------- #
#               ------- Authentication --------
# ---------------------------------------------------------------------------- #

# Toggles user account creation. [ConfigVar]
ENABLE_SIGNUP=false

# Adds a "Confirm Password" field on the sign-up page.
# ENABLE_SIGNUP_PASSWORD_CONFIRMATION=false

# Toggles email/password sign-in form. [ConfigVar]
ENABLE_LOGIN_FORM=true

# Controls visibility of password change UI in Settings > Account. [ConfigVar]
ENABLE_PASSWORD_CHANGE_FORM=true

# When false, disables all password-based logins (SSO-only). Only safe when
# ENABLE_OAUTH_SIGNUP is also true.
ENABLE_PASSWORD_AUTH=true

# Enable password complexity validation.
# ENABLE_PASSWORD_VALIDATION=false

# Regex for password complexity (default: 8+ chars, upper, lower, digit, special).
# PASSWORD_VALIDATION_REGEX_PATTERN=^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\w\s]).{8,}$

# Custom hint shown when password fails validation.
# PASSWORD_VALIDATION_HINT=

# Master authentication switch. Disabling requires a fresh install with no users.
WEBUI_AUTH=true

# ---------------------------------------------------------------------------- #
#               ------- Admin & User Defaults --------
# ---------------------------------------------------------------------------- #

# Email for auto-created admin account on first startup (no users must exist).
# Must be paired with WEBUI_ADMIN_PASSWORD. After creation, signup is disabled.
WEBUI_ADMIN_EMAIL=${OPEN_WEBUI_ADMIN_EMAIL}

# Password for the auto-created admin account. Use a strong, unique value.
WEBUI_ADMIN_PASSWORD=${OPEN_WEBUI_ADMIN_PASSWORD}

# Display name for the auto-created admin account.
WEBUI_ADMIN_NAME=${USER_NAME}

# Sets the admin email shown in the UI. [ConfigVar]
ADMIN_EMAIL=${OPEN_WEBUI_ADMIN_EMAIL}

# Toggles whether admin details are shown in the interface. [ConfigVar]
SHOW_ADMIN_DETAILS=false

# Default role for new users: pending, user, admin. [ConfigVar]
DEFAULT_USER_ROLE=pending

# Default locale (e.g., en, fr, de). [ConfigVar]
DEFAULT_LOCALE=en

# Default group ID assigned to new users on registration. [ConfigVar]
# DEFAULT_GROUP_ID=

# Default share permission for new groups: members, true, false.
# DEFAULT_GROUP_SHARE_PERMISSION=members

# Comma-separated list of model IDs to set as default models. [ConfigVar]
# DEFAULT_MODELS=

# Comma-separated list of model IDs pinned by default for new users. [ConfigVar]
# DEFAULT_PINNED_MODELS=

# Global default model metadata as JSON (capabilities, etc.). [ConfigVar]
# DEFAULT_MODEL_METADATA={}

# Global default model parameters as JSON (temperature, top_p, etc.). [ConfigVar]
# DEFAULT_MODEL_PARAMS={}

# ---------------------------------------------------------------------------- #
#               ------- Feature Toggles --------
# ---------------------------------------------------------------------------- #

# Enables real-time per-token chat saving. PERFORMANCE RISK: keep off in production.
ENABLE_REALTIME_CHAT_SAVE=false

# Enables admin export (data, chats, DB). Requires restart.
ENABLE_ADMIN_EXPORT=true

# Enables admin access to other users' chats via admin panel.
ENABLE_ADMIN_CHAT_ACCESS=true

# Enables the admin Analytics tab. Requires restart.
# ENABLE_ADMIN_ANALYTICS=true

# When false, admin sees only their own workspace items + shares (not all users').
# Deprecates ENABLE_ADMIN_WORKSPACE_CONTENT_ACCESS.
# BYPASS_ADMIN_ACCESS_CONTROL=true

# Bypasses model access control — all users see all models.
BYPASS_MODEL_ACCESS_CONTROL=false

# Enables channel support. [ConfigVar]
ENABLE_CHANNELS=false

# Enables folders for organizing chats. [ConfigVar]
# ENABLE_FOLDERS=true

# Enables notes feature. [ConfigVar]
# ENABLE_NOTES=true

# Enables memory feature (long-term user info). [ConfigVar]
# ENABLE_MEMORIES=true

# Enables Automations feature. [ConfigVar]
# ENABLE_AUTOMATIONS=true

# Enables Calendar feature. [ConfigVar]
# ENABLE_CALENDAR=true

# Enables user webhooks (SSRF-protected). [ConfigVar]
# ENABLE_USER_WEBHOOKS=false

# Enables easter egg features (special themes, etc.).
# ENABLE_EASTER_EGGS=true

# Enables title generation for new chats. [ConfigVar]
# ENABLE_TITLE_GENERATION=true

# Enables follow-up question generation. [ConfigVar]
# ENABLE_FOLLOW_UP_GENERATION=true

# Enables autocomplete generation. [ConfigVar]
# ENABLE_AUTOCOMPLETE_GENERATION=true

# Enables tag generation for chats. [ConfigVar]
# ENABLE_TAGS_GENERATION=true

# Enables community sharing (prompts, tools, models). [ConfigVar]
# ENABLE_COMMUNITY_SHARING=true

# Enables message rating (thumbs up/down). [ConfigVar]
# ENABLE_MESSAGE_RATING=true

# Enables evaluation arena models. [ConfigVar]
# ENABLE_EVALUATION_ARENA_MODELS=true

# Shows active user count to all users (false = admin only). [ConfigVar]
# ENABLE_PUBLIC_ACTIVE_USERS_COUNT=true

# Enables user status indicators (online/away). [ConfigVar]
# ENABLE_USER_STATUS=true

# ---------------------------------------------------------------------------- #
#               ------- Persistent Config --------
# ---------------------------------------------------------------------------- #

# When false, environment variables always take precedence over DB-stored
# config. UI changes won't survive restarts.
# ENABLE_PERSISTENT_CONFIG=true

# Resets config.json on startup to env-var values.
# RESET_CONFIG_ON_START=false

# ---------------------------------------------------------------------------- #
#               ------- Performance --------
# ---------------------------------------------------------------------------- #

# Max concurrent blocking operations in the AnyIO thread pool.
# Default (unset) = 40. Set to 2000+ for production multi-user instances.
# Exception: keep low (~200) on constrained hardware (Raspberry Pi, tiny VPS).
# THREAD_POOL_SIZE=2000

# ---------------------------------------------------------------------------- #
#               ------- Webhook, Banners & Misc --------
# ---------------------------------------------------------------------------- #

# Webhook URL for Discord/Slack/Teams notifications. [ConfigVar]
# WEBHOOK_URL=

# Build hash for release identification.
WEBUI_BUILD_HASH=dev-build

# JSON list of banner objects to display. [ConfigVar]
# WEBUI_BANNERS=[]

# Custom text appended when copying a message in chat. [ConfigVar]
# RESPONSE_WATERMARK=

# Content-Security-Policy for srcdoc iframes (Artifacts, previews).
# IFRAME_CSP=

# External PWA manifest URL; uses default manifest.json if unset.
# EXTERNAL_PWA_MANIFEST_URL=

# Enables gzip compression middleware for HTTP responses.
# ENABLE_COMPRESSION_MIDDLEWARE=true

# Global default prompt suggestions (JSON array of {title, content} objects).
# DEFAULT_PROMPT_SUGGESTIONS=[]

# Enterprise license key. [ConfigVar]
# LICENSE_KEY=${OPEN_WEBUI_LICENSE_KEY}

# SSL assert fingerprint. [ConfigVar]
# SSL_ASSERT_FINGERPRINT=

# Enables custom model fallback to DEFAULT_MODELS when base model is missing.
# ENABLE_CUSTOM_MODEL_FALLBACK=false

# Auto-converts base64 images in responses to image file URLs.
# ENABLE_CHAT_RESPONSE_BASE64_IMAGE_URL_CONVERSION=false

# Fallback MIME-type dictionary for minimal container images missing /etc/mime.types.
# ENABLE_IMAGE_CONTENT_TYPE_EXTENSION_FALLBACK=false

# Controls whether profile image endpoints honor external URLs via 302 redirect.
# ENABLE_PROFILE_IMAGE_URL_FORWARDING=true

# Allowlisted MIME types for serving profile images as data URIs.
# PROFILE_IMAGE_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/gif,image/webp

# Max size in bytes for inline data:image profile images.
# PROFILE_IMAGE_MAX_DATA_URI_SIZE=

# Minimum token batch size for streaming responses (higher = less CPU).
# CHAT_RESPONSE_STREAM_DELTA_CHUNK_SIZE=1

# Max buffer size in bytes for stream response chunks (empty = no limit).
# Recommended: 16-20 MB (16777216) for image generation models.
# CHAT_STREAM_RESPONSE_CHUNK_MAX_BUFFER_SIZE=

# Max sequential tool-calling iterations per assistant response (Native FC).
# CHAT_RESPONSE_MAX_TOOL_CALL_ITERATIONS=256

# Enables stateful session handling for the Responses API (experimental).
# ENABLE_RESPONSES_API_STATEFUL=false

# Bypasses access control during RAG retrieval.
# BYPASS_RETRIEVAL_ACCESS_CONTROL=false

# Controls unscoped/legacy collection handling in RAG retrieval.
# ENABLE_RETRIEVAL_UNSCOPED_COLLECTIONS=false

# Indicates Docker runtime (set automatically).
DOCKER=true

# ---------------------------------------------------------------------------- #
#               ------- GPU / Device --------
# ---------------------------------------------------------------------------- #

# Builds Docker image with NVIDIA CUDA support (for Whisper & embeddings).
USE_CUDA_DOCKER=false

# Controls CUDA acceleration for local models.
# USE_CUDA=false

# Device type for model execution: cpu, cuda, mps.
# DEVICE_TYPE=cpu

# ---------------------------------------------------------------------------- #
#               ------- JWT & Session Security --------
# ---------------------------------------------------------------------------- #

# JWT expiration time. Valid units: s, m, h, d, w, or -1 for no expiration.
# WARNING: -1 disables expiration — never use in production.
# [ConfigVar]
JWT_EXPIRES_IN=7d

# Overrides the secret key for JWT signing and sensitive data encryption.
# Generate with: openssl rand -hex 32
# CRITICAL: Set explicitly for multi-worker/multi-node deployments.
WEBUI_SECRET_KEY=${OPEN_WEBUI_SECRET_KEY}

# Session cookie SameSite: lax, strict, none.
# WEBUI_SESSION_COOKIE_SAME_SITE=lax

# Sets Secure flag on session cookies.
# WEBUI_SESSION_COOKIE_SECURE=false

# Auth cookie SameSite: lax, strict, none (falls back to session setting).
# WEBUI_AUTH_COOKIE_SAME_SITE=lax

# Sets Secure flag on auth cookies (falls back to session setting).
# WEBUI_AUTH_COOKIE_SECURE=false

# Enables automatic version update checks. Disabled if OFFLINE_MODE is true.
ENABLE_VERSION_UPDATE_CHECK=true

# Disables network connections for update checks and HuggingFace model downloads.
# OFFLINE_MODE=false

# Tells HuggingFace to operate offline (1 = no downloads).
# HF_HUB_OFFLINE=0

# Enables safe mode — disables all functions.
# SAFE_MODE=false

# CORS allowed origins, semicolon-separated.
# CORS_ALLOW_ORIGIN=*

# Additional allowed CORS schemes (e.g., app;file;electron), semicolon-separated.
# CORS_ALLOW_CUSTOM_SCHEME=

# ---------------------------------------------------------------------------- #
#               ------- Forward User Info Headers --------
# ---------------------------------------------------------------------------- #

# Forwards user/session info headers to upstream APIs (Ollama, OpenAI, MCP, Tools).
# ENABLE_FORWARD_USER_INFO_HEADERS=false

# Custom header name overrides:
# FORWARD_USER_INFO_HEADER_USER_NAME=X-OpenWebUI-User-Name
# FORWARD_USER_INFO_HEADER_USER_ID=X-OpenWebUI-User-Id
# FORWARD_USER_INFO_HEADER_USER_EMAIL=X-OpenWebUI-User-Email
# FORWARD_USER_INFO_HEADER_USER_ROLE=X-OpenWebUI-User-Role
# FORWARD_SESSION_INFO_HEADER_CHAT_ID=X-OpenWebUI-Chat-Id
# FORWARD_SESSION_INFO_HEADER_MESSAGE_ID=X-OpenWebUI-Message-Id

# When set, forwards user identity as a single HS256-signed JWT instead of
# plaintext headers. Upstream verifies with this shared secret.
# FORWARD_USER_INFO_HEADER_JWT_SECRET=${OPEN_WEBUI_FORWARD_JWT_SECRET}

# Name of the header carrying the signed JWT.
# FORWARD_USER_INFO_HEADER_JWT=X-OpenWebUI-User-Jwt

# Lifetime of the forwarded-identity JWT in seconds.
# FORWARD_USER_INFO_HEADER_JWT_EXPIRES_SECONDS=300

# ---------------------------------------------------------------------------- #
#               ------- SSL / TLS --------
# ---------------------------------------------------------------------------- #

# Bypasses SSL verification for RAG web fetches. [ConfigVar]
# ENABLE_WEB_LOADER_SSL_VERIFICATION=true

# Controls SSL verification for synchronous requests (Tika, External Reranker).
# REQUESTS_VERIFY=true

# ---------------------------------------------------------------------------- #
#               ------- AIOHTTP Client --------
# ---------------------------------------------------------------------------- #

# Timeout in seconds for AIOHTTP client connections (Ollama, OpenAI, etc.).
# AIOHTTP_CLIENT_TIMEOUT=300

# Timeout in seconds for fetching model lists from endpoints.
# AIOHTTP_CLIENT_TIMEOUT_MODEL_LIST=10

# Timeout in seconds for fetching OpenAI model lists specifically.
# AIOHTTP_CLIENT_TIMEOUT_OPENAI_MODEL_LIST=

# Timeout for tool server API calls (falls back to AIOHTTP_CLIENT_TIMEOUT).
# AIOHTTP_CLIENT_TIMEOUT_TOOL_SERVER=

# Timeout for retrieving tool server metadata/configuration.
# AIOHTTP_CLIENT_TIMEOUT_TOOL_SERVER_DATA=10

# Controls SSL verification for AIOHTTP client sessions.
# AIOHTTP_CLIENT_SESSION_SSL=true

# Controls SSL verification for tool server connections specifically.
# AIOHTTP_CLIENT_SESSION_TOOL_SERVER_SSL=true

# Controls whether AIOHTTP follows 3xx redirects (SSRF protection).
# AIOHTTP_CLIENT_ALLOW_REDIRECTS=false

# MCP initialize() handshake timeout in seconds.
# MCP_INITIALIZE_TIMEOUT=10

# User-Agent header for outbound web fetches (default Python UA is blocked by many sites).
# USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0 Safari/537.36

# Max total concurrent connections in the shared AIOHTTP pool.
# AIOHTTP_POOL_CONNECTIONS=

# Max concurrent connections per host in the shared AIOHTTP pool.
# AIOHTTP_POOL_CONNECTIONS_PER_HOST=

# DNS cache TTL in seconds for the shared AIOHTTP pool.
# AIOHTTP_POOL_DNS_TTL=300

# ---------------------------------------------------------------------------- #
#               ------- Directories --------
# ---------------------------------------------------------------------------- #

# Base directory for data storage (uploads, cache, vector DB, etc.).
# DATA_DIR=./data

# Fonts directory.
# FONTS_DIR=

# Location of built frontend files.
# FRONTEND_BUILD_DIR=../build

# Directory for static files (favicon, etc.).
# STATIC_DIR=./static

# ---------------------------------------------------------------------------- #
#               ------- Logging --------
# ---------------------------------------------------------------------------- #

# Global log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# GLOBAL_LOG_LEVEL=INFO

# Set to 'json' for structured JSON logging (suppresses ASCII banner).
LOG_FORMAT=json

# Output audit logs to stdout.
# ENABLE_AUDIT_STDOUT=false

# Write audit logs to file.
# ENABLE_AUDIT_LOGS_FILE=true

# Path to audit log file.
# AUDIT_LOGS_FILE_PATH=${DATA_DIR}/audit.log

# Max audit log file size before rotation (e.g., 10MB, 100MB, 1GB).
# AUDIT_LOG_FILE_ROTATION_SIZE=10MB

# Comma-separated logger names for audit capture.
# AUDIT_UVICORN_LOGGER_NAMES=uvicorn.access

# Audit verbosity: NONE, METADATA, REQUEST, REQUEST_RESPONSE.
# AUDIT_LOG_LEVEL=NONE

# Max body size in bytes for audit logs.
# MAX_BODY_LOG_SIZE=2048

# Comma-separated URL paths to exclude from audit (blacklist).
# AUDIT_EXCLUDED_PATHS=/chats,/chat,/folders

# Comma-separated URL paths to include in audit (whitelist — overrides blacklist).
# AUDIT_INCLUDED_PATHS=

# ---------------------------------------------------------------------------- #
#               ------- Ollama --------
# ---------------------------------------------------------------------------- #

# Enables Ollama API integration. [ConfigVar]
ENABLE_OLLAMA_API=true

# Ollama backend URL. Deprecated: OLLAMA_API_BASE_URL.
OLLAMA_BASE_URL=http://ollama:11434

# Load-balanced Ollama hosts, semicolon-separated. Takes precedence over OLLAMA_BASE_URL. [ConfigVar]
# OLLAMA_BASE_URLS=

# Builds Docker image with bundled Ollama instance.
# USE_OLLAMA_DOCKER=false

# Assumes Helm chart deployment; sets OLLAMA_BASE_URL accordingly.
# K8S_FLAG=false

# ---------------------------------------------------------------------------- #
#               ------- OpenAI --------
# ---------------------------------------------------------------------------- #

# Enables OpenAI API integration. [ConfigVar]
ENABLE_OPENAI_API=true

# OpenAI-compatible base API URL. [ConfigVar]
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Load-balanced OpenAI base URLs, semicolon-separated. [ConfigVar]
# OPENAI_API_BASE_URLS=

# OpenAI API key. [ConfigVar]
# Use least-privilege keys, not provider management/master keys.
OPENAI_API_KEY=${OPENAI_OPEN_WEBUI_API_KEY}

# Multiple OpenAI API keys, semicolon-separated. [ConfigVar]
# OPENAI_API_KEYS=

# When enabled, the catch-all proxy forwards requests to upstream using admin
# key with no access control. DANGER: keep disabled unless you need it.
# ENABLE_OPENAI_API_PASSTHROUGH=false

# ---------------------------------------------------------------------------- #
#               ------- Tasks --------
# ---------------------------------------------------------------------------- #

# Default model for tasks (title/search query gen) when using Ollama. [ConfigVar]
# TASK_MODEL=

# Default model for tasks when using OpenAI-compatible endpoints. [ConfigVar]
# TASK_MODEL_EXTERNAL=

# Custom prompt template for title generation. [ConfigVar]
# TITLE_GENERATION_PROMPT_TEMPLATE=

# Custom prompt template for follow-up question generation. [ConfigVar]
# FOLLOW_UP_GENERATION_PROMPT_TEMPLATE=

# Custom prompt template for tool function calling. [ConfigVar]
# TOOLS_FUNCTION_CALLING_PROMPT_TEMPLATE=

# ---------------------------------------------------------------------------- #
#               ------- Code Execution --------
# ---------------------------------------------------------------------------- #

# Enables code execution. [ConfigVar]
# ENABLE_CODE_EXECUTION=true

# Code execution engine: pyodide, jupyter. [ConfigVar]
# CODE_EXECUTION_ENGINE=pyodide

# Jupyter URL for code execution. [ConfigVar]
# CODE_EXECUTION_JUPYTER_URL=

# Jupyter auth method. [ConfigVar]
# CODE_EXECUTION_JUPYTER_AUTH=

# Jupyter auth token. [ConfigVar]
# CODE_EXECUTION_JUPYTER_AUTH_TOKEN=${OPEN_WEBUI_JUPYTER_AUTH_TOKEN}

# Jupyter auth password. [ConfigVar]
# CODE_EXECUTION_JUPYTER_AUTH_PASSWORD=${OPEN_WEBUI_JUPYTER_AUTH_PASSWORD}

# Timeout for Jupyter code execution. [ConfigVar]
# CODE_EXECUTION_JUPYTER_TIMEOUT=

# ---------------------------------------------------------------------------- #
#               ------- Code Interpreter --------
# ---------------------------------------------------------------------------- #

# Enables code interpreter. [ConfigVar]
# ENABLE_CODE_INTERPRETER=true

# Code interpreter engine: pyodide, jupyter. [ConfigVar]
# CODE_INTERPRETER_ENGINE=pyodide

# Comma-separated blacklisted Python modules.
# CODE_INTERPRETER_BLACKLISTED_MODULES=

# Custom prompt template for code interpreter. [ConfigVar]
# CODE_INTERPRETER_PROMPT_TEMPLATE=

# Jupyter URL for code interpreter. [ConfigVar]
# CODE_INTERPRETER_JUPYTER_URL=

# Jupyter auth method. [ConfigVar]
# CODE_INTERPRETER_JUPYTER_AUTH=

# Jupyter auth token. [ConfigVar]
# CODE_INTERPRETER_JUPYTER_AUTH_TOKEN=${OPEN_WEBUI_JUPYTER_INTERPRETER_TOKEN}

# Jupyter auth password. [ConfigVar]
# CODE_INTERPRETER_JUPYTER_AUTH_PASSWORD=${OPEN_WEBUI_JUPYTER_INTERPRETER_PASSWORD}

# Timeout for Jupyter code interpreter. [ConfigVar]
# CODE_INTERPRETER_JUPYTER_TIMEOUT=

# ---------------------------------------------------------------------------- #
#               ------- Direct Connections (OpenAPI/MCPO Tool Servers) --------
# ---------------------------------------------------------------------------- #

# Enables direct connections to tool servers. [ConfigVar]
# ENABLE_DIRECT_CONNECTIONS=true

# JSON array of tool server connection configurations. [ConfigVar]
# TOOL_SERVER_CONNECTIONS=[]

# ---------------------------------------------------------------------------- #
#               ------- Terminal Server --------
# ---------------------------------------------------------------------------- #

# JSON array of terminal server connection configs. [ConfigVar]
# TERMINAL_SERVER_CONNECTIONS=[]

# Custom HTTP response headers for the terminal proxy (JSON object).
# TERMINAL_PROXY_HEADERS={}

# ---------------------------------------------------------------------------- #
#               ------- Autocomplete --------
# ---------------------------------------------------------------------------- #

# Max input length for autocomplete generation. [ConfigVar]
# AUTOCOMPLETE_GENERATION_INPUT_MAX_LENGTH=-1

# Custom prompt template for autocomplete generation. [ConfigVar]
# AUTOCOMPLETE_GENERATION_PROMPT_TEMPLATE=

# ---------------------------------------------------------------------------- #
#               ------- Tags Generation --------
# ---------------------------------------------------------------------------- #

# Custom prompt template for tag generation. [ConfigVar]
# TAGS_GENERATION_PROMPT_TEMPLATE=

# ---------------------------------------------------------------------------- #
#               ------- API Keys --------
# ---------------------------------------------------------------------------- #

# Enables API key creation globally. [ConfigVar]
# ENABLE_API_KEYS=false

# Enables endpoint restrictions on API keys. [ConfigVar]
# ENABLE_API_KEYS_ENDPOINT_RESTRICTIONS=false

# Comma-separated allowed endpoints when restrictions are enabled. [ConfigVar]
# API_KEYS_ALLOWED_ENDPOINTS=

# Custom HTTP header for API-key credentials (default: x-api-key).
# Useful behind proxies that consume Authorization header.
# CUSTOM_API_KEY_HEADER=x-api-key

# ---------------------------------------------------------------------------- #
#               ------- Model Caching --------
# ---------------------------------------------------------------------------- #

# Caches base model list in memory (reduces API calls to providers). [ConfigVar]
ENABLE_BASE_MODELS_CACHE=true

# TTL in seconds for model list cache (empty = disable). 0 = no caching.
# MODELS_CACHE_TTL=1

# ---------------------------------------------------------------------------- #
#               ------- Password Validation --------
# ---------------------------------------------------------------------------- #

# (See PASSWORD_VALIDATION_* under Authentication section above)

# ---------------------------------------------------------------------------- #
#               ------- RAG Embedding Model Trust --------
# ---------------------------------------------------------------------------- #

# Allow custom models from HuggingFace Hub with their own modeling files.
# RAG_EMBEDDING_MODEL_TRUST_REMOTE_CODE=false

# Same as above but for reranking models.
# RAG_RERANKING_MODEL_TRUST_REMOTE_CODE=false

# Auto-update Sentence-Transformer embedding model.
# RAG_EMBEDDING_MODEL_AUTO_UPDATE=true

# Auto-update reranking model.
# RAG_RERANKING_MODEL_AUTO_UPDATE=true

# ---------------------------------------------------------------------------- #
#               ------- Vector Database --------
# ---------------------------------------------------------------------------- #

# Vector database: chroma, elasticsearch, mariadb-vector, milvus, opensearch,
# pgvector, qdrant, pinecone, s3vector, oracle23ai, weaviate, valkey.
# WARNING: Default ChromaDB (SQLite) is NOT safe for multi-worker.
# VECTOR_DB=chroma

# ---------- ChromaDB ----------
# Tenant for ChromaDB RAG embeddings.
# CHROMA_TENANT=

# Database name within the ChromaDB tenant.
# CHROMA_DATABASE=

# Remote ChromaDB server host. Required for multi-worker (switches to HttpClient).
# CHROMA_HTTP_HOST=

# Remote ChromaDB server port.
# CHROMA_HTTP_PORT=8000

# Comma-separated HTTP headers for ChromaDB requests.
# CHROMA_HTTP_HEADERS=

# SSL for ChromaDB server connections.
# CHROMA_HTTP_SSL=false

# Auth provider for remote ChromaDB (e.g., chromadb.auth.basic_authn.BasicAuthClientProvider).
# CHROMA_CLIENT_AUTH_PROVIDER=

# Auth credentials for remote ChromaDB (e.g., username:password).
# CHROMA_CLIENT_AUTH_CREDENTIALS=${OPEN_WEBUI_CHROMA_CREDENTIALS}

# ---------- PGVector ----------
# PostgreSQL connection URL (falls back to DATABASE_URL).
# PGVECTOR_DB_URL=

# Max vector length for PGVector initialization.
# PGVECTOR_INITIALIZE_MAX_VECTOR_LENGTH=1536

# Auto-creates pgvector extension (set false if pre-configured).
# PGVECTOR_CREATE_EXTENSION=true

# Index method: ivfflat, hnsw. [ConfigVar]
# PGVECTOR_INDEX_METHOD=

# HNSW M parameter. [ConfigVar]
# PGVECTOR_HNSW_M=16

# HNSW ef_construction parameter. [ConfigVar]
# PGVECTOR_HNSW_EF_CONSTRUCTION=64

# IVFFlat lists parameter. [ConfigVar]
# PGVECTOR_IVFFLAT_LISTS=100

# Use halfvec instead of vector (required for >2000 dims).
# PGVECTOR_USE_HALFVEC=false

# Enables pgcrypto extension for encrypted data at rest.
# PGVECTOR_PGCRYPTO=false

# Encryption key for pgcrypto (required when PGVECTOR_PGCRYPTO is true).
# PGVECTOR_PGCRYPTO_KEY=${OPEN_WEBUI_PGVECTOR_PGCRYPTO_KEY}

# PGVector connection pool settings:
# PGVECTOR_POOL_SIZE=
# PGVECTOR_POOL_MAX_OVERFLOW=0
# PGVECTOR_POOL_TIMEOUT=30
# PGVECTOR_POOL_RECYCLE=3600

# ---------- Qdrant ----------
# QDRANT_API_KEY=${OPEN_WEBUI_QDRANT_API_KEY}
# QDRANT_URI=
# QDRANT_ON_DISK=false
# QDRANT_PREFER_GRPC=false
# QDRANT_GRPC_PORT=6334
# QDRANT_TIMEOUT=5
# QDRANT_HNSW_M=16
# ENABLE_QDRANT_MULTITENANCY_MODE=true
# QDRANT_COLLECTION_PREFIX=open-webui

# ---------- Milvus ----------
# MILVUS_URI=${DATA_DIR}/vector_db/milvus.db
# MILVUS_DB=default
# MILVUS_TOKEN=${OPEN_WEBUI_MILVUS_TOKEN}
# MILVUS_INDEX_TYPE=HNSW
# MILVUS_METRIC_TYPE=COSINE
# ENABLE_MILVUS_MULTITENANCY_MODE=false
# MILVUS_COLLECTION_PREFIX=open_webui

# ---------- Elasticsearch ----------
# ELASTICSEARCH_URL=https://localhost:9200
# ELASTICSEARCH_API_KEY=${OPEN_WEBUI_ELASTICSEARCH_API_KEY}
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=${OPEN_WEBUI_ELASTICSEARCH_PASSWORD}
# ELASTICSEARCH_CLOUD_ID=
# ELASTICSEARCH_CA_CERTS=
# ELASTICSEARCH_INDEX_PREFIX=open_webui_collections

# ---------- OpenSearch ----------
# OPENSEARCH_URI=https://localhost:9200
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=${OPEN_WEBUI_OPENSEARCH_PASSWORD}
# OPENSEARCH_SSL=true
# OPENSEARCH_CERT_VERIFY=false

# ---------- Pinecone ----------
# PINECONE_API_KEY=${OPEN_WEBUI_PINECONE_API_KEY}
# PINECONE_ENVIRONMENT=
# PINECONE_INDEX_NAME=open-webui-index
# PINECONE_DIMENSION=1536

# ---------- Weaviate ----------
# WEAVIATE_HTTP_HOST=
# WEAVIATE_GRPC_HOST=
# WEAVIATE_HTTP_PORT=8080
# WEAVIATE_GRPC_PORT=50051
# WEAVIATE_HTTP_SECURE=false
# WEAVIATE_GRPC_SECURE=false
# WEAVIATE_API_KEY=${OPEN_WEBUI_WEAVIATE_API_KEY}

# ---------- Valkey ----------
# VALKEY_URL=
# VALKEY_COLLECTION_PREFIX=open_webui
# VALKEY_INDEX_TYPE=HNSW

# ---------- MariaDB Vector ----------
# MARIADB_VECTOR_DB_URL=
# MARIADB_VECTOR_INITIALIZE_MAX_VECTOR_LENGTH=1536

# ---------- Oracle 23ai ----------
# ORACLE_DB_USER=DEMOUSER
# ORACLE_DB_PASSWORD=${OPEN_WEBUI_ORACLE_DB_PASSWORD}
# ORACLE_DB_DSN=localhost:1521/FREEPDB1

# ---------- S3 Vector Bucket ----------
# S3_VECTOR_BUCKET_NAME=
# S3_VECTOR_REGION=

# ---------------------------------------------------------------------------- #
#               ------- RAG Content Extraction Engine --------
# ---------------------------------------------------------------------------- #

# Content extraction engine: (empty=default), external, tika, docling,
# document_intelligence, mistral_ocr, datalab_marker, mineru, paddleocr_vl. [ConfigVar]
# CONTENT_EXTRACTION_ENGINE=

# Mistral OCR API key. [ConfigVar]
# MISTRAL_OCR_API_KEY=${OPEN_WEBUI_MISTRAL_OCR_API_KEY}

# Mistral OCR API base URL. [ConfigVar]
# MISTRAL_OCR_API_BASE_URL=https://api.mistral.ai/v1

# External document loader URL. [ConfigVar]
# EXTERNAL_DOCUMENT_LOADER_URL=

# External document loader API key. [ConfigVar]
# EXTERNAL_DOCUMENT_LOADER_API_KEY=${OPEN_WEBUI_EXTERNAL_DOC_LOADER_KEY}

# Apache Tika server URL. [ConfigVar]
# TIKA_SERVER_URL=http://localhost:9998

# Docling server URL (v2.0.0+ required). [ConfigVar]
# DOCLING_SERVER_URL=http://docling:5001

# Docling API key. [ConfigVar]
# DOCLING_API_KEY=${OPEN_WEBUI_DOCLING_API_KEY}

# Docling processing parameters as JSON. [ConfigVar]
# DOCLING_PARAMS={}

# MinerU API timeout in seconds. [ConfigVar]
# MINERU_API_TIMEOUT=300

# File extensions routed to MinerU, comma-separated. [ConfigVar]
# MINERU_FILE_EXTENSIONS=pdf

# PaddleOCR-vl server base URL. [ConfigVar]
# PADDLEOCR_VL_BASE_URL=http://localhost:8080

# PaddleOCR-vl auth token. Required for the engine to activate. [ConfigVar]
# PADDLEOCR_VL_TOKEN=${OPEN_WEBUI_PADDLEOCR_VL_TOKEN}

# ---------------------------------------------------------------------------- #
#               ------- RAG — Core Configuration --------
# ---------------------------------------------------------------------------- #

# Embedding engine: (empty=SentenceTransformers), ollama, openai, azure_openai. [ConfigVar]
# RAG_EMBEDDING_ENGINE=

# Embedding model (default: sentence-transformers/all-MiniLM-L6-v2). [ConfigVar]
# RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Default number of embedding results for RAG. [ConfigVar]
# RAG_TOP_K=3

# Default number of results for reranker. [ConfigVar]
# RAG_TOP_K_RERANKER=3

# Relevance threshold for reranked results. [ConfigVar]
# RAG_RELEVANCE_THRESHOLD=0.0

# Enables hybrid search (BM25 + vector). [ConfigVar]
# ENABLE_RAG_HYBRID_SEARCH=false

# Enables kb_exec tool for filesystem-style knowledge base exploration. [ConfigVar]
# ENABLE_KB_EXEC=false

# BM25 weight during hybrid search (1 = keyword only, 0 = vector only). [ConfigVar]
# RAG_HYBRID_BM25_WEIGHT=0.5

# Enhances BM25 with document metadata (filenames, titles). [ConfigVar]
# ENABLE_RAG_HYBRID_SEARCH_ENRICHED_TEXTS=false

# RAG prompt template. [ConfigVar]
# RAG_TEMPLATE=

# ---------------------------------------------------------------------------- #
#               ------- RAG — Document Processing --------
# ---------------------------------------------------------------------------- #

# Document chunk size for embeddings. [ConfigVar]
# CHUNK_SIZE=1000

# Chunk overlap amount. [ConfigVar]
# CHUNK_OVERLAP=100

# Min chunk size target; smaller chunks are merged when markdown header
# splitter is enabled. [ConfigVar]
# CHUNK_MIN_SIZE_TARGET=0

# Text splitter: character (RecursiveCharacterTextSplitter) or token (Tiktoken). [ConfigVar]
# RAG_TEXT_SPLITTER=character

# Pre-splits by markdown headers before character/token splitting. [ConfigVar]
# ENABLE_MARKDOWN_HEADER_TEXT_SPLITTER=true

# TikToken cache directory.
# TIKTOKEN_CACHE_DIR={CACHE_DIR}/tiktoken

# TikToken encoding name. [ConfigVar]
# TIKTOKEN_ENCODING_NAME=cl100k_base

# Extracts images from PDFs via OCR during loading. [ConfigVar]
# PDF_EXTRACT_IMAGES=false

# PDF loader mode: page (one doc per page), single (all pages combined). [ConfigVar]
# PDF_LOADER_MODE=page

# Max upload file size in MB. [ConfigVar]
# RAG_FILE_MAX_SIZE=

# Max number of files per upload. [ConfigVar]
# RAG_FILE_MAX_COUNT=

# Max width for client-side image compression.
# FILE_IMAGE_COMPRESSION_WIDTH=

# Max height for client-side image compression.
# FILE_IMAGE_COMPRESSION_HEIGHT=

# Allowed file extensions for upload (empty = all supported). [ConfigVar]
# RAG_ALLOWED_FILE_EXTENSIONS=

# ---------------------------------------------------------------------------- #
#               ------- RAG — Embedding Engine Configuration --------
# ---------------------------------------------------------------------------- #

# Batch size for external embedding providers (Ollama, OpenAI, Azure). [ConfigVar]
# RAG_EMBEDDING_BATCH_SIZE=1

# Runs embedding tasks asynchronously for max performance (Ollama/OpenAI/Azure). [ConfigVar]
# ENABLE_ASYNC_EMBEDDING=true

# Max concurrent embedding API requests (0 = unlimited). [ConfigVar]
# RAG_EMBEDDING_CONCURRENT_REQUESTS=0

# Timeout in seconds for embedding operations.
# RAG_EMBEDDING_TIMEOUT=

# Prefix prepended to document content before embedding (e.g., search_document: for nomic).
# RAG_EMBEDDING_CONTENT_PREFIX=

# Prefix prepended to user queries before embedding (e.g., search_query: for nomic).
# RAG_EMBEDDING_QUERY_PREFIX=

# JSON field name for sending prefix as a dedicated API parameter (not inline).
# RAG_EMBEDDING_PREFIX_FIELD_NAME=

# ---------- OpenAI Embeddings ----------
# OpenAI base URL for RAG embeddings (falls back to OPENAI_API_BASE_URL). [ConfigVar]
# RAG_OPENAI_API_BASE_URL=

# OpenAI API key for RAG embeddings (falls back to OPENAI_API_KEY). [ConfigVar]
# RAG_OPENAI_API_KEY=${OPENAI_OPEN_WEBUI_API_KEY}

# OpenAI embedding batch size. [ConfigVar]
# RAG_EMBEDDING_OPENAI_BATCH_SIZE=1

# ---------- Azure OpenAI Embeddings ----------
# RAG_AZURE_OPENAI_BASE_URL= [ConfigVar]
# RAG_AZURE_OPENAI_API_KEY=${OPEN_WEBUI_AZURE_OPENAI_API_KEY} [ConfigVar]
# RAG_AZURE_OPENAI_API_VERSION= [ConfigVar]

# ---------- Ollama Embeddings ----------
# RAG_OLLAMA_BASE_URL= [ConfigVar]
# RAG_OLLAMA_API_KEY=${OPEN_WEBUI_OLLAMA_API_KEY} [ConfigVar]

# ---------------------------------------------------------------------------- #
#               ------- RAG — Reranking --------
# ---------------------------------------------------------------------------- #

# Reranking engine: (empty=local CrossEncoder), external. [ConfigVar]
# RAG_RERANKING_ENGINE=

# Reranking model (local Sentence-Transformer). [ConfigVar]
# RAG_RERANKING_MODEL=

# Batch size for local reranking. [ConfigVar]
# RAG_RERANKING_BATCH_SIZE=32

# Applies sigmoid normalization to local CrossEncoder scores. [ConfigVar]
# SENTENCE_TRANSFORMERS_CROSS_ENCODER_SIGMOID_ACTIVATION_FUNCTION=true

# Timeout for external reranker API requests. [ConfigVar]
# RAG_EXTERNAL_RERANKER_TIMEOUT=

# Full URL for external reranking API (must include endpoint path). [ConfigVar]
# RAG_EXTERNAL_RERANKER_URL=

# API key for external reranking API. [ConfigVar]
# RAG_EXTERNAL_RERANKER_API_KEY=${OPEN_WEBUI_EXTERNAL_RERANKER_API_KEY}

# ---------------------------------------------------------------------------- #
#               ------- RAG — Query Generation --------
# ---------------------------------------------------------------------------- #

# Enables retrieval query generation. [ConfigVar]
# ENABLE_RETRIEVAL_QUERY_GENERATION=true

# Enables request-scoped caching of generated search queries.
# ENABLE_QUERIES_CACHE=false

# Custom prompt template for query generation. [ConfigVar]
# QUERY_GENERATION_PROMPT_TEMPLATE=

# ---------------------------------------------------------------------------- #
#               ------- RAG — Azure Document Intelligence --------
# ---------------------------------------------------------------------------- #

# DOCUMENT_INTELLIGENCE_ENDPOINT= [ConfigVar]
# DOCUMENT_INTELLIGENCE_KEY=${OPEN_WEBUI_DOCUMENT_INTELLIGENCE_KEY} [ConfigVar]
# DOCUMENT_INTELLIGENCE_MODEL= [ConfigVar]

# ---------------------------------------------------------------------------- #
#               ------- RAG — Advanced --------
# ---------------------------------------------------------------------------- #

# Bypasses the embedding and retrieval process. [ConfigVar]
# BYPASS_EMBEDDING_AND_RETRIEVAL=false

# Uses full context for RAG. [ConfigVar]
# RAG_FULL_CONTEXT=false

# Injects RAG context into system message instead of user message
# (better for prompt caching). [ConfigVar]
# RAG_SYSTEM_CONTEXT=false

# Allows web fetches to access private/local IPs (SSRF risk). [ConfigVar]
# ENABLE_RAG_LOCAL_WEB_FETCH=false

# ---------------------------------------------------------------------------- #
#               ------- Google Drive --------
# ---------------------------------------------------------------------------- #

# Enables Google Drive integration. [ConfigVar]
# ENABLE_GOOGLE_DRIVE_INTEGRATION=false

# Google Drive client ID. [ConfigVar]
# GOOGLE_DRIVE_CLIENT_ID=${OPEN_WEBUI_GOOGLE_DRIVE_CLIENT_ID}

# Google Drive API key. [ConfigVar]
# GOOGLE_DRIVE_API_KEY=${OPEN_WEBUI_GOOGLE_DRIVE_API_KEY}

# ---------------------------------------------------------------------------- #
#               ------- OneDrive --------
# ---------------------------------------------------------------------------- #

# Enables OneDrive integration globally. [ConfigVar]
# ENABLE_ONEDRIVE_INTEGRATION=false

# Shows "Personal OneDrive" option. [ConfigVar]
# ENABLE_ONEDRIVE_PERSONAL=true

# Shows "Work/School OneDrive" option. [ConfigVar]
# ENABLE_ONEDRIVE_BUSINESS=true

# Legacy generic client ID (prefer specific vars below).
# ONEDRIVE_CLIENT_ID=

# Personal OneDrive client ID.
# ONEDRIVE_CLIENT_ID_PERSONAL=${OPEN_WEBUI_ONEDRIVE_PERSONAL_CLIENT_ID}

# Business OneDrive client ID.
# ONEDRIVE_CLIENT_ID_BUSINESS=${OPEN_WEBUI_ONEDRIVE_BUSINESS_CLIENT_ID}

# SharePoint root URL (required for work/school integration). [ConfigVar]
# ONEDRIVE_SHAREPOINT_URL=

# Directory (tenant) ID for work/school integration. [ConfigVar]
# ONEDRIVE_SHAREPOINT_TENANT_ID=

# ---------------------------------------------------------------------------- #
#               ------- Web Search --------
# ---------------------------------------------------------------------------- #

# Enables web search. [ConfigVar]
# ENABLE_WEB_SEARCH=false

# Enables LLM-based search query generation (legacy Default Mode only). [ConfigVar]
# ENABLE_SEARCH_QUERY_GENERATION=true

# Routes web fetcher through http_proxy/https_proxy env vars. [ConfigVar]
# WEB_SEARCH_TRUST_ENV=true

# Additional URL filtering rules (comma-separated, ! prefix = block).
# WEB_FETCH_FILTER_LIST=

# Comma-separated domain filter for search results (! = block). [ConfigVar]
# WEB_SEARCH_DOMAIN_FILTER_LIST=

# Max web search results to crawl (also cap for Native Mode search_web). [ConfigVar]
# WEB_SEARCH_RESULT_COUNT=3

# Max concurrent search requests to the engine (0 = unlimited). [ConfigVar]
# WEB_SEARCH_CONCURRENT_REQUESTS=0

# Max chars returned from fetched URLs (empty = no limit). [ConfigVar]
# WEB_FETCH_MAX_CONTENT_LENGTH=

# Concurrent requests for web loader (fetching result pages). [ConfigVar]
# WEB_LOADER_CONCURRENT_REQUESTS=10

# Search engine: searxng, google_pse, brave, brave_llm_context, kagi,
# mojeek, serpstack, serper, serply, searchapi, serpapi, duckduckgo,
# tavily, linkup, jina, bing, exa, perplexity, perplexity_search, sougou,
# ollama_cloud, azure_ai_search, yacy, yandex, youcom. [ConfigVar]
# WEB_SEARCH_ENGINE=searxng

# Bypasses web search embedding and retrieval. [ConfigVar]
# BYPASS_WEB_SEARCH_EMBEDDING_AND_RETRIEVAL=false

# Bypasses web loader — uses only search engine snippets. [ConfigVar]
# BYPASS_WEB_SEARCH_WEB_LOADER=false

# ---------- Provider-specific search keys (set only for your chosen engine) ----------
# SEARXNG_QUERY_URL=http://searxng.local/search?q=<query>
# GOOGLE_PSE_API_KEY=${OPEN_WEBUI_GOOGLE_PSE_API_KEY}
# GOOGLE_PSE_ENGINE_ID=
# BRAVE_SEARCH_API_KEY=${OPEN_WEBUI_BRAVE_SEARCH_API_KEY}
# KAGI_SEARCH_API_KEY=${OPEN_WEBUI_KAGI_SEARCH_API_KEY}
# MOJEEK_SEARCH_API_KEY=${OPEN_WEBUI_MOJEEK_SEARCH_API_KEY}
# SERPSTACK_API_KEY=${OPEN_WEBUI_SERPSTACK_API_KEY}
# SERPER_API_KEY=${OPEN_WEBUI_SERPER_API_KEY}
# SERPLY_API_KEY=${OPEN_WEBUI_SERPLY_API_KEY}
# SEARCHAPI_API_KEY=${OPEN_WEBUI_SEARCHAPI_API_KEY}
# SERPAPI_API_KEY=${OPEN_WEBUI_SERPAPI_API_KEY}
# TAVILY_API_KEY=${OPEN_WEBUI_TAVILY_API_KEY}
# LINKUP_API_KEY=${OPEN_WEBUI_LINKUP_API_KEY}
# JINA_API_KEY=${OPEN_WEBUI_JINA_API_KEY}
# BING_SEARCH_V7_SUBSCRIPTION_KEY=${OPEN_WEBUI_BING_SEARCH_KEY}
# BOCHA_SEARCH_API_KEY=${OPEN_WEBUI_BOCHA_SEARCH_API_KEY}
# EXA_API_KEY=${OPEN_WEBUI_EXA_API_KEY}
# SOUGOU_API_SID=
# SOUGOU_API_SK=${OPEN_WEBUI_SOUGOU_API_SK}
# OLLAMA_CLOUD_WEB_SEARCH_API_KEY=${OPEN_WEBUI_OLLAMA_CLOUD_SEARCH_KEY}
# AZURE_AI_SEARCH_API_KEY=${OPEN_WEBUI_AZURE_AI_SEARCH_KEY}
# AZURE_AI_SEARCH_ENDPOINT=
# AZURE_AI_SEARCH_INDEX_NAME=
# YACY_QUERY_URL=
# YACY_USERNAME=
# YACY_PASSWORD=${OPEN_WEBUI_YACY_PASSWORD}
# YANDEX_WEB_SEARCH_API_KEY=${OPEN_WEBUI_YANDEX_SEARCH_API_KEY}
# PERPLEXITY_API_KEY=${OPEN_WEBUI_PERPLEXITY_API_KEY}
# YOUCOM_API_KEY=${OPEN_WEBUI_YOUCOM_API_KEY}

# ---------------------------------------------------------------------------- #
#               ------- Web Loader Configuration --------
# ---------------------------------------------------------------------------- #

# Web loader engine: (empty=safe_web), playwright, firecrawl, tavily, external. [ConfigVar]
# WEB_LOADER_ENGINE=

# Playwright WebSocket URI for remote browser (keeps container lightweight). [ConfigVar]
# PLAYWRIGHT_WS_URL=

# Firecrawl API base URL. [ConfigVar]
# FIRECRAWL_API_BASE_URL=https://api.firecrawl.dev

# Firecrawl API key. [ConfigVar]
# FIRECRAWL_API_KEY=${OPEN_WEBUI_FIRECRAWL_API_KEY}

# Firecrawl timeout in milliseconds. [ConfigVar]
# FIRECRAWL_TIMEOUT=

# Playwright timeout. [ConfigVar]
# PLAYWRIGHT_TIMEOUT=

# SafeWebBaseLoader request timeout in seconds. [ConfigVar]
# WEB_LOADER_TIMEOUT=

# ---------------------------------------------------------------------------- #
#               ------- YouTube Loader --------
# ---------------------------------------------------------------------------- #

# Proxy URL for YouTube loader. [ConfigVar]
# YOUTUBE_LOADER_PROXY_URL=

# Comma-separated language codes for YouTube transcription, in priority order.
# YOUTUBE_LOADER_LANGUAGE=en

# ---------------------------------------------------------------------------- #
#               ------- Audio — Whisper STT (Local) --------
# ---------------------------------------------------------------------------- #

# Whisper model: tiny, base, small, medium, large. [ConfigVar]
# WHISPER_MODEL=base

# Directory for Whisper model files.
# WHISPER_MODEL_DIR=${DATA_DIR}/cache/whisper/models

# Compute type: int8 (CPU), float16 (CUDA).
# WHISPER_COMPUTE_TYPE=

# Enables Voice Activity Detection filter.
# WHISPER_VAD_FILTER=false

# Auto-update Whisper model.
# WHISPER_MODEL_AUTO_UPDATE=false

# ISO 639-1 language code (empty = auto-detect).
# WHISPER_LANGUAGE=

# Use multilingual model (false = English-only for better performance).
# WHISPER_MULTILINGUAL=false

# ---------------------------------------------------------------------------- #
#               ------- Audio — Speech-to-Text Engines --------
# ---------------------------------------------------------------------------- #

# STT engine: (empty=local Whisper), openai, deepgram, azure, mistral. [ConfigVar]
# AUDIO_STT_ENGINE=

# STT model for OpenAI-compatible endpoints. [ConfigVar]
# AUDIO_STT_MODEL=whisper-1

# OpenAI-compatible base URL for STT (falls back to OPENAI_API_BASE_URL). [ConfigVar]
# AUDIO_STT_OPENAI_API_BASE_URL=

# OpenAI API key for STT (falls back to OPENAI_API_KEY). [ConfigVar]
# AUDIO_STT_OPENAI_API_KEY=${OPENAI_OPEN_WEBUI_API_KEY}

# Azure STT API key. [ConfigVar]
# AUDIO_STT_AZURE_API_KEY=${OPEN_WEBUI_AZURE_STT_API_KEY}

# Azure STT region. [ConfigVar]
# AUDIO_STT_AZURE_REGION=

# Deepgram API key. [ConfigVar]
# DEEPGRAM_API_KEY=${OPEN_WEBUI_DEEPGRAM_API_KEY}

# Mistral STT API key. [ConfigVar]
# AUDIO_STT_MISTRAL_API_KEY=${OPEN_WEBUI_MISTRAL_API_KEY}

# Mistral STT API base URL. [ConfigVar]
# AUDIO_STT_MISTRAL_API_BASE_URL=https://api.mistral.ai/v1

# Comma-separated supported MIME types for STT.
# AUDIO_STT_SUPPORTED_CONTENT_TYPES=

# Comma-separated allowed audio file extensions.
# AUDIO_STT_ALLOWED_EXTENSIONS=mp3,wav,m4a,webm,ogg,flac,mp4,mpga,mpeg

# Skips pydub audio preprocessing (format conversion, compression).
# BYPASS_PYDUB_PREPROCESSING=false

# ---------------------------------------------------------------------------- #
#               ------- Audio — Text-to-Speech --------
# ---------------------------------------------------------------------------- #

# TTS engine: (empty=disabled, browser-only), openai, mistral, elevenlabs,
# azure, transformers. [ConfigVar]
# AUDIO_TTS_ENGINE=

# TTS API key. [ConfigVar]
# AUDIO_TTS_API_KEY=${OPEN_WEBUI_TTS_API_KEY}

# OpenAI TTS model (e.g., tts-1, tts-1-hd). [ConfigVar]
# AUDIO_TTS_MODEL=tts-1

# OpenAI TTS voice: alloy, echo, fable, onyx, nova, shimmer. [ConfigVar]
# AUDIO_TTS_VOICE=alloy

# OpenAI TTS split-on strategy. [ConfigVar]
# AUDIO_TTS_SPLIT_ON=punctuation

# OpenAI-compatible base URL for TTS (falls back to OPENAI_API_BASE_URL). [ConfigVar]
# AUDIO_TTS_OPENAI_API_BASE_URL=

# OpenAI API key for TTS (falls back to OPENAI_API_KEY). [ConfigVar]
# AUDIO_TTS_OPENAI_API_KEY=${OPENAI_OPEN_WEBUI_API_KEY}

# Additional OpenAI TTS params as JSON. [ConfigVar]
# AUDIO_TTS_OPENAI_PARAMS={}

# Azure TTS region. [ConfigVar]
# AUDIO_TTS_AZURE_SPEECH_REGION=

# Azure TTS output format. [ConfigVar]
# AUDIO_TTS_AZURE_SPEECH_OUTPUT_FORMAT=audio-24khz-160kbitrate-mono-mp3

# Azure TTS custom base URL. [ConfigVar]
# AUDIO_TTS_AZURE_SPEECH_BASE_URL=

# Mistral TTS API key. [ConfigVar]
# AUDIO_TTS_MISTRAL_API_KEY=${OPEN_WEBUI_MISTRAL_API_KEY}

# Mistral TTS API base URL. [ConfigVar]
# AUDIO_TTS_MISTRAL_API_BASE_URL=https://api.mistral.ai/v1

# ElevenLabs API base URL. [ConfigVar]
# ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io

# ---------------------------------------------------------------------------- #
#               ------- Voice Mode --------
# ---------------------------------------------------------------------------- #

# Master switch for voice-mode system prompt. [ConfigVar]
# ENABLE_VOICE_MODE_PROMPT=true

# Custom system prompt for voice mode. [ConfigVar]
# VOICE_MODE_PROMPT_TEMPLATE=

# ---------------------------------------------------------------------------- #
#               ------- Image Generation — General --------
# ---------------------------------------------------------------------------- #

# Enables image generation features. [ConfigVar]
# ENABLE_IMAGE_GENERATION=false

# Enables automatic prompt enhancement. [ConfigVar]
# ENABLE_IMAGE_PROMPT_GENERATION=true

# Custom prompt template for image generation prompts. [ConfigVar]
# IMAGE_PROMPT_GENERATION_PROMPT_TEMPLATE=

# ---------------------------------------------------------------------------- #
#               ------- Image Generation — Image Creation --------
# ---------------------------------------------------------------------------- #

# Image generation engine: openai, comfyui, automatic1111, gemini. [ConfigVar]
# IMAGE_GENERATION_ENGINE=openai

# Default image generation model (e.g., dall-e-3, gemini-2.0-flash-exp). [ConfigVar]
# IMAGE_GENERATION_MODEL=

# Default output dimensions: WIDTHxHEIGHT or auto. [ConfigVar]
# IMAGE_SIZE=512x512

# Default iteration steps (used by ComfyUI and AUTOMATIC1111). [ConfigVar]
# IMAGE_STEPS=50

# ---------------------------------------------------------------------------- #
#               ------- Image Generation — Image Editing --------
# ---------------------------------------------------------------------------- #

# Enables image editing. [ConfigVar]
# ENABLE_IMAGE_EDIT=true

# Image editing engine: openai, gemini, comfyui. [ConfigVar]
# IMAGE_EDIT_ENGINE=openai

# Image editing model. [ConfigVar]
# IMAGE_EDIT_MODEL=

# Output dimensions for edited images: WIDTHxHEIGHT. [ConfigVar]
# IMAGE_EDIT_SIZE=

