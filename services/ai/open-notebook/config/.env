# ---------------------------------------------------------------------------- #
#               ------- Open Notebook Configuration File --------
# ---------------------------------------------------------------------------- #

# This encrypts your API keys in the database
OPEN_NOTEBOOK_ENCRYPTION_KEY=${OPEN_NOTEBOOK_ENCRYPTION_KEY}

# ---------------------------------------------------------------------------- #
#               ------- SurrealDB --------
# ---------------------------------------------------------------------------- #
SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_USER=${OPEN_NOTEBOOK_SURREAL_USERNAME}
SURREAL_PASSWORD=${OPEN_NOTEBOOK_SURREAL_PASSWORD}
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook
