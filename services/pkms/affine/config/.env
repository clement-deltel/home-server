# ---------------------------------------------------------------------------- #
#               ------- Affine Configuration File --------
# ---------------------------------------------------------------------------- #

AFFINE_CONFIG_PATH=/root/.affine/config

# ---------------------------------------------------------------------------- #
#               ------- Administration User --------
# ---------------------------------------------------------------------------- #

AFFINE_ADMIN_EMAIL=${USER_EMAIL}
AFFINE_ADMIN_PASSWORD=${AFFINE_ADMIN_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #

DATABASE_URL=postgres://${AFFINE_DB_USER}:${AFFINE_DB_PASSWORD}@db:5432/postgres

# ---------------------------------------------------------------------------- #
#               ------- Cache --------
# ---------------------------------------------------------------------------- #

REDIS_SERVER_HOST=cache

# ---------------------------------------------------------------------------- #
#               ------- NodeJS --------
# ---------------------------------------------------------------------------- #

NODE_ENV=production
NODE_OPTIONS="--import=./scripts/register.js"

# ---------------------------------------------------------------------------- #
#               ------- Telemetry --------
# ---------------------------------------------------------------------------- #
# Telemetry allows us to collect data on how you use the affine. This data will
# helps us improve the app and provide better features.
TELEMETRY_ENABLE=false
