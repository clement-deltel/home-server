# ---------------------------------------------------------------------------- #
#               ------- LibreTranslate Configuration File ------
# ---------------------------------------------------------------------------- #
# https://docs.libretranslate.com/guides/installation/#arguments
#
# Environment variables mirror the CLI arguments: upper_snake_case with LT_ prefix.
# E.g. --char-limit → LT_CHAR_LIMIT, --api-keys → LT_API_KEYS.
# Env vars override defaults but have lower priority than CLI arguments.

# ---------------------------------------------------------------------------- #
#               ------- Server ------
# ---------------------------------------------------------------------------- #

# Host to bind the server to.
LT_HOST=0.0.0.0

# Port to bind the server to.
LT_PORT=5000

# Whether to enable SSL (Disabled if omitted).
# LT_SSL=

# Add prefix to URL (e.g., LT_URL_PREFIX=/translate → example.com:5000/translate/).
# LT_URL_PREFIX=

# Enable debug environment (Disabled if omitted).
# LT_DEBUG=

# Set number of threads.
LT_THREADS=4

# Mark this instance as a secondary instance to avoid conflicts with the primary
# node in multi-node setups.
# LT_SECONDARY=

# ---------------------------------------------------------------------------- #
#               ------- Security & API Keys ------
# ---------------------------------------------------------------------------- #

# Enable API keys database for per-client rate limits when request limit is reached.
# To always require an API key: set LT_REQ_LIMIT=0 and LT_API_KEYS=True.
LT_API_KEYS=True

# Require an API key for programmatic access, unless the request origin matches
# this domain.
# LT_REQUIRE_API_KEY_ORIGIN=

# Require an API key for programmatic access, unless the client also sends a
# secret matching this value.
# Secret — generate a strong random value.
# LT_REQUIRE_API_KEY_SECRET=${LT_REQUIRE_API_KEY_SECRET}

# Require an API key for programmatic access, unless the client also matches a
# fingerprint.
# LT_REQUIRE_API_KEY_FINGERPRINT=

# Enable under attack mode. When enabled, requests must be made with an API key.
# LT_UNDER_ATTACK=

# ---------------------------------------------------------------------------- #
#               ------- Rate Limiting ------
# ---------------------------------------------------------------------------- #

# Maximum number of requests per minute per client (outside of API key limits).
# No limit if not set.
# LT_REQ_LIMIT=

# Storage URI for request limit data storage. See Flask Limiter.
LT_REQ_LIMIT_STORAGE=memory://

# Time cost (in seconds) for request limiting purposes.
# If a request takes 10s and this is 5, the request cost is 2.
# LT_REQ_TIME_COST=

# Character limit per translation request. No limit if not set.
# LT_CHAR_LIMIT=

# Maximum number of texts to translate in a single batch request. No limit if not set.
# LT_BATCH_LIMIT=

# ---------------------------------------------------------------------------- #
#               ------- Translation ------
# ---------------------------------------------------------------------------- #

# Comma-separated list of language codes to load (others will be unavailable).
# Leave empty or omit to load all languages.
LT_LOAD_ONLY=en,es,fr,ja,ko

# Cache translation output for users with a particular API key, or use 'all'
# to cache all translations (Disabled by default).
# LT_TRANSLATION_CACHE=

# Disable file translation (enabled by default — set True to disable).
# LT_DISABLE_FILES_TRANSLATION=

# Allow user suggestions for translations (Disabled if omitted).
# LT_SUGGESTIONS=

# ---------------------------------------------------------------------------- #
#               ------- Frontend ------
# ---------------------------------------------------------------------------- #

# Frontend default source language.
LT_FRONTEND_LANGUAGE_SOURCE=auto

# Frontend default target language.
LT_FRONTEND_LANGUAGE_TARGET=locale

# Set frontend translation timeout (in seconds).
LT_FRONTEND_TIMEOUT=500

# Custom title displayed in the web UI.
# LT_FRONTEND_TITLE=

# Disable the web UI entirely (enabled by default — set True to disable).
# LT_DISABLE_WEB_UI=

# Show a link in the UI where users can get an API key.
# LT_GET_API_KEY_LINK=

# ---------------------------------------------------------------------------- #
#               ------- Storage & Database ------
# ---------------------------------------------------------------------------- #

# Path for the API keys database. Absolute or relative to the container.
LT_API_KEYS_DB_PATH=/app/db/api_keys.db

# Remote endpoint to query for valid API keys instead of using the local database.
# LT_API_KEYS_REMOTE=

# Shared storage URI for multi-process data sharing (e.g., when using Gunicorn).
LT_SHARED_STORAGE=memory://

# ---------------------------------------------------------------------------- #
#               ------- Monitoring ------
# ---------------------------------------------------------------------------- #

# Enable Prometheus /metrics endpoint for usage metrics.
# LT_METRICS=

# Authorization Bearer token required to access /metrics.
# Secret — generate with: openssl rand -hex 32
# LT_METRICS_AUTH_TOKEN=${LT_METRICS_AUTH_TOKEN}

# ---------------------------------------------------------------------------- #
#               ------- Maintenance ------
# ---------------------------------------------------------------------------- #

# Update language models at startup (Disabled if omitted).
# LT_UPDATE_MODELS=

# ---------------------------------------------------------------------------- #
#               ------- Sentence Boundary Detection ------
# ---------------------------------------------------------------------------- #

# Use MINISBD for faster sentence boundary detection. Leave unset to use default.
# ARGOS_CHUNK_TYPE=MINISBD
#
