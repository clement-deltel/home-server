# ---------------------------------------------------------------------------- #
#               ------- Yamtrack Configuration File ------
# ---------------------------------------------------------------------------- #
# https://fuzzygrim.github.io/Yamtrack/release/env-variables/
#
# Flat env vars (no prefix). Sorted by documentation section order.
# Secrets use ${YAMTRACK_*} placeholders — never hardcoded values.
# Docker secrets via _FILE suffix are supported for marked variables.

# ---------------------------------------------------------------------------- #
#               ------- Media Sources ------
# ---------------------------------------------------------------------------- #

# The Movie Database API key for movies and TV shows. A default key is provided.
# TMDB_API=${THEMOVIEDB_API_KEY}

# Include adult content in TMDB searches. [True, False]
TMDB_NSFW=False

# TMDB metadata language in ISO 639-1 (e.g., 'en', 'en-US').
# TMDB_LANG=

# MyAnimeList API key for anime and manga. A default key is provided.
# MAL_API=${MYANIMELIST_API_KEY}

# Include adult content in MyAnimeList anime/manga searches. [True, False]
MAL_NSFW=False

# Include adult content in MangaUpdates manga searches. [True, False]
MU_NSFW=False

# IGDB API key for games. A default key is provided, but it has a low rate limit
# — getting your own is recommended.
IGDB_ID=${IGDB_CLIENT_ID}

# IGDB API secret for games. A default value is provided.
IGDB_SECRET=${IGDB_CLIENT_SECRET}

# Include adult content in IGDB game searches. [True, False]
IGDB_NSFW=False

# Hardcover API key for books. A default key is provided (low rate limit).
# Custom values must include the 'Bearer' prefix.
# HARDCOVER_API=${HARDCOVER_API_KEY}

# ComicVine API key for comics. A default key is provided (low rate limit).
# COMICVINE_API=${COMICVINE_API_KEY}

# ---------------------------------------------------------------------------- #
#               ------- Redis & Django Settings ------
# ---------------------------------------------------------------------------- #

# Redis server URL. Format: redis://[user:password@]host:port.
REDIS_URL=redis://:${YAMTRACK_CACHE_PASSWORD}@cache:6379

# Redis URL for Celery. Defaults to REDIS_URL if not set.
# CELERY_REDIS_URL=

# Optional prefix for Redis keys/channels to isolate apps sharing a Redis instance.
# REDIS_PREFIX=

# Secret key for cryptographic signing.
# Generate with: openssl rand -hex 32
SECRET=${YAMTRACK_SECRET}

# Shortcut to set both CSRF and ALLOWED_HOSTS. Comma-separated URLs
# (e.g., https://yamtrack.example.com).
URLS=https://${YAMTRACK_HOST}

# Comma-separated host/domain names this site can serve. Defaults to *.
# ALLOWED_HOSTS=

# Comma-separated trusted origins for POST requests when using reverse proxies
# (e.g., https://yamtrack.example.com).
# CSRF=

# Enable user registration. [True, False]
REGISTRATION=True

# Enable Django debug mode. [True, False]
DEBUG=False

# Enable the Django admin interface. [True, False]
ADMIN_ENABLED=False

# Enable time tracking. [True, False]
TRACK_TIME=True

# ---------------------------------------------------------------------------- #
#               ------- User & System ------
# ---------------------------------------------------------------------------- #

# User ID for the app process.
PUID=${USER_UID}

# Group ID for the app process.
PGID=${USER_GID}

# Timezone (e.g., Europe/Berlin). Defaults to UTC.
TZ=${TIMEZONE}

# Number of web server worker processes.
# WEB_CONCURRENCY=1

# Comma-separated social auth providers to enable
# (e.g., allauth.socialaccount.providers.openid_connect).
# SOCIAL_PROVIDERS=

# JSON configuration for social providers. See docs for OIDC example.
# Also supports _FILE suffix via Docker secrets.
# SOCIALACCOUNT_PROVIDERS=${YAMTRACK_SOCIALACCOUNT_PROVIDERS}

# Protocol for social auth redirect URIs. [https, http]
# Set to https if your OIDC redirect_uri uses https.
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=

# Absolute URL to redirect users after logout (useful for OIDC full logout).
# ACCOUNT_LOGOUT_REDIRECT_URL=

# Disable local authentication — social auth only. [True, False]
# SOCIALACCOUNT_ONLY=False

# Auto-redirect to SSO provider when only one is available. [True, False]
# REDIRECT_LOGIN_TO_SSO=False

# Username to auto-login with (user must exist and be active).
# YAMTRACK_AUTO_LOGIN_USERNAME=

# ---------------------------------------------------------------------------- #
#               ------- Celery Health Check ------
# ---------------------------------------------------------------------------- #

# Timeout in seconds for the health check ping to Celery.
# HEALTHCHECK_CELERY_PING_TIMEOUT=1

# ---------------------------------------------------------------------------- #
#               ------- PostgreSQL ------
# ---------------------------------------------------------------------------- #

# PostgreSQL hostname or IP. If not set, SQLite is used.
DB_HOST=db

# PostgreSQL port.
DB_PORT=5432

# Database name.
DB_NAME=postgres

# Database user.
DB_USER=${YAMTRACK_DB_USERNAME}

# Database password.
DB_PASSWORD=${YAMTRACK_DB_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- PostgreSQL SSL ------
# ---------------------------------------------------------------------------- #

# SSL mode for PostgreSQL connections. See PostgreSQL docs for values.
# DB_SSL_MODE=

# Client certificate mode for PostgreSQL. See PostgreSQL docs for values.
# DB_SSL_CERT_MODE=

# ---------------------------------------------------------------------------- #
#               ------- Host Under Subpath ------
# ---------------------------------------------------------------------------- #

# Host Yamtrack under a subpath (e.g., /yamtrack). No trailing slash.
# BASE_URL=

# ---------------------------------------------------------------------------- #
#               ------- Self-Signed Certificates ------
# ---------------------------------------------------------------------------- #

# Path to a custom CA certificate bundle for SSL verification
# (e.g., /etc/ssl/certs/ca-certificates.crt).
# REQUESTS_CA_BUNDLE=

# ---------------------------------------------------------------------------- #
#               ------- Docker Secrets (_FILE equivalents) ------
# ---------------------------------------------------------------------------- #
# The following variables also support _FILE suffix for Docker secrets:
# SECRET_FILE, DB_NAME_FILE, DB_USER_FILE, DB_PASSWORD_FILE,
# TMDB_API_FILE, MAL_API_FILE, IGDB_ID_FILE, IGDB_SECRET_FILE,
# HARDCOVER_API_FILE, COMICVINE_API_FILE, TRAKT_API_FILE,
# SIMKL_ID_FILE, SIMKL_SECRET_FILE, SOCIALACCOUNT_PROVIDERS_FILE
