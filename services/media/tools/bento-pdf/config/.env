# ---------------------------------------------------------------------------- #
#               ------- BentoPDF Configuration File ------
# ---------------------------------------------------------------------------- #
# https://www.bentopdf.com/docs/self-hosting/docker#environment-variables

# ---------------------------------------------------------------------------- #
#               ------- Build Mode ------
# ---------------------------------------------------------------------------- #
# Build the Self-Hosted variant, which hides bentopdf.com marketing
# chrome (hero section, FAQ, testimonials, footer). All PDF tools remain fully
# functional. Use true for internal/team deployments.
# Note: bentopdf-simple:latest already has this baked in as true.
# SIMPLE_MODE=true

# Deploy to a subdirectory instead of the root path.
# Example: /tools would serve the app at https://example.com/tools
# BASE_URL=/

# ---------------------------------------------------------------------------- #
#               ------- WASM Module URLs ------
# ---------------------------------------------------------------------------- #
# These URLs point to the WebAssembly modules downloaded by the
# user's browser at runtime. The Docker build does NOT download them — the
# browser does. Override for air-gapped or self-hosted WASM deployments.
# See: https://www.bentopdf.com/docs/self-hosting/docker#custom-wasm-urls-air-gapped-self-hosted
#
# The CSP (Content-Security-Policy) header is generated at build time from
# these URLs. Overriding them at runtime via in-app Advanced Settings bypasses
# the CSP and will be blocked by the browser.

# PyMuPDF WASM module URL
# VITE_WASM_PYMUPDF_URL=https://cdn.jsdelivr.net/npm/@bentopdf/pymupdf-wasm@0.11.16/

# Ghostscript WASM module URL
# VITE_WASM_GS_URL=https://cdn.jsdelivr.net/npm/@bentopdf/gs-wasm@0.1.1/assets/

# CoherentPDF WASM module URL
# VITE_WASM_CPDF_URL=https://cdn.jsdelivr.net/npm/coherentpdf@2.5.5/dist/

# ---------------------------------------------------------------------------- #
#               ------- OCR (Tesseract) ------
# ---------------------------------------------------------------------------- #
# URLs for the Tesseract.js OCR engine components.
# Leave all three empty to use the default Tesseract.js CDN (recommended for
# internet-connected deployments). For offline/air-gapped OCR, all three MUST
# be set together — partial overrides are rejected because the worker, core
# runtime, and traineddata must match.

# OCR worker script URL
# (empty = use Tesseract.js default CDN)
# VITE_TESSERACT_WORKER_URL=

# OCR core runtime directory
# (empty = use Tesseract.js default CDN)
# VITE_TESSERACT_CORE_URL=

# OCR traineddata directory
# (empty = use Tesseract.js default CDN)
# VITE_TESSERACT_LANG_URL=

# Comma-separated OCR languages exposed in UI
# (empty = show full catalog)
# VITE_TESSERACT_AVAILABLE_LANGUAGES=

# OCR text-layer font directory
# (empty = use remote Noto font URLs)
# VITE_OCR_FONT_BASE_URL=

# ---------------------------------------------------------------------------- #
#               ------- UI & Branding ------
# ---------------------------------------------------------------------------- #
# Default UI language
# VITE_DEFAULT_LANGUAGE=en

# Custom brand name
# VITE_BRAND_NAME=BentoPDF

# Logo path relative to public/
# VITE_BRAND_LOGO=images/favicon-no-bg.svg

# Custom footer / copyright text
# VITE_FOOTER_TEXT=© 2026 BentoPDF. All rights reserved.

# ---------------------------------------------------------------------------- #
#               ------- Tool Visibility ------
# ---------------------------------------------------------------------------- #
# Comma-separated list of tool IDs to hide from the UI. Disabled tools are
# removed from the homepage, search results, keyboard shortcuts, and the
# workflow builder. Direct URL access shows a "tool unavailable" page.
#
# Tool ID = page URL without .html (e.g., edit-pdf, sign-pdf, encrypt-pdf).
#
# Full list of tool IDs by category:
#
# Edit & Annotate:
#   edit-pdf, bookmark, table-of-contents, page-numbers, add-page-labels,
#   bates-numbering, add-watermark, header-footer, invert-colors, scanner-effect,
#   adjust-colors, background-color, text-color, sign-pdf, add-stamps,
#   remove-annotations, crop-pdf, form-filler, form-creator, remove-blank-pages
#
# Convert to PDF:
#   image-to-pdf, jpg-to-pdf, png-to-pdf, webp-to-pdf, svg-to-pdf, bmp-to-pdf,
#   heic-to-pdf, tiff-to-pdf, txt-to-pdf, markdown-to-pdf, json-to-pdf,
#   csv-to-pdf, rtf-to-pdf, odt-to-pdf, word-to-pdf, excel-to-pdf,
#   powerpoint-to-pdf, xps-to-pdf, mobi-to-pdf, epub-to-pdf, fb2-to-pdf,
#   cbz-to-pdf, wpd-to-pdf, wps-to-pdf, xml-to-pdf, pages-to-pdf, odg-to-pdf,
#   ods-to-pdf, odp-to-pdf, pub-to-pdf, vsd-to-pdf, psd-to-pdf, email-to-pdf
#
# Convert from PDF:
#   pdf-to-jpg, pdf-to-png, pdf-to-webp, pdf-to-bmp, pdf-to-tiff, pdf-to-cbz,
#   pdf-to-svg, pdf-to-csv, pdf-to-excel, pdf-to-greyscale, pdf-to-json,
#   pdf-to-docx, extract-images, pdf-to-markdown, prepare-pdf-for-ai, pdf-to-text
#
# Organize & Manage:
#   ocr-pdf, merge-pdf, alternate-merge, organize-pdf, add-attachments,
#   extract-attachments, edit-attachments, pdf-multi-tool, pdf-layers,
#   extract-tables, split-pdf, divide-pages, extract-pages, delete-pages,
#   add-blank-page, reverse-pages, rotate-pdf, rotate-custom, n-up-pdf,
#   pdf-booklet, combine-single-page, view-metadata, edit-metadata, pdf-to-zip,
#   compare-pdfs, posterize-pdf, page-dimensions
#
# Optimize & Repair:
#   compress-pdf, pdf-to-pdfa, fix-page-size, linearize-pdf, remove-restrictions,
#   repair-pdf, rasterize-pdf, deskew-pdf, font-to-outline
#
# Security:
#   encrypt-pdf, sanitize-pdf, decrypt-pdf, flatten-pdf, remove-metadata,
#   change-permissions, digital-sign-pdf, validate-signature-pdf, timestamp-pdf
#
# (empty = all tools enabled)
# DISABLE_TOOLS=

# ---------------------------------------------------------------------------- #
#               ------- Runtime: Web Server ------
# ---------------------------------------------------------------------------- #
# Port that nginx listens on inside the container.
# Map this to your desired host port in docker-compose.yml (e.g., "3000:8080").
# Behind Traefik, keep this at 8080 and let Traefik handle external port mapping.
PORT=8080

# ---------------------------------------------------------------------------- #
#               ------- Runtime: User / Permissions (Dockerfile.nonroot only) ------
# ---------------------------------------------------------------------------- #
# The following three variables only apply when using the non-root
# image built from Dockerfile.nonroot. They have no effect on the standard
# bentopdf-simple:latest image (which uses nginx-unprivileged at UID 101).
# Use Dockerfile.nonroot only when you need to run as a specific UID/GID
# (e.g., NAS devices, Kubernetes with security contexts).
# WARNING: PUID and PGID cannot be 0 (root).

# PUID=1000
# PGID=1000

# Disable the IPv6 listener in nginx. Set to true if your host has no IPv6 support.
# DISABLE_IPV6=false
