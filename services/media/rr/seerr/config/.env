# ---------------------------------------------------------------------------- #
#               ------- Seerr Configuration ------
# ---------------------------------------------------------------------------- #
# https://docs.seerr.dev/category/settings

LOG_LEVEL=info
TZ=${TIMEZONE}
PORT=5055 #optional

# ---------------------------------------------------------------------------- #
#               ------- Database ------
# ---------------------------------------------------------------------------- #

# Which DB engine to use, either sqlite or postgres. The default is sqlite.
DB_TYPE=postgres
# (optional) The host (URL) of the database. The default is "localhost".
DB_HOST=db
# (optional) The port to connect to. The default is "5432".
DB_PORT=5432
# (required) Username used to connect to the database.
DB_USER=${SEERR_DB_USERNAME}
# (required) Password of the user used to connect to the database.
DB_PASS=${SEERR_DB_PASSWORD}
# (optional) The name of the database to connect to. The default is "seerr".
DB_NAME=postgres
# (optional) The number of connections to maintain in the connection pool. The default is "10".
DB_POOL_SIZE=10
# (optional) Whether to log the DB queries for debugging. The default is "false".
DB_LOG_QUERIES=false
