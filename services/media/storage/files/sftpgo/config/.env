# ---------------------------------------------------------------------------- #
#               ------- SFTPGo Configuration File ------
# ---------------------------------------------------------------------------- #
# https://docs.sftpgo.com/latest/config-file/
# https://docs.sftpgo.com/latest/env-vars/

# ---------------------------------------------------------------------------- #
#               ------- First-Run Admin Bootstrap ------
# ---------------------------------------------------------------------------- #
# Used to automatically create the first admin account when
# data_provider.create_default_admin is set to true (see Data Provider section).
# Remove or comment out after first start.
SFTPGO_DEFAULT_ADMIN_USERNAME=${SFTPGO_ADMIN_USER}
SFTPGO_DEFAULT_ADMIN_PASSWORD=${SFTPGO_ADMIN_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Common ------
# ---------------------------------------------------------------------------- #
# Time in minutes after which an idle client will be disconnected. 0 means disabled.
SFTPGO_COMMON__IDLE_TIMEOUT=15

# Upload mode: 0=standard (direct), 1=atomic (temp file + rename on finish),
# 2=atomic with resume support. Atomic avoids partial files being served mid-upload.
SFTPGO_COMMON__UPLOAD_MODE=1

# Mode for setstat requests (chmod, chown, timestamps).
# 0=execute all, 1=silently ignore all, 2=ignore only for cloud backends.
SFTPGO_COMMON__SETSTAT_MODE=0

# Allow recursive renames for cloud storage providers (S3, GCS, Azure).
# 0=disabled (default), 1=enabled (can be slow, no atomic API).
SFTPGO_COMMON__RENAME_MODE=0

# Maximum size in bytes allowed for resuming uploads on immutable object backends.
# 0 means resume is not allowed for cloud backends (default).
SFTPGO_COMMON__RESUME_MAX_SIZE=0

# Path for temporary files (atomic uploads, pipes). Leave empty for system default.
# Must be on the same filesystem as user home dirs to avoid slow cross-device copies.
SFTPGO_COMMON__TEMP_PATH=

# HAProxy PROXY protocol support. 0=disabled, 1=enabled (header optional per IP),
# 2=required (connection rejected if IP not in proxy_allowed and header found).
# Set to 1 if Traefik is configured to send PROXY protocol headers.
SFTPGO_COMMON__PROXY_PROTOCOL=0

# Comma-separated list of IPs/CIDRs allowed to send the PROXY protocol header.
# e.g. 172.20.0.0/16 for your Docker network containing Traefik.
SFTPGO_COMMON__PROXY_ALLOWED=

# Comma-separated list of IPs/CIDRs for which NOT to read the proxy header at all.
SFTPGO_COMMON__PROXY_SKIPPED=

# Absolute path or HTTP URL to invoke at SFTPGo startup. Leave empty to disable.
SFTPGO_COMMON__STARTUP_HOOK=

# Absolute path or HTTP URL to invoke after each client connection. Leave empty to disable.
SFTPGO_COMMON__POST_CONNECT_HOOK=

# Absolute path or HTTP URL to invoke after each client disconnection. Leave empty to disable.
SFTPGO_COMMON__POST_DISCONNECT_HOOK=

# Maximum number of concurrent client connections across all protocols. 0=unlimited.
SFTPGO_COMMON__MAX_TOTAL_CONNECTIONS=0

# Maximum number of concurrent connections from the same IP. 0=unlimited.
# Exceeding this generates defender score_limit_exceeded events.
SFTPGO_COMMON__MAX_PER_HOST_CONNECTIONS=20

# Set to 1 to enable the allow-list (only listed IPs/networks can connect).
# Populate the list via WebAdmin or REST API BEFORE enabling this.
SFTPGO_COMMON__ALLOWLIST_STATUS=0

# Set to 1 to allow users on this instance to use other local users/folders as
# storage backends. Enable only if you know what you are doing.
SFTPGO_COMMON__ALLOW_SELF_CONNECTIONS=0

# File mode creation mask (e.g. 002). Leave blank to use the system umask (*NIX only).
SFTPGO_COMMON__UMASK=

# Set to 'short' to hide the SFTPGo version number in the advertised server version.
SFTPGO_COMMON__SERVER_VERSION=

# Time zone for EventManager scheduler and time-based access restrictions.
# 'local' = server local time. Leave blank for UTC.
SFTPGO_COMMON__TZ=

# ---------------------------------------------------------------------------- #
#               ------- Common - Actions (Hooks) ------
# ---------------------------------------------------------------------------- #
# Comma-separated list of filesystem events that trigger the hook.
# Valid values: pre-download, download, first-download, pre-upload, upload,
# first-upload, pre-delete, delete, rename, mkdir, rmdir, ssh_cmd, copy.
# Leave empty to disable.
SFTPGO_COMMON__ACTIONS__EXECUTE_ON=

# Actions from the execute_on list to run synchronously (SFTPGo waits for them).
# pre-* actions are always synchronous. Leave empty for default behaviour.
SFTPGO_COMMON__ACTIONS__EXECUTE_SYNC=

# Absolute path to the command to execute, or HTTP URL to notify for actions.
SFTPGO_COMMON__ACTIONS__HOOK=

# ---------------------------------------------------------------------------- #
#               ------- Common - Defender ------
# ---------------------------------------------------------------------------- #
# Enable the brute-force defender. Tracks failed logins and bans offending IPs.
SFTPGO_COMMON__DEFENDER__ENABLED=true

# Defender storage driver. 'memory'=single instance, 'provider'=shared DB
# (requires MySQL, PostgreSQL or CockroachDB as data provider).
SFTPGO_COMMON__DEFENDER__DRIVER=memory

# Duration in minutes for which an IP is banned.
SFTPGO_COMMON__DEFENDER__BAN_TIME=30

# Percentage to increment ban time if a banned host tries to connect again.
SFTPGO_COMMON__DEFENDER__BAN_TIME_INCREMENT=50

# Score threshold to trigger a ban.
SFTPGO_COMMON__DEFENDER__THRESHOLD=15

# Score assigned to login attempts for non-existent user accounts.
SFTPGO_COMMON__DEFENDER__SCORE_INVALID=2

# Score assigned to failed login attempts for valid (existing) user accounts.
SFTPGO_COMMON__DEFENDER__SCORE_VALID=1

# Score assigned when a host exceeds rate limits or max per-host connections.
SFTPGO_COMMON__DEFENDER__SCORE_LIMIT_EXCEEDED=3

# Score assigned to clients that disconnect without any authentication attempt.
SFTPGO_COMMON__DEFENDER__SCORE_NO_AUTH=0

# Time window in minutes for tracking client errors. A host is banned if it
# exceeds the threshold within this window.
SFTPGO_COMMON__DEFENDER__OBSERVATION_TIME=30

# Soft limit for the number of in-memory defender entries (memory driver only).
SFTPGO_COMMON__DEFENDER__ENTRIES_SOFT_LIMIT=100

# Hard limit for in-memory defender entries (memory driver) or max entries
# returned for the host list API (provider driver).
SFTPGO_COMMON__DEFENDER__ENTRIES_HARD_LIMIT=150

# Milliseconds to pause before allowing a successful login (0=disabled).
SFTPGO_COMMON__DEFENDER__LOGIN_DELAY__SUCCESS=0

# Milliseconds to pause before reporting a failed password/interactive login.
SFTPGO_COMMON__DEFENDER__LOGIN_DELAY__PASSWORD_FAILED=1000

# ---------------------------------------------------------------------------- #
#               ------- Common - Rate Limiters ------
# ---------------------------------------------------------------------------- #
# Rate limiters are configured per-index (0, 1, 2, ...). The example below
# defines a single per-IP rate limiter for all protocols.
# See: https://docs.sftpgo.com/latest/rate-limiting/

# Maximum average request rate allowed. 0=disabled.
SFTPGO_COMMON__RATE_LIMITERS__0__AVERAGE=100

# Period in milliseconds. Rate = average / period.
SFTPGO_COMMON__RATE_LIMITERS__0__PERIOD=1000

# Maximum burst (requests allowed in the same instant).
SFTPGO_COMMON__RATE_LIMITERS__0__BURST=10

# Limiter type: 1=global (all IPs combined), 2=per-IP.
SFTPGO_COMMON__RATE_LIMITERS__0__TYPE=2

# Protocols to apply the limiter to. Leave empty for all (SSH, FTP, DAV, HTTP).
SFTPGO_COMMON__RATE_LIMITERS__0__PROTOCOLS=SSH,DAV,FTP,HTTP

# If true, generate a defender event each time the rate limit is exceeded (per-IP only).
SFTPGO_COMMON__RATE_LIMITERS__0__GENERATE_DEFENDER_EVENTS=true

# Soft/hard limits for in-memory per-IP rate limiter entries.
SFTPGO_COMMON__RATE_LIMITERS__0__ENTRIES_SOFT_LIMIT=100
SFTPGO_COMMON__RATE_LIMITERS__0__ENTRIES_HARD_LIMIT=150

# ---------------------------------------------------------------------------- #
#               ------- ACME (Let's Encrypt) ------
# ---------------------------------------------------------------------------- #
# Since you are using Traefik for TLS termination, ACME inside SFTPGo is
# typically not needed. Leave domains empty to disable. Configure only if you
# need SFTPGo to manage its own TLS certificates independently of Traefik.

# Comma-separated list of domains. Empty = ACME disabled.
SFTPGO_ACME__DOMAINS=

# Email used for ACME registration and recovery contact.
SFTPGO_ACME__EMAIL=

# Key type: 2048, 3072, 4096 (RSA), 8192, P256, P384 (EC).
SFTPGO_ACME__KEY_TYPE=4096

# Directory to store certificates and ACME state data.
SFTPGO_ACME__CERTS_PATH=/var/lib/sftpgo/certs

# ACME directory endpoint.
SFTPGO_ACME__CA_ENDPOINT=https://acme-v02.api.letsencrypt.org/directory

# Number of days before expiry at which to renew the certificate.
SFTPGO_ACME__RENEW_DAYS=30

# Port for the HTTP-01 challenge (must be reachable on port 80).
# Set to 0 to disable HTTP-01 challenge.
SFTPGO_ACME__HTTP01_CHALLENGE__PORT=80

# Proxy header to validate against when behind a reverse proxy (empty = Host).
SFTPGO_ACME__HTTP01_CHALLENGE__PROXY_HEADER=

# Absolute path to webroot for file-based HTTP-01 challenge. If set, the built-in
# server is disabled and the directory must be publicly served.
SFTPGO_ACME__HTTP01_CHALLENGE__WEBROOT=

# Port for TLS-ALPN-01 challenge (443). 0=disabled.
SFTPGO_ACME__TLS_ALPN01_CHALLENGE__PORT=0

# ---------------------------------------------------------------------------- #
#               ------- SSH / SFTP Server ------
# ---------------------------------------------------------------------------- #
# Port for SFTP connections. Traefik routes external SSH on port 22 to this port.
SFTPGO_SFTPD__BINDINGS__0__PORT=2022

# Address to listen on. Leave blank for all interfaces.
SFTPGO_SFTPD__BINDINGS__0__ADDRESS=

# Apply the common proxy protocol configuration for this binding.
SFTPGO_SFTPD__BINDINGS__0__APPLY_PROXY_CONFIG=true

# Maximum number of authentication attempts per connection.
# 0 = limited to 6, negative = unlimited.
SFTPGO_SFTPD__MAX_AUTH_TRIES=6

# Comma-separated paths to the server's private host keys (absolute or relative
# to config dir). If empty, id_rsa, id_ecdsa and id_ed25519 are auto-generated.
SFTPGO_SFTPD__HOST_KEYS=

# Comma-separated paths to public host certificates.
SFTPGO_SFTPD__HOST_CERTIFICATES=

# Comma-separated list of accepted host key algorithms.
# Default: rsa-sha2-512,rsa-sha2-256,ecdsa-sha2-nistp256,ecdsa-sha2-nistp384,ecdsa-sha2-nistp521,ssh-ed25519
SFTPGO_SFTPD__HOST_KEY_ALGORITHMS=

# Comma-separated KEX algorithms in preference order. Leave empty for defaults.
SFTPGO_SFTPD__KEX_ALGORITHMS=

# Comma-separated cipher list in preference order. Leave empty for defaults.
# Default: aes128-gcm@openssh.com,aes256-gcm@openssh.com,chacha20-poly1305@openssh.com,aes128-ctr,aes192-ctr,aes256-ctr
SFTPGO_SFTPD__CIPHERS=

# Comma-separated MAC algorithms in preference order. Leave empty for defaults.
# Default: hmac-sha2-256-etm@openssh.com,hmac-sha2-256
SFTPGO_SFTPD__MACS=

# Comma-separated public key algorithms accepted for client authentication.
# Default: ecdsa-sha2-nistp256,ecdsa-sha2-nistp384,ecdsa-sha2-nistp521,rsa-sha2-512,rsa-sha2-256,ssh-ed25519,...
SFTPGO_SFTPD__PUBLIC_KEY_ALGORITHMS=

# Comma-separated paths to CA public keys trusted to sign user certificates.
SFTPGO_SFTPD__TRUSTED_USER_CA_KEYS=

# Path to a JSON file listing revoked user certificate fingerprints.
# Example content: ["SHA256:abc...","SHA256:def..."]
SFTPGO_SFTPD__REVOKED_USER_CERTS_FILE=

# Absolute path to the opkssh binary for OpenPubkey SSH integration.
# Mutually exclusive with trusted_user_ca_keys.
SFTPGO_SFTPD__OPKSSH_PATH=

# Expected SHA256 checksum for the opkssh binary (verified at startup).
SFTPGO_SFTPD__OPKSSH_CHECKSUM=

# Path to a login banner file shown to users before authentication.
SFTPGO_SFTPD__LOGIN_BANNER_FILE=

# Comma-separated list of enabled SSH commands. Use '*' to enable all.
# See: https://docs.sftpgo.com/latest/ssh/#ssh-commands
SFTPGO_SFTPD__ENABLED_SSH_COMMANDS=md5sum,sha1sum,sha256sum,sha512sum,cd,pwd,scp,rsync,git-receive-pack,git-upload-pack,git-upload-archive

# Allow keyboard interactive authentication.
SFTPGO_SFTPD__KEYBOARD_INTERACTIVE_AUTHENTICATION=true

# Absolute path or HTTP URL for the keyboard interactive authentication hook.
SFTPGO_SFTPD__KEYBOARD_INTERACTIVE_AUTH_HOOK=

# Allow password authentication. Set to false for public-key-only setups.
SFTPGO_SFTPD__PASSWORD_AUTHENTICATION=true

# ---------------------------------------------------------------------------- #
#               ------- FTP Server ------
# ---------------------------------------------------------------------------- #
# Port for FTP connections. Set to 0 to disable FTP entirely.
SFTPGO_FTPD__BINDINGS__0__PORT=0

# Address to listen on. Leave blank for all interfaces.
SFTPGO_FTPD__BINDINGS__0__ADDRESS=

# Apply the common proxy protocol configuration for this binding.
SFTPGO_FTPD__BINDINGS__0__APPLY_PROXY_CONFIG=true

# TLS mode: 0=cleartext + TLS accepted, 1=TLS required, 2=implicit TLS.
# Requires a valid certificate if not 0.
SFTPGO_FTPD__BINDINGS__0__TLS_MODE=0

# Binding-specific TLS certificate file (absolute or relative to config dir).
SFTPGO_FTPD__BINDINGS__0__CERTIFICATE_FILE=

# Binding-specific private key file matching the certificate above.
SFTPGO_FTPD__BINDINGS__0__CERTIFICATE_KEY_FILE=

# Minimum TLS version: 10=TLS1.0, 11=TLS1.1, 12=TLS1.2, 13=TLS1.3.
SFTPGO_FTPD__BINDINGS__0__MIN_TLS_VERSION=12

# External IPv4 address for passive connections. Leave empty to autodetect.
SFTPGO_FTPD__BINDINGS__0__FORCE_PASSIVE_IP=

# Hostname for passive connections (resolved on each request; for dynamic IPs).
SFTPGO_FTPD__BINDINGS__0__PASSIVE_HOST=

# Client certificate auth: 0=disabled, 1=required, 2=requested but optional.
SFTPGO_FTPD__BINDINGS__0__CLIENT_AUTH_TYPE=0

# Security for passive data connections: 0=require matching peer IP, 1=no checks.
SFTPGO_FTPD__BINDINGS__0__PASSIVE_CONNECTIONS_SECURITY=0

# Security for active data connections: 0=require matching peer IP, 1=no checks.
# Changing this makes FTP vulnerable to bounce attacks on untrusted networks.
SFTPGO_FTPD__BINDINGS__0__ACTIVE_CONNECTIONS_SECURITY=0

# Log every FTP command (very verbose; enable only for debugging).
SFTPGO_FTPD__BINDINGS__0__DEBUG=false

# Path to the banner file shown on connection. Leave empty to disable.
SFTPGO_FTPD__BANNER_FILE=

# Allow active data transfers from ports other than 20 (enables lower privileges).
SFTPGO_FTPD__ACTIVE_TRANSFERS_PORT_NON_20=true

# Start port for the passive data connection range.
SFTPGO_FTPD__PASSIVE_PORT_RANGE__START=50000

# End port for the passive data connection range.
SFTPGO_FTPD__PASSIVE_PORT_RANGE__END=50100

# Disable active FTP mode entirely.
SFTPGO_FTPD__DISABLE_ACTIVE_MODE=false

# Enable the FTP SITE command (supports chmod and symlink).
SFTPGO_FTPD__ENABLE_SITE=false

# Enable hash commands (HASH, XCRC, MD5, XSHA, etc.). 0=disabled, 1=enabled.
# Calculating hashes on remote backends requires downloading the entire file.
SFTPGO_FTPD__HASH_SUPPORT=0

# Enable the non-standard COMB command for combining partial uploads. 0=disabled, 1=enabled.
# Only useful for local filesystem; cloud backends support native multipart uploads.
SFTPGO_FTPD__COMBINE_SUPPORT=0

# Global TLS certificate for FTPS (absolute or relative to config dir).
SFTPGO_FTPD__CERTIFICATE_FILE=

# Private key matching the FTPS certificate above.
SFTPGO_FTPD__CERTIFICATE_KEY_FILE=

# Comma-separated paths to CA certificates for verifying client certificates.
SFTPGO_FTPD__CA_CERTIFICATES=

# Comma-separated paths to CRL files (one per root CA) for checking revoked client certs.
SFTPGO_FTPD__CA_REVOCATION_LISTS=

# ---------------------------------------------------------------------------- #
#               ------- WebDAV Server ------
# ---------------------------------------------------------------------------- #
# Port for WebDAV connections.
SFTPGO_WEBDAVD__BINDINGS__0__PORT=8081

# Address to listen on. Leave blank for all interfaces.
SFTPGO_WEBDAVD__BINDINGS__0__ADDRESS=

# Traefik handles TLS termination — keep HTTPS disabled on the binding.
SFTPGO_WEBDAVD__BINDINGS__0__ENABLE_HTTPS=false

# Binding-specific TLS certificate (not needed; Traefik handles TLS).
SFTPGO_WEBDAVD__BINDINGS__0__CERTIFICATE_FILE=

# Binding-specific private key matching the certificate above.
SFTPGO_WEBDAVD__BINDINGS__0__CERTIFICATE_KEY_FILE=

# Minimum TLS version: 10=TLS1.0, 11=TLS1.1, 12=TLS1.2, 13=TLS1.3.
SFTPGO_WEBDAVD__BINDINGS__0__MIN_TLS_VERSION=12

# Client certificate auth: 0=disabled, 1=required, 2=requested but optional.
SFTPGO_WEBDAVD__BINDINGS__0__CLIENT_AUTH_TYPE=0

# HTTPS protocols in preference order. Supported: http/1.1, h2.
SFTPGO_WEBDAVD__BINDINGS__0__TLS_PROTOCOLS=http/1.1,h2

# WebDAV resources served at /webdav.
SFTPGO_WEBDAVD__BINDINGS__0__PREFIX=/webdav

# Set to 1 to use the PROXY protocol config from the common section instead
# of the proxy header config below.
SFTPGO_WEBDAVD__BINDINGS__0__PROXY_MODE=0

# Comma-separated IPs/CIDRs allowed to set client IP proxy headers.
# Set to Traefik's Docker network subnet (e.g. 172.20.0.0/16).
SFTPGO_WEBDAVD__BINDINGS__0__PROXY_ALLOWED=

# Header name to read the real client IP from (e.g. X-Forwarded-For, X-Real-IP).
SFTPGO_WEBDAVD__BINDINGS__0__CLIENT_IP_PROXY_HEADER=X-Real-IP

# Position to trust in multi-value proxy headers, counting from the right. 0=rightmost.
SFTPGO_WEBDAVD__BINDINGS__0__CLIENT_IP_HEADER_DEPTH=0

# Set to true to suppress the WWW-Authenticate header on auth failure (only 401 is sent).
# Keep false so WebDAV clients (macOS Finder, Windows, Cyberduck) can prompt for credentials.
SFTPGO_WEBDAVD__BINDINGS__0__DISABLE_WWW_AUTH_HEADER=false

# Global TLS certificate for WebDAV over HTTPS (not needed; Traefik handles TLS).
SFTPGO_WEBDAVD__CERTIFICATE_FILE=

# Private key matching the WebDAV TLS certificate.
SFTPGO_WEBDAVD__CERTIFICATE_KEY_FILE=

# Comma-separated paths to CA certificates for verifying WebDAV client certificates.
SFTPGO_WEBDAVD__CA_CERTIFICATES=

# Comma-separated paths to CRL files for revoking WebDAV client certificates.
SFTPGO_WEBDAVD__CA_REVOCATION_LISTS=

# ---------------------------------------------------------------------------- #
#               ------- WebDAV - Cache ------
# ---------------------------------------------------------------------------- #
# Expiration time in minutes for cached authenticated WebDAV users. 0=unlimited.
SFTPGO_WEBDAVD__CACHE__USERS__EXPIRATION_TIME=0

# Maximum number of WebDAV users to cache. 0=unlimited.
SFTPGO_WEBDAVD__CACHE__USERS__MAX_SIZE=50

# Enable MIME type caching for WebDAV responses.
SFTPGO_WEBDAVD__CACHE__MIME_TYPES__ENABLED=true

# Maximum number of MIME types to cache. 0=no cache.
SFTPGO_WEBDAVD__CACHE__MIME_TYPES__MAX_SIZE=1000

# ---------------------------------------------------------------------------- #
#               ------- Data Provider ------
# ---------------------------------------------------------------------------- #
# Database driver. Supported: sqlite, mysql, postgresql, cockroachdb, bolt, memory.
SFTPGO_DATA_PROVIDER__DRIVER=postgresql

# Database name (or SQLite file path relative to config dir, or absolute path).
SFTPGO_DATA_PROVIDER__NAME=postgres

# Database host. For postgresql/cockroachdb multiple hosts can be comma-separated.
SFTPGO_DATA_PROVIDER__HOST=database

# Database port.
SFTPGO_DATA_PROVIDER__PORT=5432

# Database username.
SFTPGO_DATA_PROVIDER__USERNAME=${SFTPGO_DB_USER}

# Database password.
SFTPGO_DATA_PROVIDER__PASSWORD=${SFTPGO_DB_PASSWORD}

# SSL mode for mysql/postgresql.
# 0=disable, 1=require, 2=verify-ca (pg) / skip-verify (mysql),
# 3=verify-full (pg) / preferred (mysql), 4=prefer (pg only), 5=allow (pg only).
SFTPGO_DATA_PROVIDER__SSLMODE=0

# Path to the root CA certificate to verify the database server certificate.
SFTPGO_DATA_PROVIDER__ROOT_CERT=

# Opt out of Server Name Indication (SNI) for TLS database connections.
SFTPGO_DATA_PROVIDER__DISABLE_SNI=false

# PostgreSQL/CockroachDB session target attributes (useful with multiple hosts).
# Supported: any, read-write, read-only, primary, standby, prefer-standby.
SFTPGO_DATA_PROVIDER__TARGET_SESSION_ATTRS=any

# Path to the client certificate for mutual TLS database authentication.
SFTPGO_DATA_PROVIDER__CLIENT_CERT=

# Path to the client key for mutual TLS database authentication.
SFTPGO_DATA_PROVIDER__CLIENT_KEY=

# Custom database connection string. If set, overrides all individual host/user/pass params.
SFTPGO_DATA_PROVIDER__CONNECTION_STRING=

# Prefix for all SQL table names (useful for shared databases).
SFTPGO_DATA_PROVIDER__SQL_TABLES_PREFIX=sftpgo_

# Quota tracking mode:
# 0=disabled, 1=track for all users on every upload/delete,
# 2=track only for users with quota restrictions and virtual folders.
SFTPGO_DATA_PROVIDER__TRACK_QUOTA=2

# Number of seconds to accumulate quota updates before writing to DB.
# 0=immediate. Useful for high-frequency upload scenarios.
SFTPGO_DATA_PROVIDER__DELAYED_QUOTA_UPDATE=0

# Maximum number of open DB connections (mysql/postgresql). 0=unlimited.
SFTPGO_DATA_PROVIDER__POOL_SIZE=10

# Default base directory for new users (absolute path). The user's home dir
# will be set to <users_base_dir>/<username> if no home dir is specified.
SFTPGO_DATA_PROVIDER__USERS_BASE_DIR=/srv/sftpgo/data

# Absolute path or HTTP URL for a command/hook to invoke on provider events.
SFTPGO_DATA_PROVIDER__ACTIONS__HOOK=

# Comma-separated provider events to trigger the hook: add, update, delete.
SFTPGO_DATA_PROVIDER__ACTIONS__EXECUTE_ON=

# Comma-separated provider objects that trigger the hook:
# user, folder, group, admin, api_key, share, event_action, event_rule.
SFTPGO_DATA_PROVIDER__ACTIONS__EXECUTE_FOR=

# Absolute path or HTTP URL for external authentication.
# See: https://docs.sftpgo.com/latest/external-auth/
SFTPGO_DATA_PROVIDER__EXTERNAL_AUTH_HOOK=

# Authentication scope for the external auth hook.
# 0=all, 1=passwords, 2=public keys, 4=keyboard interactive, 8=TLS cert. Combinable.
SFTPGO_DATA_PROVIDER__EXTERNAL_AUTH_SCOPE=0

# Directory for storing user-provided credential files (e.g. GCS credentials).
SFTPGO_DATA_PROVIDER__CREDENTIALS_PATH=/var/lib/sftpgo/credentials

# Absolute path or HTTP URL for the pre-login hook (modify user before login).
# See: https://docs.sftpgo.com/latest/dynamic-user-mod/
SFTPGO_DATA_PROVIDER__PRE_LOGIN_HOOK=

# Absolute path or HTTP URL for the post-login hook (notify login result).
# See: https://docs.sftpgo.com/latest/post-login-hook/
SFTPGO_DATA_PROVIDER__POST_LOGIN_HOOK=

# Scope for the post-login hook: 0=all, 1=failed only, 2=successful only.
SFTPGO_DATA_PROVIDER__POST_LOGIN_SCOPE=0

# Absolute path or HTTP URL for the check-password hook.
# See: https://docs.sftpgo.com/latest/check-password-hook/
SFTPGO_DATA_PROVIDER__CHECK_PASSWORD_HOOK=

# Scope for the check-password hook: 0=all, 1=SSH, 2=FTP, 4=WebDAV. Combinable.
SFTPGO_DATA_PROVIDER__CHECK_PASSWORD_SCOPE=0

# ---------------------------------------------------------------------------- #
#               ------- Data Provider - Password Hashing ------
# ---------------------------------------------------------------------------- #
# Algorithm for hashing plain-text passwords before storage. [argon2id, bcrypt]
SFTPGO_DATA_PROVIDER__PASSWORD_HASHING__ALGO=argon2id

# bcrypt cost factor (4-31). Higher = more secure but slower.
SFTPGO_DATA_PROVIDER__PASSWORD_HASHING__BCRYPT_OPTIONS__COST=10

# argon2id memory usage in kibibytes.
SFTPGO_DATA_PROVIDER__PASSWORD_HASHING__ARGON2_OPTIONS__MEMORY=65536

# argon2id iteration count.
SFTPGO_DATA_PROVIDER__PASSWORD_HASHING__ARGON2_OPTIONS__ITERATIONS=1

# argon2id parallelism (number of threads).
SFTPGO_DATA_PROVIDER__PASSWORD_HASHING__ARGON2_OPTIONS__PARALLELISM=2

# ---------------------------------------------------------------------------- #
#               ------- Data Provider - Password Validation ------
# ---------------------------------------------------------------------------- #
# Minimum password entropy for admin accounts.
# 0=disabled (any password accepted). See: https://github.com/wagslane/go-password-validator
SFTPGO_DATA_PROVIDER__PASSWORD_VALIDATION__ADMINS__MIN_ENTROPY=50

# Minimum password entropy for protocol users (fallback if not set at user/group level).
SFTPGO_DATA_PROVIDER__PASSWORD_VALIDATION__USERS__MIN_ENTROPY=0

# Enable in-memory password caching to reduce argon2id/bcrypt CPU cost on repeated logins.
SFTPGO_DATA_PROVIDER__PASSWORD_CACHING=true

# Database update mode: 0=automatic migrations, 1=manual (use initprovider subcommand).
SFTPGO_DATA_PROVIDER__UPDATE_MODE=0

# Automatically create the first admin account using SFTPGO_DEFAULT_ADMIN_* env vars.
# Has no effect if an admin account already exists.
SFTPGO_DATA_PROVIDER__CREATE_DEFAULT_ADMIN=true

# Naming rules for usernames and object names.
# 0=unreserved URI chars only, 1=any UTF-8, 2=lowercase enforced, 4=trim whitespace.
# Combinable: 5 (default) = lowercase + trim.
SFTPGO_DATA_PROVIDER__NAMING_RULES=5

# Set to 1 if this data provider is shared across multiple SFTPGo instances.
# Enables cross-instance quota tracking, password reset persistence, etc.
# Supported for MySQL, PostgreSQL, CockroachDB.
SFTPGO_DATA_PROVIDER__IS_SHARED=0

# Path to the backup directory for provider dumps (relative to config dir or absolute).
SFTPGO_DATA_PROVIDER__BACKUPS_PATH=/var/lib/sftpgo/backups

# ---------------------------------------------------------------------------- #
#               ------- HTTP Server (REST API, WebAdmin, WebClient) ------
# ---------------------------------------------------------------------------- #
# Port for the HTTP server. Traefik will proxy to this port.
SFTPGO_HTTPD__BINDINGS__0__PORT=8080

# Address to listen on. Leave blank for all interfaces.
SFTPGO_HTTPD__BINDINGS__0__ADDRESS=

# Enable the built-in WebAdmin UI on this binding.
SFTPGO_HTTPD__BINDINGS__0__ENABLE_WEB_ADMIN=true

# Enable the built-in WebClient UI on this binding.
SFTPGO_HTTPD__BINDINGS__0__ENABLE_WEB_CLIENT=true

# Enable the REST API on this binding.
SFTPGO_HTTPD__BINDINGS__0__ENABLE_REST_API=true

# Disabled login methods (bitmask). 0=all enabled.
# 1=OIDC WebAdmin, 2=OIDC WebClient, 4=form WebAdmin, 8=form WebClient,
# 16=admin token REST API, 32=user token REST API, 64=admin API key, 128=user API key.
SFTPGO_HTTPD__BINDINGS__0__DISABLED_LOGIN_METHODS=0

# Enable HTTPS on this binding. Traefik handles TLS, so keep this false.
SFTPGO_HTTPD__BINDINGS__0__ENABLE_HTTPS=false

# Binding-specific TLS certificate file.
SFTPGO_HTTPD__BINDINGS__0__CERTIFICATE_FILE=

# Binding-specific private key file.
SFTPGO_HTTPD__BINDINGS__0__CERTIFICATE_KEY_FILE=

# Minimum TLS version: 10=TLS1.0, 11=TLS1.1, 12=TLS1.2, 13=TLS1.3.
SFTPGO_HTTPD__BINDINGS__0__MIN_TLS_VERSION=12

# Client certificate auth: 0=disabled, 1=required, 2=optional.
SFTPGO_HTTPD__BINDINGS__0__CLIENT_AUTH_TYPE=0

# HTTPS protocols in preference order. Supported: http/1.1, h2.
SFTPGO_HTTPD__BINDINGS__0__TLS_PROTOCOLS=http/1.1,h2

# Set to 1 to use the PROXY protocol config from the common section.
# Set to 0 to use the proxy header config below (preferred behind Traefik).
SFTPGO_HTTPD__BINDINGS__0__PROXY_MODE=0

# Comma-separated IPs/CIDRs allowed to set client IP proxy headers.
# Set to Traefik's Docker network subnet (e.g. 172.20.0.0/16).
SFTPGO_HTTPD__BINDINGS__0__PROXY_ALLOWED=

# Header used to read the real client IP (e.g. X-Forwarded-For, X-Real-IP).
SFTPGO_HTTPD__BINDINGS__0__CLIENT_IP_PROXY_HEADER=X-Real-IP

# Position to trust in multi-value proxy headers, counting from the right.
SFTPGO_HTTPD__BINDINGS__0__CLIENT_IP_HEADER_DEPTH=0

# Hide login page links: 0=show both, 1=hide client link on admin page,
# 2=hide admin link on client page, 3=hide both.
SFTPGO_HTTPD__BINDINGS__0__HIDE_LOGIN_URL=0

# Serve the OpenAPI schema and renderer.
SFTPGO_HTTPD__BINDINGS__0__RENDER_OPENAPI=true

# Comma-separated UI languages. Supported: en, it, de, fr.
SFTPGO_HTTPD__BINDINGS__0__LANGUAGES=en

# ---------------------------------------------------------------------------- #
#               ------- HTTP Server - OIDC ------
# ---------------------------------------------------------------------------- #
# OpenID Connect provider configuration URL (without /.well-known/openid-configuration).
# Leave blank to disable OIDC.
SFTPGO_HTTPD__BINDINGS__0__OIDC__CONFIG_URL=

# OIDC application client ID.
SFTPGO_HTTPD__BINDINGS__0__OIDC__CLIENT_ID=

# OIDC application client secret.
SFTPGO_HTTPD__BINDINGS__0__OIDC__CLIENT_SECRET=

# Path to a file containing the OIDC client secret (takes precedence over the above).
SFTPGO_HTTPD__BINDINGS__0__OIDC__CLIENT_SECRET_FILE=

# Base URL for the OIDC redirect (suffix /web/oidc/redirect is appended automatically).
SFTPGO_HTTPD__BINDINGS__0__OIDC__REDIRECT_BASE_URL=

# ID token claim field to map to the SFTPGo username.
SFTPGO_HTTPD__BINDINGS__0__OIDC__USERNAME_FIELD=

# Comma-separated OAuth2 scopes to request. The openid scope is mandatory.
SFTPGO_HTTPD__BINDINGS__0__OIDC__SCOPES=openid,profile,email

# ID token claim field to map to the SFTPGo role (value 'admin' = SFTPGo admin).
# Use dot notation for nested fields (e.g. roles.primary). Leave blank if using WebClient only.
SFTPGO_HTTPD__BINDINGS__0__OIDC__ROLE_FIELD=

# If true, SFTPGo role is inferred from the login link used (ignores role_field).
SFTPGO_HTTPD__BINDINGS__0__OIDC__IMPLICIT_ROLES=false

# Comma-separated custom token claim fields to forward to the pre-login hook.
SFTPGO_HTTPD__BINDINGS__0__OIDC__CUSTOM_FIELDS=

# Skip JWT signature validation (for providers like Azure that use 'none' algo). Security risk!
SFTPGO_HTTPD__BINDINGS__0__OIDC__INSECURE_SKIP_SIGNATURE_CHECK=false

# Log received ID tokens at debug level.
SFTPGO_HTTPD__BINDINGS__0__OIDC__DEBUG=false

# ---------------------------------------------------------------------------- #
#               ------- HTTP Server - Security Headers ------
# ---------------------------------------------------------------------------- #
# Enable HTTP security headers and host restrictions.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__ENABLED=true

# Comma-separated list of fully-qualified domain names to allow. Empty=any host.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__ALLOWED_HOSTS=

# Treat allowed_hosts entries as regular expressions.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__ALLOWED_HOSTS_ARE_REGEX=false

# Comma-separated proxy headers that may carry the proxied hostname (e.g. X-Forwarded-Host).
SFTPGO_HTTPD__BINDINGS__0__SECURITY__HOSTS_PROXY_HEADERS=X-Forwarded-Host

# Redirect HTTP to HTTPS. Not needed if Traefik handles the redirect.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__HTTPS_REDIRECT=false

# Hostname for HTTPS redirects. Empty = use the same host.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__HTTPS_HOST=

# Proxy headers that indicate a valid HTTPS request (e.g. X-Forwarded-Proto=https).
# Format is a JSON-style list; set via config file or multiple env vars if needed.
# SFTPGO_HTTPD__BINDINGS__0__SECURITY__HTTPS_PROXY_HEADERS=

# max-age for Strict-Transport-Security header in seconds. 0=header not sent.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__STS_SECONDS=31536000

# Append includeSubdomains to the STS header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__STS_INCLUDE_SUBDOMAINS=true

# Append preload flag to the STS header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__STS_PRELOAD=false

# Add X-Content-Type-Options: nosniff header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__CONTENT_TYPE_NOSNIFF=true

# Value for the Content-Security-Policy header. Leave blank for default.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__CONTENT_SECURITY_POLICY=

# Value for the Permissions-Policy header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__PERMISSIONS_POLICY=

# Value for the Cross-Origin-Opener-Policy header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__CROSS_ORIGIN_OPENER_POLICY=

# Value for the Cross-Origin-Resource-Policy header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__CROSS_ORIGIN_RESOURCE_POLICY=

# Value for the Cross-Origin-Embedder-Policy header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__CROSS_ORIGIN_EMBEDDER_POLICY=

# Value for the Referrer-Policy header.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__REFERRER_POLICY=strict-origin-when-cross-origin

# Value for the Cache-Control header. Set to 'private' to disable caching for dynamic pages.
SFTPGO_HTTPD__BINDINGS__0__SECURITY__CACHE_CONTROL=private

# ---------------------------------------------------------------------------- #
#               ------- HTTP Server - Global Settings ------
# ---------------------------------------------------------------------------- #
# Path to HTML web templates (absolute or relative to config dir).
# Leave empty to use the built-in templates.
SFTPGO_HTTPD__TEMPLATES_PATH=

# Path to static files for the web interface (absolute or relative to config dir).
# Leave empty to use the built-in static files.
SFTPGO_HTTPD__STATIC_FILES_PATH=

# Path to the directory containing the OpenAPI schema and renderer.
SFTPGO_HTTPD__OPENAPI_PATH=

# Base URI for WebAdmin and WebClient (e.g. /sftpgo). Empty = served at root /.
SFTPGO_HTTPD__WEB_ROOT=

# Global TLS certificate for HTTPS (absolute or relative to config dir).
SFTPGO_HTTPD__CERTIFICATE_FILE=

# Private key matching the global HTTPS certificate.
SFTPGO_HTTPD__CERTIFICATE_KEY_FILE=

# Comma-separated paths to CA certificates for verifying HTTP client certificates.
SFTPGO_HTTPD__CA_CERTIFICATES=

# Comma-separated paths to CRL files for revoking HTTP client certificates.
SFTPGO_HTTPD__CA_REVOCATION_LISTS=

# Passphrase for deriving the signing key for JWT and CSRF tokens.
# If empty, a random key is generated at each startup (invalidates all sessions on restart).
SFTPGO_HTTPD__SIGNING_PASSPHRASE=${SFTPGO_SIGNING_PASSPHRASE}

# Path to a file containing the signing passphrase (takes precedence over the above).
SFTPGO_HTTPD__SIGNING_PASSPHRASE_FILE=

# JWT/cookie validation mode.
# 0=token must match original IP, 1=disable IP check, 2=invalidate tokens from before last update.
SFTPGO_HTTPD__TOKEN_VALIDATION=0

# Duration in minutes for WebAdmin and WebClient cookies. Max: 720. Default: 20.
SFTPGO_HTTPD__COOKIE_LIFETIME=20

# Duration in minutes for public sharing cookies. Max: 720. Default: 120.
SFTPGO_HTTPD__SHARE_COOKIE_LIFETIME=120

# Duration in minutes for REST API JWT tokens. Max: 720. Default: 20.
SFTPGO_HTTPD__JWT_LIFETIME=20

# Maximum HTTP upload request body size in bytes. 0=no limit.
SFTPGO_HTTPD__MAX_UPLOAD_FILE_SIZE=0

# If set, this code is required when creating the first admin account via the setup screen.
SFTPGO_HTTPD__SETUP__INSTALLATION_CODE=${SFTPGO_INSTALLATION_CODE}

# Label for the installation code input field on the setup screen.
SFTPGO_HTTPD__SETUP__INSTALLATION_CODE_HINT=Installation code

# Hide the link to the SFTPGo sponsors section on the setup screen.
SFTPGO_HTTPD__HIDE_SUPPORT_LINK=false

# ---------------------------------------------------------------------------- #
#               ------- Telemetry ------
# ---------------------------------------------------------------------------- #
# Port for the telemetry HTTP server (/healthz, /metrics, /debug/pprof).
# Set to 0 to disable. Bind to 127.0.0.1 and expose via Traefik if needed externally.
SFTPGO_TELEMETRY__BIND_PORT=10000

# Address to listen on for telemetry. Default: 127.0.0.1 (localhost only).
SFTPGO_TELEMETRY__BIND_ADDRESS=127.0.0.1

# Enable the built-in Go pprof profiling endpoint (/debug/pprof).
SFTPGO_TELEMETRY__ENABLE_PROFILER=false

# Path to an htpasswd file for HTTP basic auth on the telemetry endpoints.
# Supported formats: bcrypt ($2y$), md5 crypt ($apr1$). Empty = no auth.
# The /healthz endpoint is always unauthenticated.
SFTPGO_TELEMETRY__AUTH_USER_FILE=

# TLS certificate for the telemetry server.
SFTPGO_TELEMETRY__CERTIFICATE_FILE=

# Private key for the telemetry server TLS certificate.
SFTPGO_TELEMETRY__CERTIFICATE_KEY_FILE=

# Minimum TLS version: 10=TLS1.0, 11=TLS1.1, 12=TLS1.2, 13=TLS1.3.
SFTPGO_TELEMETRY__MIN_TLS_VERSION=12

# ---------------------------------------------------------------------------- #
#               ------- HTTP Clients (used by hooks) ------
# ---------------------------------------------------------------------------- #
# Timeout in seconds for a single HTTP request made by a hook. For retryable
# hooks, this applies per attempt.
SFTPGO_HTTP__TIMEOUT=20

# Minimum wait time between retry attempts in seconds.
SFTPGO_HTTP__RETRY_WAIT_MIN=2

# Maximum wait time between retry attempts (exponential backoff cap) in seconds.
SFTPGO_HTTP__RETRY_WAIT_MAX=30

# Maximum number of retries after the first request fails.
SFTPGO_HTTP__RETRY_MAX=3

# Comma-separated paths to extra CA certificates to trust for hook HTTP calls.
# Useful for self-signed certificates on internal services.
SFTPGO_HTTP__CA_CERTIFICATES=

# Skip TLS verification for hook HTTP clients (insecure; for testing only).
SFTPGO_HTTP__SKIP_TLS_VERIFY=false

# ---------------------------------------------------------------------------- #
#               ------- External Commands ------
# ---------------------------------------------------------------------------- #
# Timeout in seconds for external hook commands. Valid range: 1-300.
SFTPGO_COMMAND__TIMEOUT=30

# Comma-separated environment variables to pass to all external commands.
# Global env is cleared for security; explicitly include what you need (e.g. PATH).
# Format: KEY=VALUE
SFTPGO_COMMAND__ENV=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# ---------------------------------------------------------------------------- #
#               ------- KMS (Key Management Service) ------
# ---------------------------------------------------------------------------- #
# URI to the KMS service for encrypting secrets at rest.
# Leave blank to use local encryption (master key below).
# See: https://docs.sftpgo.com/latest/kms/
SFTPGO_KMS__SECRETS__URL=

# Master encryption key as a plain string (used when KMS URL is blank).
# Generate a strong random value. Leave blank for no master key.
SFTPGO_KMS__SECRETS__MASTER_KEY=${SFTPGO_KMS_MASTER_KEY}

# Absolute path to a file containing the master key (takes precedence over the above).
SFTPGO_KMS__SECRETS__MASTER_KEY_PATH=

# ---------------------------------------------------------------------------- #
#               ------- Multi-Factor Authentication (TOTP) ------
# ---------------------------------------------------------------------------- #
# TOTP configuration name. Do NOT change this after users have enrolled,
# as stored TOTP secrets are linked to the configuration name.
SFTPGO_MFA__TOTP__0__NAME=Default

# Organization name shown in authenticator apps (e.g. Google Authenticator).
SFTPGO_MFA__TOTP__0__ISSUER=SFTPGo

# HMAC algorithm for TOTP: sha1, sha256, sha512.
# Check compatibility with your target authenticator app before changing.
# Google Authenticator on iOS only supports sha1.
SFTPGO_MFA__TOTP__0__ALGO=sha1

# ---------------------------------------------------------------------------- #
#               ------- SMTP ------
# ---------------------------------------------------------------------------- #
# SMTP server address. Leave blank to disable email sending.
SFTPGO_SMTP__HOST=${SMTP_HOST}
# SMTP server port.
SFTPGO_SMTP__PORT=${SMTP_PORT}
# From address for outgoing emails (e.g. "SFTPGo <sftpgo@example.com>").
SFTPGO_SMTP__FROM=SFTPGo <noreply-sftpgo@${DOMAIN}>
# SMTP username.
SFTPGO_SMTP__USER=${SMTP_USERNAME}
# SMTP password. Leave both user and password empty to disable SMTP authentication.
SFTPGO_SMTP__PASSWORD=${SMTP_PASSWORD}

# SMTP authentication type: 0=Plain, 1=Login, 2=CRAM-MD5, 3=XOAUTH2.
SFTPGO_SMTP__AUTH_TYPE=0
# SMTP encryption: 0=none, 1=TLS (SMTPS), 2=STARTTLS.
SFTPGO_SMTP__ENCRYPTION=2
# Domain for the SMTP HELO command. Leave blank to use localhost.
SFTPGO_SMTP__DOMAIN=${DOMAIN}
# Path to custom email templates directory (templates searched in an 'email' subdirectory).
# Leave blank to use built-in templates.
SFTPGO_SMTP__TEMPLATES_PATH=
# Enable SMTP debug logging. 0=disabled, 1=enabled.
SFTPGO_SMTP__DEBUG=0
