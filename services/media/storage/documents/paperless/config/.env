# ---------------------------------------------------------------------------- #
#               ------- Paperless Configuration File --------
# ---------------------------------------------------------------------------- #
# https://docs.paperless-ngx.com/configuration

# ---------------------------------------------------------------------------- #
#               ------- Redis Broker --------
# ---------------------------------------------------------------------------- #
PAPERLESS_REDIS=redis://:${PAPERLESS_CACHE_PASSWORD}@cache:6379

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #
PAPERLESS_DBENGINE=postgres
PAPERLESS_DBHOST=db
PAPERLESS_DBPORT=5432
PAPERLESS_DBNAME=postgres
PAPERLESS_DBUSER=${PAPERLESS_DB_USERNAME}
PAPERLESS_DBPASS=${PAPERLESS_DB_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Docker specific --------
# ---------------------------------------------------------------------------- #
USERMAP_UID=${USER_UID}
USERMAP_GID=${USER_GID}

# ---------------------------------------------------------------------------- #
#               ------- Email --------
# ---------------------------------------------------------------------------- #
PAPERLESS_EMAIL_HOST=${SMTP_HOST}
PAPERLESS_EMAIL_PORT=${SMTP_PORT}
PAPERLESS_EMAIL_HOST_USER=${SMTP_USERNAME}
PAPERLESS_EMAIL_FROM=noreply-paperless@${DOMAIN}
PAPERLESS_EMAIL_HOST_PASSWORD=${SMTP_PASSWORD}
PAPERLESS_EMAIL_USE_TLS=true
PAPERLESS_EMAIL_USE_SSL=false

# ---------------------------------------------------------------------------- #
#               ------- Frontend --------
# ---------------------------------------------------------------------------- #
PAPERLESS_APP_TITLE="${NAME} Paperless"

# ---------------------------------------------------------------------------- #
#               ------- Logging --------
# ---------------------------------------------------------------------------- #
PAPERLESS_LOGROTATE_MAX_BACKUPS=5
PAPERLESS_LOGROTATE_MAX_SIZE=10000000

# ---------------------------------------------------------------------------- #
#               ------- OCR --------
# ---------------------------------------------------------------------------- #
PAPERLESS_OCR_LANGUAGE=eng+fra
PAPERLESS_OCR_MODE=skip
PAPERLESS_OCR_SKIP_ARCHIVE_FILE=never

PAPERLESS_OCR_CLEAN=clean
PAPERLESS_OCR_DESKEW=true

PAPERLESS_OCR_ROTATE_PAGES=true
PAPERLESS_OCR_ROTATE_PAGES_THRESHOLD=12

PAPERLESS_OCR_OUTPUT_TYPE=pdfa
# PAPERLESS_OCR_PAGES=


# ---------------------------------------------------------------------------- #
#               ------- Paths and Folders --------
# ---------------------------------------------------------------------------- #

# ---------------------------------------------------------------------------- #
#               ------- Security --------
# ---------------------------------------------------------------------------- #
PAPERLESS_SECRET_KEY=${PAPERLESS_SECRET_KEY}

PAPERLESS_URL=https://${PAPERLESS_HOST}

PAPERLESS_ADMIN_USER=${PAPERLESS_ADMIN_USERNAME}
PAPERLESS_ADMIN_MAIL=${USER_EMAIL}
PAPERLESS_ADMIN_PASSWORD=${PAPERLESS_ADMIN_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Tika --------
# ---------------------------------------------------------------------------- #
PAPERLESS_TIKA_ENABLED=true
PAPERLESS_TIKA_ENDPOINT=http://tika:9998
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://gotenberg:3000

# ---------------------------------------------------------------------------- #
#               ------- Trash --------
# ---------------------------------------------------------------------------- #
PAPERLESS_EMPTY_TRASH_DELAY=30

# ---------------------------------------------------------------------------- #
#               ------- Tweaks --------
# ---------------------------------------------------------------------------- #
PAPERLESS_TIME_ZONE=${TIMEZONE}
