# ---------------------------------------------------------------------------- #
#               ------- Nextcloud Configuration File --------
# ---------------------------------------------------------------------------- #

# ---------------------------------------------------------------------------- #
#               ------- Administration User --------
# ---------------------------------------------------------------------------- #
NEXTCLOUD_ADMIN_USER=${NEXTCLOUD_ROOT_USER}
NEXTCLOUD_ADMIN_PASSWORD=${NEXTCLOUD_ROOT_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Cache --------
# ---------------------------------------------------------------------------- #
REDIS_HOST=cache
REDIS_HOST_PORT=6379
REDIS_HOST_PASSWORD=${NEXTCLOUD_CACHE_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Database--------
# ---------------------------------------------------------------------------- #
MYSQL_HOST=db
MYSQL_DATABASE=mariadb
MYSQL_USER=${NEXTCLOUD_DB_USER}
MYSQL_PASSWORD=${NEXTCLOUD_DB_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- SMTP --------
# ---------------------------------------------------------------------------- #
#SMTP_HOST=${SMTP_HOST}
#SMTP_SECURE=tls
#SMTP_PORT=${SMTP_PORT}
#SMTP_AUTHTYPE=LOGIN
#SMTP_NAME=${SMTP_USERNAME}
#SMTP_PASSWORD=${SMTP_PASSWORD}
#MAIL_FROM_ADDRESS=noreply-nextcloud@${DOMAIN}

# ---------------------------------------------------------------------------- #
#               ------- PHP --------
# ---------------------------------------------------------------------------- #
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_LIMIT=16G

# ---------------------------------------------------------------------------- #
#               ------- Web --------
# ---------------------------------------------------------------------------- #
# Trusted Domains
NEXTCLOUD_TRUSTED_DOMAINS=${NEXTCLOUD_HOST}

# Configuration behind nginx proxy
TRUSTED_PROXIES=${NEXTCLOUD_WEB_IP}
