# ---------------------------------------------------------------------------- #
#               ------- Librum Configuration File --------
# ---------------------------------------------------------------------------- #
# https://github.com/Librum-Reader/Librum-Server

# Administrator
AdminEmail=${USER_EMAIL}                       # Admin login username
AdminPassword=${LIBRUM_ADMIN_PASSWORD}    # Admin login password

JWTValidIssuer=${LIBRUM_JWT_VALID_ISSUER} # Optional. You can leave it as-is
JWTKey=${LIBRUM_JWT_KEY}                  # Optional. You can leave it as-is

# ---------------------------------------------------------------------------- #
#               ------- Artificial Intelligence --------
# ---------------------------------------------------------------------------- #

# Optional. Generate here: https://platform.openai.com/api-keys
# OpenAIToken=

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #
DBConnectionString=Server=db;port=3306;Database=librum;Uid=${LIBRUM_DB_USER};Pwd=${LIBRUM_DB_PASSWORD};

# ---------------------------------------------------------------------------- #
#               ------- Email --------
# ---------------------------------------------------------------------------- #
SMTPEndpoint=${SMTP_HOST}:${SMTP_PORT}
SMTPUsername=${SMTP_USERNAME}
SMTPPassword=${SMTP_PASSWORD}
SMTPMailFrom=noreply-librum@${DOMAIN}
