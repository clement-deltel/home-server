# ---------------------------------------------------------------------------- #
#               ------- Karakeep Configuration File --------
# ---------------------------------------------------------------------------- #
# https://docs.karakeep.app/configuration/environment-variables

PORT=3000
LOG_LEVEL=warning
DATA_DIR=/data

# Should point to the address of your server. The app will function without it,
# but will redirect you to wrong addresses on signout for example.
NEXTAUTH_URL=http://bookmarks.${DOMAIN}
# Random string used to sign the JWT tokens. Generate one with:
# openssl rand -base64 36
NEXTAUTH_SECRET=${KARAKEEP_NEXTAUTH_SECRET}

# Enables WAL mode for the sqlite database. This should improve the performance
# of the database. There's no reason why you shouldn't set this to true unless
# you're running the db on a network attached drive. This will become the default
# at some time in the future.
DB_WAL_MODE=true

# ---------------------------------------------------------------------------- #
#               ------- Meilisearch --------
# ---------------------------------------------------------------------------- #
MEILI_ADDR=http://meilisearch:7700
MEILI_MASTER_KEY=${KARAKEEP_MEILI_MASTER_KEY}

MEILI_NO_ANALYTICS=true

# ---------------------------------------------------------------------------- #
#               ------- Authentication --------
# ---------------------------------------------------------------------------- #

# If enabled, no new signups will be allowed and the signup button will be
# disabled in the UI
DISABLE_SIGNUPS=false

# OAUTH_AUTO_REDIRECT=
# OAUTH_WELLKNOWN_URL=
# OAUTH_CLIENT_SECRET=
# OAUTH_CLIENT_ID=
# OAUTH_SCOPE=
# OAUTH_PROVIDER_NAME=
# OAUTH_ALLOW_DANGEROUS_EMAIL_ACCOUNT_LINKING=
# OAUTH_TIMEOUT=

# ---------------------------------------------------------------------------- #
#               ------- Artificial Intelligence --------
# ---------------------------------------------------------------------------- #

# OpenAI
# OPENAI_API_KEY=${OPENAI_API_KEY}

# Ollama
# OLLAMA_BASE_URL=${KARAKEEP_GATEWAY}:11434
# INFERENCE_TEXT_MODEL=
# INFERENCE_IMAGE_MODEL=
# INFERENCE_CONTEXT_LENGTH=

# ---------------------------------------------------------------------------- #
#               ------- Crawler (Chrome) --------
# ---------------------------------------------------------------------------- #

# Number of allowed concurrent crawling jobs. By default, we're only doing one
# crawling request at a time to avoid consuming a lot of resources.
CRAWLER_NUM_WORKERS=1

# The browser's http debugging address. The worker will talk to this endpoint to
# resolve the debugging console's websocket address. If you already have the
# websocket address, use BROWSER_WEBSOCKET_URL instead. If neither
# BROWSER_WEB_URL nor BROWSER_WEBSOCKET_URL are set, the worker will use plain
# http requests skipping screenshotting and javascript execution.
BROWSER_WEB_URL=http://chrome:9222

# ---------------------------------------------------------------------------- #
#               ------- OCR (Tesseract) --------
# ---------------------------------------------------------------------------- #

# The dir where tesseract will download its models. By default, those models are
# not persisted and stored in the OS' temp dir.
# OCR_CACHE_DIR=$TEMP_DIR

# Comma separated list of the language codes that you want tesseract to support.
# You can find the language codes here. Set to empty string to disable OCR.
OCR_LANGS=eng,fra

# A number between 0 and 100 indicating the minimum acceptable confidence from
# tesseract. If tesseract's confidence is lower than this value, extracted text
# won't be stored.
OCR_CONFIDENCE_THRESHOLD=50

# If set to true, uses the configured inference model (OpenAI or Ollama) for OCR
# instead of Tesseract. This can provide better results for complex images but
# requires a configured inference provider (OPENAI_API_KEY or OLLAMA_BASE_URL).
# Falls back to Tesseract if no inference provider is configured.
OCR_USE_LLM=false

# ---------------------------------------------------------------------------- #
#               ------- Webhooks --------
# ---------------------------------------------------------------------------- #

# ---------------------------------------------------------------------------- #
#               ------- SMTP --------
# ---------------------------------------------------------------------------- #

# The SMTP server hostname or IP address. Required if you want to enable email
# functionality.
SMTP_HOST=${SMTP_HOST}

# The SMTP server port. Common values are 587 (STARTTLS), 465 (SSL/TLS), or 25
# (unencrypted).
SMTP_PORT=${SMTP_PORT}

# Whether to use SSL/TLS encryption. Set to true for port 465, false for port
# 587 with STARTTLS.
SMTP_SECURE=true

# The username for SMTP authentication. Usually your email address.
SMTP_USER=${SMTP_USERNAME}

# The password for SMTP authentication. For services like Gmail, use an
# app-specific password.
SMTP_PASSWORD=${SMTP_PASSWORD}

# The "from" email address that will appear in sent emails. This should be a
# valid email address.
SMTP_FROM=noreply-bookmarks@${DOMAIN}

# ---------------------------------------------------------------------------- #
#               ------- Proxy --------
# ---------------------------------------------------------------------------- #

