# ---------------------------------------------------------------------------- #
#               ------- Authentik Configuration File --------
# ---------------------------------------------------------------------------- #
# https://docs.goauthentik.io/install-config/configuration

AUTHENTIK_SECRET_KEY=${AUTHENTIK_SECRET_KEY}

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #
AUTHENTIK_POSTGRESQL__HOST=db
AUTHENTIK_POSTGRESQL__NAME=postgres
AUTHENTIK_POSTGRESQL__PASSWORD=${AUTHENTIK_DB_PASSWORD}
AUTHENTIK_POSTGRESQL__USER=${AUTHENTIK_DB_USER}

# ---------------------------------------------------------------------------- #
#               ------- Email --------
# ---------------------------------------------------------------------------- #
AUTHENTIK_EMAIL__HOST=${SMTP_HOST}
AUTHENTIK_EMAIL__PORT=${SMTP_PORT}

# Optionally authenticate (don't add quotation marks to your password)
AUTHENTIK_EMAIL__USERNAME=${SMTP_USERNAME}
AUTHENTIK_EMAIL__PASSWORD=${SMTP_PASSWORD}

# Use StartTLS
AUTHENTIK_EMAIL__USE_TLS=true

# Use SSL
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__TIMEOUT=15

# Email address authentik will send from, should have a correct @domain
AUTHENTIK_EMAIL__FROM=noreply-authentik@${DOMAIN}

# ---------------------------------------------------------------------------- #
#               ------- Log --------
# ---------------------------------------------------------------------------- #
AUTHENTIK_LOG_LEVEL=info
