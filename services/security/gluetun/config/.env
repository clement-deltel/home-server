# ---------------------------------------------------------------------------- #
#               ------- Gluetun Configuration File --------
# ---------------------------------------------------------------------------- #
# https://github.com/qdm12/gluetun-wiki/tree/main/setup

# ---------------------------------------------------------------------------- #
#               ------- Control Server --------
# ---------------------------------------------------------------------------- #

# Listening address for the HTTP control server
HTTP_CONTROL_SERVER_ADDRESS=:8000

# Enable logging of HTTP requests
HTTP_CONTROL_SERVER_LOG=on

# Path to a TOML file containing authentication configuration
# HTTP_CONTROL_SERVER_AUTH_CONFIG_FILEPATH=

# ---------------------------------------------------------------------------- #
#               ------- DNS --------
# ---------------------------------------------------------------------------- #
# How to connect to the upstream DNS servers. dot means DNS over TLS, doh means
# DNS over HTTPS, plain means plain UDP DNS.
DNS_UPSTREAM_RESOLVER_TYPE=dot

# Comma delimited list of DNS over TLS providers
DNS_UPSTREAM_RESOLVERS=cloudflare

# DNS caching
DNS_CACHING=on

# DNS IPv6 resolution
DNS_UPSTREAM_IPV6=off

# ---------------------------------------------------------------------------- #
#               ------- Firewall --------
# ---------------------------------------------------------------------------- #
# Comma separated list of ports to allow from the VPN server side
# FIREWALL_VPN_INPUT_PORTS=

# Comma separated list of ports to allow through the default interface. This
# seems needed for Kubernetes sidecars.
# FIREWALL_INPUT_PORTS=

# Prints every firewall related command. You should use it for debugging purposes
# only.
# FIREWALL_DEBUG=off

# Comma separated subnets that Gluetun and the containers sharing its network
# stack are allowed to access. This involves firewall and routing modifications.
# FIREWALL_OUTBOUND_SUBNETS=

# ---------------------------------------------------------------------------- #
#               ------- Healthcheck --------
# ---------------------------------------------------------------------------- #
# Addresses to TCP+TLS dial on connection establishment and then every 5
# minutes. Extra addresses are used as fallbacks.
HEALTH_TARGET_ADDRESSES=cloudflare.com:443,github.com:443

# Addresses to ICMP ping every minute after connection. Extra addresses are
# used as fallbacks.
HEALTH_ICMP_TARGET_IPS=${DNS_SERVER_1},${DNS_SERVER_2}

# Internal health check server listening address
HEALTH_SERVER_ADDRESS=127.0.0.1:9999

# Auto healing feature. I highly suggest keeping this on. You can keep it off to
# debug why your connection goes unstable.
HEALTH_RESTART_VPN=on

# ---------------------------------------------------------------------------- #
#               ------- HTTP Proxy --------
# ---------------------------------------------------------------------------- #
# Enable the internal HTTP proxy
HTTPPROXY=off

# Logs every tunnel requests
HTTPPROXY_LOG=off

# Internal listening address for the HTTP proxy
# HTTPPROXY_LISTENING_ADDRESS=:8888

# Username to use to connect to the HTTP proxy
# HTTPPROXY_USER=

# Password to use to connect to the HTTP proxy
# HTTPPROXY_PASSWORD=

# Stealth mode means HTTP proxy headers are not added to your requests
# HTTPPROXY_STEALTH=off

# ---------------------------------------------------------------------------- #
#               ------- Others --------
# ---------------------------------------------------------------------------- #
# Set the logging level verbosity
LOG_LEVEL=info

# Specify a timezone to use to have correct log times
TZ=${TIMEZONE}

# User ID to run as non root and for ownership of files written
PUID=${USER_PID}

# Group ID to run as non root and for ownership of files written
PGID=${USER_GID}

# Check for public IP address information on VPN connection
PUBLICIP_ENABLED=true

# Public IP echo service API to use or an echoip URL in the form
# echoip#https://xyz
PUBLICIP_API=ipinfo,ifconfigco,ip2location,cloudflare

# Optional API token for the public IP echo service to increase rate limiting
# PUBLICIP_API_TOKEN=

# Filepath to store the public IP address assigned. This will be removed in the
# v4 program, instead you might want to use the control server
# PUBLICIP_FILE=/tmp/gluetun/ip

# Logs a message indicating if a newer version is available once the VPN is
# connected
VERSION_INFORMATION=on

# Fight AI slop and help the Gluetun community by polling periodically every few
# minutes a 500KB file from gluetun[dot]com to make it unsustainable to host due
# to egress costs. And no, this won't be extended to other sites, nor will it
# default to on.
BORINGPOLL_GLUETUNCOM=on

# ---------------------------------------------------------------------------- #
#               ------- Port Forwarding --------
# ---------------------------------------------------------------------------- #
# Enable custom port forwarding code for supported providers
VPN_PORT_FORWARDING=on

# Choose the custom port forwarding code to use. This is useful when using the
# custom provider with Wireguard. For PIA, make sure you set
# SERVER_NAMES=<server-name>.
# VPN_PORT_FORWARDING_PROVIDER=${GLUETUN_PROVIDER}

# File path to use for writing the forwarded port obtained.
# VPN_PORT_FORWARDING_STATUS_FILE=/tmp/gluetun/forwarded_port

# Port redirection to redirect incoming traffic to. Do not use with torrent clients.
# VPN_PORT_FORWARDING_LISTENING_PORT=

# Command to run when port forwarding has finished setting up.
# VPN_PORT_FORWARDING_UP_COMMAND=

# Command to run when port forwarding has finished tearing down.
# VPN_PORT_FORWARDING_DOWN_COMMAND=

# ---------------------------------------------------------------------------- #
#               ------- Shadowsocks --------
# ---------------------------------------------------------------------------- #
# Enable the internal Shadowsocks proxy
SHADOWSOCKS=off

# Enable logging
SHADOWSOCKS_LOG=off

# Internal listening address for Shadowsocks
# SHADOWSOCKS_LISTENING_ADDRESS=:8388

# Password to use to connect to Shadowsocks
# SHADOWSOCKS_PASSWORD=

# AEAD Cipher to use for Shadowsocks
# SHADOWSOCKS_CIPHER=chacha20-ietf-poly1305

# ---------------------------------------------------------------------------- #
#               ------- Storage --------
# ---------------------------------------------------------------------------- #
# Path of servers.json file, or empty to disable caching servers
STORAGE_FILEPATH=/gluetun/servers.json

# ---------------------------------------------------------------------------- #
#               ------- Updater --------
# ---------------------------------------------------------------------------- #
# Period to update the VPN servers data in memory and to /gluetun/servers.json.
# Set to 0 to disable. This does a burst of DNS over TLS requests, which may be
# blocked if you set BLOCK_MALICIOUS=on for example.
UPDATER_PERIOD=0

# Ratio of servers to be found for the update to succeed, compared to the servers
# already built in the program
UPDATER_MIN_RATIO=0.8

# List of providers to update servers data for, when the updater triggers
# periodically. If left empty, it defaults to the current VPN provider used at
# start.
UPDATER_VPN_SERVICE_PROVIDERS=${GLUETUN_PROVIDER}

# If you need paid servers data, you must use a paid account. Otherwise I
# recommend creating a free throwaway account for this.
# UPDATER_PROTONVPN_EMAIL=

# If you need paid servers data, you must use a paid account. Otherwise I
# recommend creating a free throwaway account for this.
# UPDATER_PROTONVPN_PASSWORD=

# ---------------------------------------------------------------------------- #
#               ------- VPN --------
# ---------------------------------------------------------------------------- #
# Specify a supported VPN provider to use
VPN_SERVICE_PROVIDER=${GLUETUN_PROVIDER}

# VPN protocol to use. Not all providers support Wireguard.
VPN_TYPE=wireguard

# Specify a custom network interface name to use
VPN_INTERFACE=tun0

# Command to run when the VPN connection goes up. You can use the following
# template variables if needed: {{VPN_INTERFACE}}
# VPN_UP_COMMAND=

# Command to run when the VPN connection goes down. You can use the following
# template variables if needed: {{VPN_INTERFACE}}
# VPN_DOWN_COMMAND=

# ---------------------------------------------------------------------------- #
#               ------- Wireguard --------
# ---------------------------------------------------------------------------- #
# Wireguard client private key to use. This is usually always needed.
WIREGUARD_PRIVATE_KEY=${GLUETUN_WIREGUARD_PRIVATE_KEY}

# This is usually needed.
WIREGUARD_ADDRESSES=10.64.222.21/32

# Wireguard server public key to use. This may or may not be needed.
# WIREGUARD_PUBLIC_KEY=

# Specify a generally optional target VPN server IP address to use
# WIREGUARD_ENDPOINT_IP=

# Specify a generally optional target VPN server port number to use
# WIREGUARD_ENDPOINT_PORT=

# ---------------------------------------------------------------------------- #
#               ------- Extra --------
# ---------------------------------------------------------------------------- #
# Comma separated list of countries
SERVER_COUNTRIES=${GLUETUN_COUNTRIES}

# Comma separated list of regions
# SERVER_REGIONS=

# Comma separated list of cities
# SERVER_CITIES=

# Comma separated list of server hostnames. Beware this is the narrowest filter,
# so if you set this to a single hostname and this hostname disappears from the
# Gluetun servers data due to an update, your container will no longer work
# until this filter is changed. I would suggest avoiding it unless you know this
# reliability risk.
# SERVER_HOSTNAMES=

# Filter only free tier servers by setting it to on. It defaults to off.
FREE_ONLY=off

# Filter only streaming servers by setting it to on. It defaults to off.
STREAM_ONLY=off

# Filter only secure core servers by setting it to on. It defaults to off.
SECURE_CORE_ONLY=off

# Filter only TOR servers by setting it to on. It defaults to off.
TOR_ONLY=off

# Filter only port-forwarding enabled (aka p2p) servers by setting it to on. It
# defaults to off.
PORT_FORWARD_ONLY=on
