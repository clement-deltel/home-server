# ---------------------------------------------------------------------------- #
#               ------- Directus Configuration File --------
# ---------------------------------------------------------------------------- #
# https://directus.io/docs/configuration/intro

# Telemetry
TELEMETRY=false

# WebSockets
WEBSOCKETS_ENABLED=true

# ---------------------------------------------------------------------------- #
#               ------- Administration User --------
# ---------------------------------------------------------------------------- #

ADMIN_EMAIL=${USER_EMAIL}
ADMIN_PASSWORD=${DIRECTUS_ADMIN_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Database --------
# ---------------------------------------------------------------------------- #

# DB_CLIENT="sqlite3"
# DB_FILENAME="/directus/database/data.db"
DB_CLIENT=pg
DB_HOST=db
DB_PORT=5432
DB_DATABASE=postgres
DB_USER=${DIRECTUS_DB_USER}
DB_PASSWORD=${DIRECTUS_DB_PASSWORD}

# ---------------------------------------------------------------------------- #
#               ------- Cache --------
# ---------------------------------------------------------------------------- #

REDIS_ENABLED=true
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=${DIRECTUS_CACHE_PASSWORD}

CACHE_ENABLED=true
CACHE_STORE=redis

# ---------------------------------------------------------------------------- #
#               ------- Security --------
# ---------------------------------------------------------------------------- #
# example: "255d861b-5ea1-5996-9aa3-922530ec40b1"
KEY=${DIRECTUS_KEY}

SECRET=${DIRECTUS_SECRET}

# ---------------------------------------------------------------------------- #
#               ------- SMTP --------
# ---------------------------------------------------------------------------- #

EMAIL_SMTP_HOST=${SMTP_HOST}
EMAIL_SMTP_PORT=${SMTP_PORT}
EMAIL_SMTP_USER=${SMTP_USERNAME}
EMAIL_SMTP_PASSWORD=${SMTP_PASSWORD}
EMAIL_SMTP_SECURE=true
